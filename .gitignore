# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
node_modules/

# ──────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# Prisma generated clients — rebuilt at dev/build time, never committed
apps/*/src/generated/

# ──────────────────────────────────────────────
# Environment files — ignore all variants, but keep the example as documentation
# ──────────────────────────────────────────────
.env*
!.env.example

# ──────────────────────────────────────────────
# Prisma
# Generated clients are rebuilt via `prisma generate` — never commit them
# Migrations ARE committed so the team can run them
# ──────────────────────────────────────────────
prisma/*/generated/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────
# Test coverage
# ──────────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ──────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
.vshistory/
MigrationBackup/

# VS Code
.vscode/
.history/
*.vsix

# JetBrains (WebStorm, Rider, etc.)
.idea/
*.iml

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
# Local Docker volume data — never commit database files
docker/data/
*.pid

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.pem
*.key
