# =============================================================
# EchoEngine — Environment Variable Reference
# =============================================================
# Copy the variables relevant to each app into their own .env:
#   apps/api/.env
#   apps/discord-bot/.env
#
# Never commit any .env file — only this example is tracked.
# =============================================================


# ── Shared / Infrastructure ───────────────────────────────────

NODE_ENV=development


# ── API (apps/api/.env) ───────────────────────────────────────

PORT=3000

# Primary database — use sslmode=verify-full for Neon/hosted Postgres
DATABASE_URL_PRIMARY=postgresql://user:password@host/echoengine_primary?sslmode=verify-full

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Shared secret for bot → API calls — must match API_KEY in apps/discord-bot/.env
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
BOT_API_KEY=change-this-to-a-random-string

# Discord OAuth2 (Developer Portal → your app → OAuth2 tab)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Must match exactly what is registered in the Developer Portal
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback


# ── Discord Bot (apps/discord-bot/.env) ───────────────────────

# Discord credentials (Developer Portal → your app → Bot tab)
BOT_TOKEN=your-bot-token-here
CLIENT_ID=your-client-id-here
GUILD_ID=your-test-guild-id-here

# Set DEPLOY=true on startup to push slash commands to Discord
# Use DEBUG=true to deploy to GUILD_ID only (instant) instead of globally (up to 1 hour)
DEPLOY=false
DEBUG=false

# Bot presence
BOT_STATUS=online
BOT_ACTIVITY_TYPE=WATCHING
BOT_ACTIVITY_TEXT=the echoes

# API connection
API_BASE_URL=http://localhost:3000

# Shared secret for bot → API calls — must match BOT_API_KEY in apps/api/.env
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
API_KEY=change-this-to-a-random-string
