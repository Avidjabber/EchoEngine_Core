// ----------------------
// Database Connection
// ----------------------
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../../apps/api/src/generated/prisma-primary"
}






// Discord users who have logged in via the website



// ============================================================
// AUTH
// ============================================================

model User {
  id            String         @id @default(cuid())
  discordId     String         @unique
  username      String
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@index([discordId])
}

// Refresh tokens for website users (short-lived access tokens + rotated refresh tokens)
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique  // stored as bcrypt hash — never the raw token
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Service clients (bot, worker, or any future machine-to-machine caller)
model ServiceClient {
  id           String   @id @default(cuid())
  name         String   @unique  // e.g. "discord-bot", "worker"
  clientId     String   @unique
  secretHash   String              // bcrypt hash of the client secret
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
}


// Global — one row per Discord user, applies across all servers
model UserSettings {
  userId  String @id  // Discord user ID

  isPremium Boolean @default(false)
  maxFactions   Int @default(10)
  maxRanks      Int @default(30)
  maxSpecies    Int @default(100)
  maxPlants     Int @default(100)

  // Premium feature toggles — only apply when isPremium = true
  premiumDoubleEnergy   Boolean @default(true)  // doubles daily energy cap from guild default
  premiumGuildBoosts    Boolean @default(true)  // applies premium cap increases to guilds the user owns
  premiumMoreEntities   Boolean @default(true)  // increases the global entity cap
  premiumRollBonus      Boolean @default(true)  // grants a bonus to dice rolls
  premiumCustomColor    Boolean @default(true)  // enables per-character embed color (hex stored in EntityBio)
  premiumLongerArchive  Boolean @default(true)  // extends isDeceased character archive retention

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

// ============================================================
// GUILD
// ============================================================







model GuildSettings {
  id       Int    @id @default(autoincrement())
  guildId  String @unique
  seasonId Int?
  season   Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  // Active weather pattern — null = no pattern running (Worker picks one at next daily tick)
  currentPatternId     Int?
  currentPatternStepId Int?       // FK to WeatherPatternStep — step carries weatherStateId; derive current weather from step at read time
  currentStepStartedAt DateTime? @db.Timestamptz // when the current step began; Worker uses this to advance steps

  currentPattern     WeatherPattern?     @relation(fields: [currentPatternId],     references: [id], onDelete: SetNull)
  currentPatternStep WeatherPatternStep? @relation(fields: [currentPatternStepId], references: [id], onDelete: SetNull)
  weatherCooldowns   Guild_WeatherPatternCooldown[]
  seasonDefaults     GuildSeason_DefaultWeather[]
  envConditionMods        EnvCondition_Modifier[]
  envConditionStatMods    EnvCondition_StatModifier[]
  envConditionProfMods    EnvCondition_ProficiencyModifier[]

  defaultDailyEnergy Int @default(100)  // baseline energy for all users; premium override stored in UserSettings
  doubleAgeMaxThreshold Int @default(0)  // cats at or below this age (in moons) age up twice per daily tick; 0 = disabled
  maxCombatRounds Int @default(50)  // maximum rounds before a combat fight is forced to end in a draw
  defaultProficiencyBonus Int @default(2)  // flat bonus added to skill rolls when an entity is proficient in that skill

  // Feature flags — disable entire subsystems guild-wide; all default to true (fully enabled)
  worldSimEnabled    Boolean @default(true)  // weather, seasons, environmental conditions, filth
  conditionsEnabled  Boolean @default(true)  // conditions, medicine, herb gathering, symptoms
  combatEnabled      Boolean @default(true)  // sparring, boss fights, combat steps in events
  activitiesEnabled  Boolean @default(true)  // patrols, hunts, action types
  eventsEnabled      Boolean @default(true)  // event chains (requires activitiesEnabled for activity-triggered events)
  craftingEnabled    Boolean @default(true)  // items, storage, crafting recipes, ingredient processing, food/prey
  progressionEnabled Boolean @default(true)  // energy, aging, EXP, skill points, faction reputation
  socialEnabled      Boolean @default(true)  // faction standings, entity relationships, family trees

  // Daily tick tracking — null = never ticked; updated by Worker after each daily processing run
  lastTickAt DateTime? @db.Timestamptz

  // Guild-wide event cooldown — null = no event has ever fired; updated whenever a global-scope event fires.
  // Worker skips firing any new global-scope event if now() < lastEventAt + EventDef.cooldownDays.
  lastEventAt DateTime? @db.Timestamptz

  // Guild-wide discipline level cap fallback. null = no cap.
  // Applies to all disciplines unless overridden by a Guild_DisciplineLevelCap row for that discipline.
  // Stat points are not capped — only discipline levels.
  disciplineLevelCap Int?

  // How many rep points an entity loses from Entity.factionRep per daily tick.
  // Tunable per guild — high-activity servers may want slower decay; low-activity ones faster.
  factionRepDecayRate Int @default(5)

  // Farming system — soil quality change rates applied by the daily tick worker.
  // soilDegradationFilth: subtracted from Plot.soilQuality per tick while Filth env condition is active on the plot's location.
  // soilDegradationToxic: subtracted from Plot.soilQuality per tick while Toxic env condition is active on the plot's location.
  // compostIncrement: added to Plot.soilQuality per compost_plot action, before PlotType.soilQualityCap is applied.
  farmingSoilDegradationFilth Float @default(0.02)
  farmingSoilDegradationToxic Float @default(0.05)
  farmingCompostIncrement     Float @default(0.10)

  disciplineLevelCaps Guild_DisciplineLevelCap[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt      @db.Timestamptz

  @@index([seasonId])
  @@index([currentPatternId])
  @@index([currentPatternStepId])
}

// ============================================================
// DEN
// ============================================================





model EchoDens {
  id        Int    @id @default(autoincrement())
  guildId   String
  channelId String

  allowWorldSim    Boolean @default(true)  // weather/env condition announcements
  allowConditions  Boolean @default(true)  // condition/medicine updates
  allowCombat      Boolean @default(true)  // combat messages
  allowActivities  Boolean @default(true)  // patrol/hunt activity messages
  allowEvents      Boolean @default(true)  // event chain messages
  allowCrafting    Boolean @default(true)  // crafting/item messages
  allowProgression Boolean @default(true)  // EXP/level-up/aging messages
  allowSocial      Boolean @default(true)  // relationship/standing messages

  @@unique([guildId, channelId])
}

// ============================================================
// SHARED LOOKUPS
// ============================================================






// Global seeded relation/effect type table. Developer-controlled — not user-editable.
// Boolean flags indicate which systems each value is valid for, allowing the app to
// filter valid options by context without hardcoding strings.
model RelationType {
  id                    Int     @id @default(autoincrement())
  name                  String  @unique @db.VarChar(50)
  isConditionSystem     Boolean @default(false)
  isStructureSystem     Boolean @default(false)
  isSkillSystem         Boolean @default(false)
  isItemSystem          Boolean @default(false)
  isCraftingSystem      Boolean @default(false)
  isEnvConditionSystem  Boolean @default(false)
  isOwnershipSystem     Boolean @default(false)

  conditionLinks                 ConditionDef_Link[]
  conditionEnvRules              ConditionDef_EnvRule[]
  itemEffects                    ItemEffect[]
  itemConditionEffects           ItemConditionEffect[]
  skillTreeRelations             SkillTreeNode_Relation[]
  upgradeRelations               StructureDef_Upgrade_Relation[]
  structureRelations             StructureDef_Relation[]
  craftingInteractionRules       Guild_CraftingInteractionRule[]
  recipeCraftingRequirements     Recipe_CraftingRequirement[]
  plantDefEnvConditionEffect     PlantDef_EnvConditionEffect[]
  plantTypeEnvConditionEffect    PlantType_EnvConditionEffect[]
  speciesEnvConditionEffect      Species_EnvConditionEffect[]
  speciesTypeEnvConditionEffect  SpeciesType_EnvConditionEffect[]
  envConditionModifiers          EnvCondition_Modifier[]
  campFactions                   Camp_Faction[]
  locationFactions               Location_Faction[]
}

model EffectType {
  id              Int     @id @default(autoincrement())
  name            String  @unique @db.VarChar(100)
  isItem          Boolean @default(false)
  isPlant         Boolean @default(false)
  isSpecies       Boolean @default(false)
  isAbility       Boolean @default(false)
  isEnvModifier   Boolean @default(false)  // valid for EnvCondition_Modifier (global world effects e.g. filth, spoilage)

  plantDefEnvConditionEffect      PlantDef_EnvConditionEffect[]
  plantTypeEnvConditionEffect     PlantType_EnvConditionEffect[]
  speciesEnvConditionEffect       Species_EnvConditionEffect[]
  speciesTypeEnvConditionEffect   SpeciesType_EnvConditionEffect[]

  abilityActionTrigger            Ability_ActionTrigger[]
  abilityPresenceEffects          Ability_PresenceEffect[]
  plotBuffs                       Plot_Buff[]
  envConditionModifiers           EnvCondition_Modifier[]
}


// Unified status table for entities and structures.
// isEntity / isStructure flags indicate which systems each value applies to.
model Status {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(50)
  isEntity    Boolean @default(false)
  isStructure Boolean @default(false)

  entities   Entity[]
  structures Structure[]
}

model EntityType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  canModifyStats       Boolean @default(false)
  canParticipateCombat Boolean @default(false)
  canParticipateEvents Boolean @default(false)
  adminOnly            Boolean @default(false)

  entities Entity[]
}

model Sex {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  entities Entity[]
}

model Gender {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  entities Entity[]
}

// Base stats
// Used as FK target for modifier tables; name matches the column on Entity
model Stat {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  envConditionModifiers  EnvCondition_StatModifier[]
  conditionStatEffects   ConditionDef_StatEffect[]
  eventChoiceDefs      EventChoiceDef[]
  proficiencyDefs                  ProficiencyDef[]
  profilesAsDamageStat ItemEquipmentProfile[] @relation("ProfileDamageStat")
  profilesAsHitStat    ItemEquipmentProfile[] @relation("ProfileHitStat")
  profilesAsHealStat   ItemEquipmentProfile[] @relation("ProfileHealStat")
  conditionCombatEffects       ConditionDef_CombatEffect[]
  abilityStatModifiers   Ability_StatModifier[]
}

// Symptom labels — shared between ConditionDef (via ConditionDef_SymptomTag) and ItemEffect.
// defaultRoll: examination roll threshold to reveal this symptom; 0 = always visible; null = not part of discovery system
model Symptom {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  defaultRoll Int?

  conditionSymptomTags ConditionDef_SymptomTag[]
  itemEffects          ItemEffect[]
}


// A reusable drop table owned by a species (loot on catch/kill) or a biome (gather yields).
model DropTable {
  id          Int     @id @default(autoincrement())
  guildId     String  @db.VarChar(50)

  entries             DropTable_Entry[]
  species             Species[]                  // species whose loot resolves from this table (catch/kill + NPC combat defeat)
  biomes              Biome[]                    // biomes whose gather yields resolve from this table
  combatParticipants  ActiveCombat_Participant[]  // snapshotted per-participant at combat spawn
  plantDefHarvests    PlantDef[]                 @relation("PlantDefHarvestDrop")
  @@index([guildId])
}

// One item entry within a drop table
model DropTable_Entry {
  id          Int   @id @default(autoincrement())
  dropTableId Int

  itemId           Int
  dropChance       Int   @default(100)     // 100 = always drops, 0 = never drops.
  averageQuantity  Int?                // average quantity dropped (in item's unit), overwrites the item count
  quantityVariance Float @default(0.3)   // ± fraction applied to averageQuantity;
  averageWeight    Float?                // average weight dropped (in item units), overwrites the item weight
  weightVariance   Float @default(0.3)   // ± fraction applied to averageWeight;
  averageVolume    Float?                 // average volume dropped (in item units), overwrites the item volume
  volumeVariance   Float @default(0.3)   // ± fraction applied to averageVolume;

  dropTable DropTable @relation(fields: [dropTableId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId],      references: [id], onDelete: Restrict)

  @@unique([dropTableId, itemId])
  @@index([dropTableId])
  @@index([itemId])
}


// Measurement units for ingredient quantities
model MeasurementType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)
  unit String @db.VarChar(20)  // display label: "g", "units", "ml"

  ingredientTypes  IngredientType[]
  recipeSlots      RecipeSlot[]
  items            Item[]
  recipeOutputs    RecipeOutput[]
  compostDeposits  Structure_CompostDeposit[]
  compostOutputs   Item_CompostOutput[]
}

// Ingredient classification labels — internal to the crafting system (global seed, no guildId).
// Each type has one canonical measurement unit. Examples: Powder → Weight, Stick → Count, Liquid → Volume.
model IngredientType {
  id                Int    @id @default(autoincrement())
  name              String @unique @db.VarChar(100)
  measurementTypeId Int?   // null = descriptive/modifier tag with no canonical measurement (e.g. Sweet, Dried, Cooked)
                           // The recipe slot's own measurementTypeId always governs quantity; this is advisory only.

  measurementType MeasurementType? @relation(fields: [measurementTypeId], references: [id], onDelete: Restrict)

  itemIngredientTypes    Item_IngredientType[]
  slotOptionRequiredTags RecipeSlotOption_RequiredTag[]
  slotOptionExcludedTags RecipeSlotOption_ExcludedTag[]
  recipeOutputAddTags    RecipeOutput_AddTag[]
  recipeOutputRemoveTags RecipeOutput_RemoveTag[]

  @@index([measurementTypeId])
}

// ============================================================
// ENVIRONMENT
// ============================================================







// Seasons
// envConditionId — the one named condition this season always contributes 1 stack of (its own seasonal condition).
// RULE: each season maps to exactly one env condition; null only during initial setup.
model Season {
  id             Int  @id @default(autoincrement())
  name           String @unique @db.VarChar(50)
  envConditionId Int?

  envCondition   EnvCondition?              @relation(fields: [envConditionId], references: [id], onDelete: Restrict)
  guilds         GuildSettings[]
  patternWeights Season_WeatherPattern[]
  guildDefaults  GuildSeason_DefaultWeather[]

  @@index([envConditionId])
}

// A discrete named weather state.
// isSevere — state may only appear in admin-triggered patterns; Worker never picks these naturally.
// Duration is defined on WeatherPatternStep, not here — the same state can last different amounts
// of time in different patterns.
model WeatherState {
  id       Int     @id @default(autoincrement())
  guildId  String  @default("global") @db.VarChar(50)
  codeName String  @db.VarChar(200)  // snake_case slug; unique per guild
  name     String  @db.VarChar(100)
  isSevere Boolean @default(false)

  envConditions        WeatherState_EnvCondition[]
  patternSteps         WeatherPatternStep[]
  eventWeatherTriggers EventDef_WeatherTrigger[]
  guildSeasonDefaults  GuildSeason_DefaultWeather[]

  abilityStatModifiers        Ability_StatModifier[]
  abilityProficiencyModifiers Ability_ProficiencyModifier[]
  abilityMultiplierEffects    Ability_MultiplierEffect[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
}

// Named environmental conditions — discrete modifier labels applied by seasons, weather states, biomes, and locations.


model EnvCondition {
  id       Int    @id @default(autoincrement())
  codeName String @unique @db.VarChar(100)  // snake_case slug; stable lookup key
  name     String @db.VarChar(100)

  seasons             Season[]
  weatherStateEntries WeatherState_EnvCondition[]
  biomeEntries       Biome_EnvCondition[]
  locationEntries    Location_EnvCondition[]
  statModifiers      EnvCondition_StatModifier[]
  proficiencyModifiers     EnvCondition_ProficiencyModifier[]
  worldModifiers     EnvCondition_Modifier[]
  eventWeights       EnvCondition_EventDef[]
  conditionEnvRules             ConditionDef_EnvRule[]
  plantDefEffects               PlantDef_EnvConditionEffect[]
  plantTypeEffects              PlantType_EnvConditionEffect[]
  speciesEffects                Species_EnvConditionEffect[]
  speciesTypeEffects            SpeciesType_EnvConditionEffect[]
  plotTypeEnvConditions         PlotType_EnvCondition[]
  structureUpgradeEffects       StructureDef_Upgrade_Effect[]
  passiveGeneratorConditions    StructureDef_FuelConfig_EnvCondition[]
}

// Environmental conditions active during a weather state (e.g. Storm → Damp, Windy)
// Each active source contributes a stack of 1; totals are summed across season + weather + biomes + location.
model WeatherState_EnvCondition {
  weatherStateId Int
  envConditionId Int

  weatherState WeatherState @relation(fields: [weatherStateId], references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)

  @@id([weatherStateId, envConditionId])
  @@index([envConditionId])
}

// A named sequence of weather states that plays out over a day.
// isSevere     — admin-triggered only; Worker never picks these during normal daily selection.
// cooldownDays — minimum days before this pattern can be selected again for the same guild.
model WeatherPattern {
  id           Int     @id @default(autoincrement())
  guildId      String  @default("global") @db.VarChar(50)
  codeName     String  @db.VarChar(200)  // snake_case slug; unique per guild
  name         String  @db.VarChar(100)
  isSevere     Boolean @default(false)
  cooldownDays Int     @default(0)

  steps          WeatherPatternStep[]
  seasonWeights  Season_WeatherPattern[]
  guildCooldowns Guild_WeatherPatternCooldown[]
  guilds         GuildSettings[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
}

// An ordered step within a weather pattern.
// weatherStateId null = use the current season's defaultWeatherStateId (calm/baseline day).
// durationHours — how long this step lasts in hours; Worker advances to the next step when elapsed.
model WeatherPatternStep {
  id              Int  @id @default(autoincrement())
  patternId       Int
  stepOrder       Int
  weatherStateId  Int?
  durationHours Int

  pattern      WeatherPattern  @relation(fields: [patternId],      references: [id], onDelete: Cascade)
  weatherState WeatherState?   @relation(fields: [weatherStateId], references: [id], onDelete: Restrict)
  guilds       GuildSettings[]

  @@unique([patternId, stepOrder])
  @@index([weatherStateId])
}

// Relative spawn weight for a weather pattern within a given season.
// Worker normalises weights across eligible (non-severe, off-cooldown) patterns to pick the day's pattern.
model Season_WeatherPattern {
  seasonId  Int
  patternId Int
  weight    Float @default(1.0)

  season  Season         @relation(fields: [seasonId],  references: [id], onDelete: Cascade)
  pattern WeatherPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@id([seasonId, patternId])
  @@index([patternId])
}

// Per-guild default weather state for each season.
// Used when a WeatherPatternStep has no explicit weatherStateId (null step = "calm baseline").
// Seeded by seedWeather; guilds can override these after initial setup.
model GuildSeason_DefaultWeather {
  guildId        String
  seasonId       Int
  weatherStateId Int

  guild        GuildSettings @relation(fields: [guildId],        references: [guildId], onDelete: Cascade)
  season       Season        @relation(fields: [seasonId],       references: [id],      onDelete: Cascade)
  weatherState WeatherState  @relation(fields: [weatherStateId], references: [id],      onDelete: Cascade)

  @@id([guildId, seasonId])
  @@index([seasonId])
  @@index([weatherStateId])
}

// Per-guild cooldown tracking for weather patterns.
// Worker skips a pattern if now() < lastRunAt + pattern.cooldownDays.
model Guild_WeatherPatternCooldown {
  guildId   String
  patternId Int
  lastRunAt DateTime @db.Timestamptz

  guild   GuildSettings  @relation(fields: [guildId],   references: [guildId], onDelete: Cascade)
  pattern WeatherPattern @relation(fields: [patternId], references: [id],      onDelete: Cascade)

  @@id([guildId, patternId])
  @@index([patternId])
}

// Per-guild, per-env-condition world effect modifiers. One row per (guild, envCondition, effectType).
// effectTypeId must have EffectType.isEnvModifier = true (e.g. filth, spoilage).
// relationTypeId (isEnvConditionSystem = true) — increase | decrease | block
// value: magnitude of effect (> 0.0); null when relationTypeId = "block" (block has no magnitude).
// Each guild defines its own modifier values — no global defaults.
model EnvCondition_Modifier {
  guildId        String @db.VarChar(50)
  envConditionId Int
  effectTypeId   Int
  relationTypeId Int
  value          Float?  // null when block

  guild        GuildSettings @relation(fields: [guildId],        references: [guildId], onDelete: Cascade)
  envCondition EnvCondition  @relation(fields: [envConditionId], references: [id],      onDelete: Cascade)
  effectType   EffectType    @relation(fields: [effectTypeId],   references: [id],      onDelete: Restrict)
  relationType RelationType  @relation(fields: [relationTypeId], references: [id],      onDelete: Restrict)

  @@id([guildId, envConditionId, effectTypeId])
  @@index([guildId])
  @@index([envConditionId])
  @@index([effectTypeId])
  @@index([relationTypeId])
}

// Per-guild stat modifier applied when an environmental condition is active.
// value is applied once per active stack — two sources of Cold each apply the modifier independently.
model EnvCondition_StatModifier {
  guildId        String @db.VarChar(50)
  envConditionId Int
  statId         Int
  value          Float  // flat additive modifier; applied once per active stack

  guild        GuildSettings @relation(fields: [guildId],        references: [guildId], onDelete: Cascade)
  envCondition EnvCondition  @relation(fields: [envConditionId], references: [id],      onDelete: Cascade)
  stat         Stat          @relation(fields: [statId],         references: [id],      onDelete: Restrict)

  @@id([guildId, envConditionId, statId])
  @@index([guildId])
  @@index([envConditionId])
  @@index([statId])
}

// Per-guild proficiency roll modifier applied when an environmental condition is active.
// value is applied once per active stack — two sources of Cold each apply the modifier independently.
// hasDisadvantage triggers if at least one stack is active (not per stack).
model EnvCondition_ProficiencyModifier {
  guildId          String @db.VarChar(50)
  envConditionId   Int
  proficiencyDefId Int
  value            Float   @default(0.0)  // flat additive modifier to the skill roll; applied once per active stack
  hasDisadvantage  Boolean @default(false) // triggers if at least one stack is active (not per stack)

  guild        GuildSettings  @relation(fields: [guildId],          references: [guildId], onDelete: Cascade)
  envCondition EnvCondition   @relation(fields: [envConditionId],   references: [id],      onDelete: Cascade)
  proficiency  ProficiencyDef @relation(fields: [proficiencyDefId], references: [id],      onDelete: Cascade)

  @@id([guildId, envConditionId, proficiencyDefId])
  @@index([guildId])
  @@index([envConditionId])
  @@index([proficiencyDefId])
}


// A named biome / terrain type. Determines what species spawn here and what can be gathered.
// Guild-extensible; guildId = "global" for seeded defaults (Forest, Moorland, River, etc.)
model Biome {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  color       Int?                        // Discord-style integer color (decimal value of RRGGBB hex)

  dropTableId Int?
  dropTable   DropTable? @relation(fields: [dropTableId], references: [id], onDelete: SetNull)

  locations    Location_Biome[]
  species      Species_Biome[]
  envConditions Biome_EnvCondition[]

  abilityStatModifiers        Ability_StatModifier[]
  abilityProficiencyModifiers Ability_ProficiencyModifier[]
  abilityMultiplierEffects    Ability_MultiplierEffect[]
  plantDefBiomes              PlantDef_Biome[]

  @@unique([guildId, name])
  @@index([guildId])
  @@index([dropTableId])
}

// Inherent environmental conditions for a biome — always active regardless of weather or season.
// e.g. Wetland biome always contributes a stack of Damp; River biome always contributes Damp.
// A location with multiple biomes stacks each biome's conditions independently.
model Biome_EnvCondition {
  biomeId        Int
  envConditionId Int
  stacks         Int @default(1)  // number of stacks this biome contributes; minimum 1 (enforced app-side)

  biome        Biome        @relation(fields: [biomeId],        references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)

  @@id([biomeId, envConditionId])
  @@index([envConditionId])
}

// ============================================================
// ENTITY & SPECIES
// ============================================================






// A species can belong to multiple types; types connect to different gameplay systems.
model SpeciesType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  species                       Species_SpeciesType[]
  speciesTypeEnvConditionEffect SpeciesType_EnvConditionEffect[]
}

// Species (guild-extensible; guildId = "global" for pre-seeded options e.g. Cat, Fox, Badger)
// Age brackets are universal (child / teen / adult / elder); thresholds are species-specific (in moons for Cat).
// App resolves bracket: age <= childMaxAge → child; <= teenMaxAge → teen; <= adultMaxAge → adult; else → elder.
// Nutrition and hydration drain rates are per-bracket; food digestion multipliers are per food category (Meat, Plant).
//
// Base combat stats: used directly for NPC instances of this species.
//   For player entities, these serve as the species reference point — players distribute their own
//   stats individually (stored on EntityStats), but the species baseline informs starting values.
//
// HP dice formula (hpDiceCount + hpDiceSides):
//   Represents the hit dice for this species, e.g. hpDiceCount=2, hpDiceSides=10 → 2d10.
//   Players roll hpDiceCount d hpDiceSides + CON modifier on character creation.
//   NPC instances always use the floor average: floor(hpDiceCount * hpDiceSides / 2) + CON modifier.
//   CON modifier = floor((constitution - 10) / 2), same formula as D&D.
//   Example: Cat 2d10, base CON 10 → modifier 0 → NPC maxHp = floor(20/2) + 0 = 10.
model Species {
  id       Int    @id @default(autoincrement())
  guildId  String @default("global") @db.VarChar(50)
  codeName String @db.VarChar(200)  // snake_case slug; unique per guild
  name     String @db.VarChar(100)

  // Stat allocation rules — enforced at app layer on character creation and stat point spending
  initialStatMinimum Int @default(1)   // minimum value any stat can be set to during character creation
  initialStatMaximum Int @default(14)  // maximum value any stat can be set to during character creation
  totalStartingStats Int @default(60)  // total points available to distribute across all stats at creation
  statCap            Int @default(20)  // hard ceiling a stat can reach through raw stat points on the character (does not include items, conditions, etc.)

  // Age bracket upper bounds (inclusive, in the species' age unit e.g. moons for Cat)
  childMaxAge Int  // 0–childMaxAge            = child
  teenMaxAge  Int  // childMaxAge+1–teenMaxAge  = teen
  adultMaxAge Int  // teenMaxAge+1–adultMaxAge  = adult; above = elder

  // Daily nutrition and hydration drain per age bracket.
  // Worker looks up the entity's current bracket (age vs. childMaxAge/teenMaxAge/adultMaxAge)
  // and drains Entity.nutritionLevel / hydrationLevel by these amounts each cycle.
  childNutritionDrain Float
  teenNutritionDrain  Float
  adultNutritionDrain Float
  elderNutritionDrain Float

  childHydrationDrain Float
  teenHydrationDrain  Float
  adultHydrationDrain Float
  elderHydrationDrain Float

  // Food digestion multipliers — applied per category when computing nutrition/hydration gained from eating.
  // net = quantity × ItemFoodProfile.*PerGram × species multiplier
  // Default 1.0; carnivores set plantNutritionMultiplier low (~0.1); omnivores near 1.0 for both.
  meatNutritionMultiplier  Float @default(1.0)
  meatHydrationMultiplier  Float @default(1.0)
  plantNutritionMultiplier Float @default(1.0)
  plantHydrationMultiplier Float @default(1.0)

  // Daily filth contribution per bracket
  childFilthPerDay Float
  teenFilthPerDay  Float
  adultFilthPerDay Float
  elderFilthPerDay Float

  // Base combat stats — all default to 10 (the baseline)
  baseStrength     Int @default(10)  // physical power, melee damage
  baseDexterity    Int @default(10)  // movement, AC modifier, initiative
  baseConstitution Int @default(10)  // health pool and illness resistance
  baseIntelligence Int @default(10)  // reasoning, learned knowledge
  baseWisdom       Int @default(10)  // instinct, perception, environmental judgment
  baseCharisma     Int @default(10)  // leadership, social influence, morale
  baseAc           Int @default(10)  // racial AC floor; effective AC = baseAc + floor((dexterity - 10) / 2)
  hpDiceCount      Int @default(2)   // number of dice rolled for HP (e.g. 2 for 2d10)
  hpDiceSides      Int @default(10)  // sides per die (e.g. 10 for 2d10)

  combatRating    Float @default(1.0)   // CR used by encounter generator to fill a max-CR budget
  combatXpReward  Int   @default(50)    // Combat discipline XP granted to each victor on defeating an entity of this species

  dropTableId Int?
  dropTable   DropTable? @relation(fields: [dropTableId], references: [id], onDelete: SetNull)

  entities            Entity[]
  bodyParts           BodyPart[]
  combatBehavior      SpeciesCombatBehavior?
  defaultLoadout      SpeciesDefaultLoadout[]
  encounterDefs       CombatEncounterDef[]
  biomes                Species_Biome[]
  envConditionEffects   Species_EnvConditionEffect[]
  defaultAbilities      Species_DefaultAbility[]
  equipmentLoadout    Species_EquipmentLoadout[]
  speciesTypes        Species_SpeciesType[]
  summonedByProfiles  ItemEquipmentProfile[]     @relation("ProfileSummonSpecies")

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])  // non-unique display name lookup
}

// Per-species equipment slot capacity overrides.
// If no row exists for a given slotTypeId, fall back to EquipmentSlotType.defaultCapacity.
model Species_EquipmentLoadout {
  speciesId  Int
  slotTypeId Int
  capacity   Int  // overrides EquipmentSlotType.defaultCapacity for this species

  species  Species           @relation(fields: [speciesId],  references: [id], onDelete: Cascade)
  slotType EquipmentSlotType @relation(fields: [slotTypeId], references: [id], onDelete: Restrict)

  @@id([speciesId, slotTypeId])
  @@index([slotTypeId])
}

model Species_SpeciesType {
  speciesId     Int
  speciesTypeId Int

  species     Species     @relation(fields: [speciesId],     references: [id], onDelete: Cascade)
  speciesType SpeciesType @relation(fields: [speciesTypeId], references: [id], onDelete: Restrict)

  @@id([speciesId, speciesTypeId])
  @@index([speciesTypeId])
}

// Biomes a prey or predator species can inhabit — pure presence join
model Species_Biome {
  speciesId   Int
  biomeId     Int
  spawnRate   Float @default(100)

  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  biome   Biome   @relation(fields: [biomeId],   references: [id], onDelete: Restrict)

  @@id([speciesId, biomeId])
  @@index([biomeId])
}

model SpeciesType_EnvConditionEffect {
  id             Int  @id @default(autoincrement())
  speciesTypeId  Int
  envConditionId Int
  relationTypeId Int
  effectTypeId   Int?
  value          Float?

  speciesType  SpeciesType   @relation(fields: [speciesTypeId],  references: [id], onDelete: Cascade)
  envCondition EnvCondition  @relation(fields: [envConditionId], references: [id], onDelete: Restrict)
  relationType RelationType  @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)
  effectType   EffectType?   @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)

  @@unique([speciesTypeId, envConditionId, relationTypeId, effectTypeId])
  @@index([speciesTypeId])
  @@index([envConditionId])
}

// Per-species response to an active env condition during encounter resolution. Overrides SpeciesType_EnvConditionEffect
// No row = neutral (no effect). One species can have multiple rows for the same
model Species_EnvConditionEffect {
  id             Int  @id @default(autoincrement())
  speciesId      Int
  envConditionId Int
  relationTypeId Int
  effectTypeId   Int?
  value          Float?

  species      Species       @relation(fields: [speciesId],      references: [id], onDelete: Cascade)
  envCondition EnvCondition  @relation(fields: [envConditionId], references: [id], onDelete: Restrict)
  relationType RelationType  @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)
  effectType   EffectType?   @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)

  @@unique([speciesId, envConditionId, relationTypeId, effectTypeId])
  @@index([speciesId])
  @@index([envConditionId])
}

// Named body part for a specific species — used to record injury location on EntityCondition
// Seeded per species; guild-extensible for custom species in future
model BodyPart {
  id        Int    @id @default(autoincrement())
  speciesId Int
  name      String @db.VarChar(100)

  species          Species           @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  entityConditions EntityCondition[]

  @@unique([speciesId, name])
  @@index([speciesId])
}

model Entity {
  id      Int    @id @default(autoincrement())
  guildId String
  userId  String?  // null for NPC entities (entityType = "npc")

  name String @db.VarChar(200)

  statusId Int
  status   Status       @relation(fields: [statusId], references: [id], onDelete: Restrict)

  typeId Int
  type   EntityType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  speciesId Int
  species   Species @relation(fields: [speciesId], references: [id], onDelete: Restrict)

  age      Int     @default(0)
  isDeceased Boolean @default(false)
  factionRep  Int     @default(0)  // individual rep within own faction; 0–500, clamped at app layer; decays by GuildSettings.factionRepDecayRate per daily tick. Every 100 = +1 to all stat rolls. Distinct from Faction.factionRep (collective score).

  // Hunger and hydration — drained daily by the worker; raised by eating.
  // Worker distributes food from faction storage automatically; manual eating is the fallback.
  // Condition system maps threshold breaches to hunger/thirst condition chains.
  // Drain rates are not stored here — derived at runtime from Species.*NutritionDrain / *HydrationDrain
  // fields based on the entity's current age bracket.
  nutritionLevel Float @default(100.0)  // current nutrition (0–100); worker drains per cycle
  hydrationLevel Float @default(100.0)  // current hydration (0–100); worker drains per cycle

  sexId    Int?
  genderId Int?
  sex    Sex?    @relation(fields: [sexId],    references: [id], onDelete: SetNull)
  gender Gender? @relation(fields: [genderId], references: [id], onDelete: SetNull)

  factionId Int?
  rankId  Int?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  faction Faction? @relation(fields: [factionId], references: [id], onDelete: SetNull)
  rank  Rank?  @relation(fields: [rankId],  references: [id], onDelete: SetNull)

  stats         EntityStats?
  bio           EntityBio?
  images        EntityImage[]
  proficiencies Entity_Proficiency[]
  disciplines   Entity_Discipline[]
  abilities     Entity_Ability[]
  skillTreeNodes Entity_SkillTreeNode[]
  conditions        EntityCondition[] @relation("EntityConditions")
  appliedConditions EntityCondition[] @relation("AppliedConditions")
  behaviorCounters EntityBehaviorCounter[]

  entityStorage          Entity_Storage[]
  housing                Entity_Housing?
  constructionsInitiated Construction[]
  plotBuffs              Plot_Buff[]

  actionParticipations  ActionInstance_Entity[]
  actionLeaderships     ActionInstance[]          @relation("ActionInstanceLeader")
  eventParticipations   ActiveEvent_Participant[]
  combatParticipations  ActiveCombat_Participant[]
  combatActionsPerformed ActiveCombat_Action[] @relation("CombatActionActor")
  combatActionsTargeted  ActiveCombat_Action[] @relation("CombatActionTarget")
  namedEncounterDefs     CombatEncounterDef_NamedEntity[]

  relationships EntityRelationship[] @relation("EntityRelationshipsFrom")
  relatedTo     EntityRelationship[] @relation("EntityRelationshipsTo")

  discoveredRecipes    Entity_DiscoveredRecipe[]
  actionUsage          Entity_ActionUsage[]

  inspectionsAsPatient EntityInspectionLog[] @relation("InspectionPatient")
  inspectionsAsMedic   EntityInspectionLog[] @relation("InspectionMedic")
  treatmentsGiven      EntityTreatmentLog[]  @relation("TreatmentMedic")

  @@index([guildId, userId])
  @@index([factionId])
  @@index([rankId])
  @@index([statusId])
  @@index([typeId])
  @@index([speciesId])
  @@index([sexId])
  @@index([genderId])
}

// One-to-one stats record; only created for entity types that use stats
model EntityStats {
  entityId     Int @id

  skillPoints    Int @default(0)  // unallocated stat points waiting to be spent; earned via Entity_Discipline where DisciplineDef.isStatProgression = true
  currentEnergy  Int @default(0)  // current energy; replenished daily up to GuildSettings.defaultDailyEnergy (or premium override)

  // HP — set during character creation via a d20+CON modifier roll or taken as average; null until first set
  // maxHp reroll is available when constitution improves (requires moderator approval)
  maxHp     Int?   // maximum health pool
  currentHp Int?   // current health; persists between combats; null until maxHp is set

  // nutritionLevel and hydrationLevel live on Entity — not duplicated here

  strength     Int @default(10)  // physical power, melee damage, grappling
  dexterity    Int @default(10)  // movement, AC modifier, initiative, fine control
  constitution Int @default(10)  // health pool, illness resistance, endurance
  intelligence Int @default(10)  // learned knowledge, reasoning, problem-solving
  wisdom       Int @default(10)  // instinct, perception, environmental judgment
  charisma     Int @default(10)  // leadership, social influence, morale

  updatedAt DateTime @updatedAt @db.Timestamptz

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// Tracks integer state counters that drive behavior-based condition progression.
// counterKey — string identifier matching ConditionDef.behaviorCounterKey (e.g. 'hunger', 'exhaustion')
// value      — current counter; Worker increments/decrements each daily tick
//              e.g. hunger: +1 per unfed day, -1 per fed day, floor 0
// Row is created on first increment; deleted when value returns to 0 (app layer)
model EntityBehaviorCounter {
  entityId   Int
  counterKey String   @db.VarChar(50)
  value      Int      @default(0)
  updatedAt  DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([entityId, counterKey])
  @@index([counterKey])
}

// Images attached to an entity — one thumbnail (isThumbnail = true) and up to 5 gallery images.
// sortOrder is only meaningful for gallery images (isThumbnail = false).
model EntityImage {
  id          Int     @id @default(autoincrement())
  entityId    Int
  photoUrl    String  @db.VarChar(500)
  isThumbnail Boolean @default(false)
  sortOrder   Int     @default(0)

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

// One-to-one bio record for extended profile information
model EntityBio {
  entityId    Int     @id

  casualName  String? @db.VarChar(200)   // informal or nickname (e.g. "Fire" for Firestar)
  description String? @db.VarChar(1000)  // physical appearance
  personality String? @db.VarChar(1000)  // personality traits
  history     String? @db.VarChar(2000)  // backstory

  embedColor  String? @db.VarChar(7)    // hex color code e.g. #a3f0c2; only used if premiumCustomColor = true

  updatedAt DateTime @updatedAt @db.Timestamptz

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}


// An active or past condition instance on an entity.
// Covers both persistent conditions (injury, illness) and combat-scoped conditions (buffs, debuffs).
//
// bodyPartId: required when category = INJURY; must match entity's species body parts.
//
// sourceEntityId: the entity whose action caused this condition to be applied. Null for natural onset
//   (illness, environmental). Used by ConditionBehaviorEffect redirect target "source" to resolve the
//   correct entity, and by linked condition pairs (grapple, guard) to identify the other party.
//
// linkedConditionId: self-referential FK to the paired EntityCondition on another entity. Used for
//   mutually dependent conditions (e.g. "Grappling" on A linked to "Grappled" on B). When either is
//   removed, the app also removes the linked partner.
//
// Combat fields — only relevant when the condition was applied during combat:
//   combatInstancedOnly: when true the condition is removed at combat end (e.g. Rallying Cry, Weakened).
//     when false it persists after combat (e.g. Bite Wound, Poisoned).
//   appliedInCombatId: the combat that applied this condition; used to bulk-remove combatInstancedOnly
//     conditions and to tick ConditionDef_CombatEffect per-round damage at the right time.
//   combatRoundApplied / combatRoundExpires: round-limited effects (e.g. Rallying Cry lasts 2 rounds).
//     combatRoundExpires null = lasts until combat ends (for combatInstancedOnly) or indefinitely.
//   resolvedFlatModifier: snapshotted at application time for skill-derived conditions (e.g. Rallying Cry
//     stores the caster's computed Leadership bonus here). ConditionDef_CombatEffect uses this value
//     when its own flatModifier is null.
model EntityCondition {
  id             Int  @id @default(autoincrement())
  entityId       Int
  conditionDefId Int
  bodyPartId     Int?

  sourceEntityId   Int?  // entity whose action applied this condition; null for natural onset
  linkedConditionId Int? // paired EntityCondition on another entity (e.g. Grappling ↔ Grappled)

  onsetAt          DateTime? @db.Timestamptz
  progressionValue Float @default(1.0) // starts at 1.0; roll below difficultyRating → increases; treatment subtracts directly
                                       // clamped to 0.0; reaching 0.0 fires recoverToId path (or removes if null + endpointType = remove)
  lastTreatedAt    DateTime? @db.Timestamptz
  discoveryLevel   Int @default(0)     // highest examination roll; symptoms at or below this threshold are visible

  // Combat-scoped fields
  combatInstancedOnly  Boolean @default(false)
  appliedInCombatId    Int?
  appliedByActionId    Int?    // the ActiveCombat_Action that created this condition; null for out-of-combat onset
  combatRoundApplied   Int?
  combatRoundExpires   Int?  // null = lasts until combat end (combatInstancedOnly) or indefinite
  resolvedFlatModifier Int?  // snapshotted skill-derived modifier; used by ConditionDef_CombatEffect when flatModifier is null

  // Set at application when ConditionDef.durationMinutes is not null.
  // expiresAt = appliedAt + durationMinutes. App removes condition when this timestamp is reached.
  // Null = no time-based expiry on this instance.
  expiresAt DateTime? @db.Timestamptz

  updatedAt DateTime @updatedAt @db.Timestamptz

  entity          Entity               @relation("EntityConditions",    fields: [entityId],          references: [id], onDelete: Cascade)
  sourceEntity    Entity?              @relation("AppliedConditions",   fields: [sourceEntityId],    references: [id], onDelete: SetNull)
  linkedCondition EntityCondition?     @relation("LinkedConditions",    fields: [linkedConditionId], references: [id], onDelete: SetNull)
  linkedBy        EntityCondition[]    @relation("LinkedConditions")
  condition       ConditionDef         @relation(fields: [conditionDefId],    references: [id], onDelete: Restrict)
  bodyPart        BodyPart?            @relation(fields: [bodyPartId],        references: [id], onDelete: Restrict)
  appliedInCombat ActiveCombat?        @relation(fields: [appliedInCombatId], references: [id], onDelete: SetNull)
  appliedByAction ActiveCombat_Action? @relation(fields: [appliedByActionId], references: [id], onDelete: SetNull)
  treatmentLogs   EntityTreatmentLog[]

  // Allows the same condition on different body parts (scratch on tail AND scratch on leg)
  // For non-injury conditions (bodyPart = null), PostgreSQL treats NULLs as distinct; app enforces uniqueness
  @@unique([entityId, conditionDefId, bodyPartId])
  @@index([entityId])
  @@index([conditionDefId])
  @@index([sourceEntityId])
  @@index([linkedConditionId])
  @@index([appliedInCombatId])
  @@index([appliedByActionId])
}

// ============================================================
// RELATIONSHIPS & FACTIONS
// ============================================================







// Relationship Types
model RelationshipType {
  id           Int     @id @default(autoincrement())
  name     String  @unique @db.VarChar(50)
  label    String  @db.VarChar(100)  // display label (e.g. "Parent")
  isUnique Boolean @default(false)   // true = only one of this type allowed per entity

  relationships EntityRelationship[]
}

model EntityRelationship {
  id                 Int     @id @default(autoincrement())
  entityId           Int
  targetEntityId     Int
  relationshipTypeId Int
  isBiological       Boolean @default(false)

  // Populated only for Mentor relationships — tracks when the apprentice last requested a training session.
  // Used to enforce the once-per-day training request cooldown.
  lastMentorRequestAt DateTime? @db.Timestamptz

  entity   Entity           @relation("EntityRelationshipsFrom", fields: [entityId],           references: [id], onDelete: Cascade)
  target   Entity           @relation("EntityRelationshipsTo",   fields: [targetEntityId],     references: [id], onDelete: Cascade)
  relType  RelationshipType @relation(                           fields: [relationshipTypeId],  references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @db.Timestamptz

  @@unique([entityId, targetEntityId, relationshipTypeId])
  @@index([entityId])
  @@index([targetEntityId])
  @@index([relationshipTypeId])
}


model FactionStandingType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  standings FactionStanding[]
}

// Directional standing between two factions — one row per direction.
// factionId = the faction holding this view; targetFactionId = the faction being viewed.
// App creates/updates both directions independently to allow asymmetric standings.
model FactionStanding {
  factionId        Int
  targetFactionId  Int
  standingTypeId Int

  faction        Faction            @relation("FactionStandingFrom", fields: [factionId],        references: [id], onDelete: Cascade)
  targetFaction  Faction            @relation("FactionStandingTo",   fields: [targetFactionId],  references: [id], onDelete: Cascade)
  standingType FactionStandingType @relation(                    fields: [standingTypeId],  references: [id], onDelete: Restrict)

  @@id([factionId, targetFactionId])
  @@index([targetFactionId])
  @@index([standingTypeId])
}

model Faction {
  id          Int     @id @default(autoincrement())
  guildId     String
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild; stable lookup key
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  // Collective faction reputation score — modified by action completions, event outcomes, and admin adjustments.
  // Distinct from Entity.factionRep (individual score). See faction-system.md section 5.
  factionRep  Int     @default(0)

  // Faction-level event cooldown — null = no event has ever fired for this faction; updated whenever any event fires.
  // Worker skips firing any new event for this faction if now() < lastEventAt + EventDef.cooldownDays.
  lastEventAt DateTime? @db.Timestamptz

  // Water access — assumed true for most factions (river, stream nearby).
  // Worker uses this for baseline hydration: if true, water drinking is available and covers hydration not met by food.
  // Set false during drought events or to model desert/arid territories.
  hasWaterAccess Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  members                  Entity[]
  locations                Location_Faction[]
  borders                  LocationBorder[]
  camps                    Camp_Faction[]
  ranks                    Rank_Faction[]
  activeEvents             ActiveEvent[]
  actionInstances          ActionInstance[]
  // no recipeDiscoveries — discovery is tracked per entity, not per faction
  standingsFrom            FactionStanding[]           @relation("FactionStandingFrom")
  standingsTo              FactionStanding[]           @relation("FactionStandingTo")

  @@unique([guildId, codeName])
  @@unique([guildId, name])
  @@index([guildId])
}


model Rank {
  id          Int     @id @default(autoincrement())
  guildId     String
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  sortOrder     Int     @default(0)  // lower = higher seniority (e.g. 0 = leader, 1 = deputy, 2 = senior warrior); used for display ordering and hierarchy comparisons
  maxCount      Int?    // null = unlimited; max entities that can hold this rank simultaneously
  canMentor     Boolean @default(false)  // true = entities with this rank may act as a mentor
  canBeMentored Boolean @default(false)  // true = entities with this rank may be assigned a mentor
  canLeadEvents Boolean @default(false)  // true = entities with this rank may fill the leader slot on events that requiresLeader = true

  members              Entity[]
  factions               Rank_Faction[]
  defaultItems         Rank_DefaultItem[]

  @@unique([guildId, name])
  @@index([guildId])
}

// Assigns a rank to one or more factions — rank must have at least one faction (enforced at app layer)
// Only entities whose faction is listed here may be assigned this rank
model Rank_Faction {
  rankId  Int
  factionId Int

  rank  Rank  @relation(fields: [rankId],  references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@id([rankId, factionId])
  @@index([factionId])
}

// Items shadow-added to an entity's inventory when they are assigned this rank, and removed when the rank changes.
// Intended for equippable items only (weapons, armor, spells, biological traits are not needed here).
// autoEquip = true  → front-end immediately equips the item on the entity as well as adding it to inventory
// autoEquip = false → item is added to inventory only; entity or leader equips it manually
model Rank_DefaultItem {
  rankId     Int
  itemId     Int
  autoEquip  Boolean @default(true)

  rank Rank @relation(fields: [rankId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([rankId, itemId])
  @@index([itemId])
}

// ============================================================
// SKILLS & DISCIPLINES
// ============================================================






// Skills (guild-extensible; guildId = "global" for seeded skills)
//
// Each skill is governed by exactly one stat (D&D style). Roll = 1d20 + stat modifier.
// If the entity is proficient in the skill, add the guild proficiency bonus on top.
model ProficiencyDef {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)

  statId Int   // the single governing stat for this skill
  stat   Stat  @relation(fields: [statId], references: [id], onDelete: Restrict)

  entityProficiencies          Entity_Proficiency[]
  conditionEffects             ConditionDef_ProficiencyEffect[]
  abilityProficiencyModifiers  Ability_ProficiencyModifier[]
  envConditionMods           EnvCondition_ProficiencyModifier[]
  eventChoiceDefs            EventChoiceDef[]
  combatActionConditions      ItemEquipmentProfile_Condition[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
  @@index([statId])
}

model Entity_Proficiency {
  entityId   Int
  proficiencyDefId Int

  bonus        Int     @default(0)
  isProficient Boolean @default(false) // true = GuildSettings.defaultProficiencyBonus is added to the roll

  entity   Entity   @relation(fields: [entityId],   references: [id], onDelete: Cascade)
  proficiencyDef ProficiencyDef @relation(fields: [proficiencyDefId], references: [id], onDelete: Restrict)

  @@id([entityId, proficiencyDefId])
  @@index([entityId])
}

// Global seeded disciplines — the same seven apply to every entity in every guild.
// XP required for level N is computed at the app layer using baseXp as the level-1 threshold.
model DisciplineDef {
  id       Int    @id @default(autoincrement())
  codeName String @unique @db.VarChar(100)  // snake_case slug; stable lookup key used in app logic
  name     String @unique @db.VarChar(100)
  description String? @db.VarChar(500)

  // XP needed to reach level 1 (disciplines) or to earn one stat point (stat progression row).
  // For disciplines: xpRequired(level) = floor(baseXp × level^1.5)
  // For the stat progression row: threshold is flat — baseXp every time, no scaling.
  baseXp Int @default(100)

  // True for the single seeded row that tracks stat point progression.
  // App excludes this row from discipline listings and applies flat-threshold logic instead of the level curve.
  isStatProgression Boolean @default(false)

  // Max stat progression XP an entity may earn in a single day from this row.
  // null = no daily cap (all discipline rows). Only meaningful on the stat progression row.
  dailyXpCap Int?

  entityDisciplines             Entity_Discipline[]
  skillTreeNodes                SkillTreeNode[]
  skillTreeNodeRequirements     SkillTreeNode_DisciplineRequirement[]
  actionRewards                 ActionType_DisciplineReward[]
  actionRequirements            ActionType_DisciplineRequirement[]
  actionInstanceXp              ActionInstance_Entity_DisciplineXp[]
  recipeRewards                 Recipe_DisciplineReward[]
  abilityActionTriggerXpGrants  Ability_ActionTrigger[]
  craftingInteractionRules      Guild_CraftingInteractionRule[]
  recipeCraftingRequirements    Recipe_CraftingRequirement[]
  guildLevelCaps                Guild_DisciplineLevelCap[]
}

// Per-guild per-discipline level cap override.
// Overrides GuildSettings.disciplineLevelCap for this specific discipline.
// If no row exists for a discipline, GuildSettings.disciplineLevelCap applies as the fallback.
// null fallback = no cap for that discipline.
model Guild_DisciplineLevelCap {
  guildId         String @db.VarChar(50)
  disciplineDefId Int
  levelCap        Int

  guild           GuildSettings @relation(fields: [guildId],         references: [guildId], onDelete: Cascade)
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id],      onDelete: Restrict)

  @@id([guildId, disciplineDefId])
  @@index([disciplineDefId])
}

// Per-entity discipline progression. A row is created for every discipline at entity creation.
model Entity_Discipline {
  entityId      Int
  disciplineId  Int

  level     Int @default(0)
  currentXp Int @default(0)

  entity     Entity        @relation(fields: [entityId],     references: [id], onDelete: Cascade)
  discipline DisciplineDef @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@id([entityId, disciplineId])
  @@index([entityId])
}


// A guild-defined node in the skill tree for a specific discipline.
// levelRequired: entity's discipline level must be >= this to unlock the node.
// statPointCost: stat points needed to purchase; 0 = free but still requires explicit player purchase.
model SkillTreeNode {
  id              Int    @id @default(autoincrement())
  guildId         String @db.VarChar(50)
  disciplineDefId Int
  abilityDefId    Int?   // null = gate-only node (level requirement with no ability grant)
  name            String @db.VarChar(200)  // human-readable; unique per guild across all discipline trees
  levelRequired   Int
  statPointCost   Int    @default(0)

  disciplineDef  DisciplineDef  @relation(fields: [disciplineDefId], references: [id], onDelete: Restrict)
  abilityDef     AbilityDef?    @relation(fields: [abilityDefId],    references: [id], onDelete: Restrict)

  // Relations to/from other nodes: REQUIRES, BLOCKS, or UPGRADES (see SkillTreeNode_Relation).
  relations  SkillTreeNode_Relation[] @relation("NodeRelations")
  relatedTo  SkillTreeNode_Relation[] @relation("RelationTarget")

  disciplineRequirements     SkillTreeNode_DisciplineRequirement[]
  entityProgress             Entity_SkillTreeNode[]
  craftingInteractionRules   Guild_CraftingInteractionRule[]
  recipeCraftingRequirements Recipe_CraftingRequirement[]

  @@unique([guildId, name])
  @@index([guildId])
  @@index([disciplineDefId])
  @@index([abilityDefId])
}

// Cross-discipline prerequisites for a skill tree node.
// A node may require the entity to meet a minimum level in one or more OTHER disciplines
// in addition to its own levelRequired. All rows must be satisfied before the node unlocks.
// Example: a "Combat Medic" Healing node with levelRequired = 3 also requires Combat level 5.
model SkillTreeNode_DisciplineRequirement {
  nodeId          Int
  disciplineDefId Int
  levelRequired   Int

  node          SkillTreeNode @relation(fields: [nodeId],          references: [id], onDelete: Cascade)
  disciplineDef DisciplineDef @relation(fields: [disciplineDefId], references: [id], onDelete: Restrict)

  @@id([nodeId, disciplineDefId])
  @@index([disciplineDefId])
}

// Directed relation edges between skill tree nodes (within a guild's tree).
// relationType: REQUIRES | BLOCKS | UPGRADES
// REQUIRES: nodeId cannot be purchased unless targetNodeId is already obtained.
// BLOCKS:   nodeId cannot be purchased if targetNodeId is already obtained (one-directional).
// UPGRADES: nodeId supersedes targetNodeId; on purchase, targetNodeId's obtained record is
//           deleted (no refund). Only one tier is active at a time. UPGRADES implies REQUIRES.
model SkillTreeNode_Relation {
  nodeId         Int
  relationTypeId Int
  targetNodeId   Int

  node         SkillTreeNode @relation("NodeRelations",  fields: [nodeId],         references: [id], onDelete: Cascade)
  target       SkillTreeNode @relation("RelationTarget", fields: [targetNodeId],   references: [id], onDelete: Cascade)
  relationType RelationType  @relation(                  fields: [relationTypeId], references: [id], onDelete: Restrict)

  @@id([nodeId, relationTypeId, targetNodeId])
  @@index([targetNodeId])
  @@index([relationTypeId])
}

// Tracks which skill tree nodes an entity has obtained (auto-granted or purchased).
model Entity_SkillTreeNode {
  id       Int @id @default(autoincrement())
  entityId Int
  nodeId   Int

  entity Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  node   SkillTreeNode @relation(fields: [nodeId],   references: [id], onDelete: Cascade)

  @@unique([entityId, nodeId])
  @@index([entityId])
}

// ============================================================
// ABILITIES
// ============================================================







// Guild-extensible ability definitions.
// Sources: species (inherent at creation), skill tree (earned), items (while equipped), events (granted).
model AbilityDef {
  id           Int     @id @default(autoincrement())
  guildId      String  @default("global") @db.VarChar(50)
  codeName     String  @db.VarChar(200)
  name         String  @db.VarChar(200)
  description  String? @db.VarChar(1000)
  maxInstances Int     @default(1)  // max active Entity_Ability rows per entity for this def; grant silently skipped if at cap

  statModifiers        Ability_StatModifier[]
  proficiencyModifiers Ability_ProficiencyModifier[]
  multiplierEffects    Ability_MultiplierEffect[]
  grantedActions       Ability_GrantedAction[]
  combatBehaviors      Ability_CombatBehavior[]
  conditionResistances Ability_ConditionResistance[]
  damageModifiers      Ability_DamageModifier[]
  actionTriggers       Ability_ActionTrigger[]
  thresholdTriggers    Ability_ThresholdTrigger[]
  presenceEffects      Ability_PresenceEffect[]

  entityAbilities Entity_Ability[]
  speciesDefaults Species_DefaultAbility[]
  skillTreeNodes  SkillTreeNode[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
}

// Per-entity active ability. sourceType/sourceId track the origin so removal can be scoped correctly.
// sourceType: "species" | "skill_tree" | "item" | "event"
// sourceId:   FK to the originating row (varies by sourceType)
model Entity_Ability {
  id           Int    @id @default(autoincrement())
  entityId     Int
  abilityDefId Int
  sourceType   String @db.VarChar(50)
  sourceId     Int?

  entity     Entity     @relation(fields: [entityId],     references: [id], onDelete: Cascade)
  abilityDef AbilityDef @relation(fields: [abilityDefId], references: [id], onDelete: Restrict)

  @@index([entityId])
  @@index([abilityDefId])
}

// Abilities a species grants to every entity at creation.
model Species_DefaultAbility {
  speciesId    Int
  abilityDefId Int

  species    Species    @relation(fields: [speciesId],    references: [id], onDelete: Cascade)
  abilityDef AbilityDef @relation(fields: [abilityDefId], references: [id], onDelete: Restrict)

  @@id([speciesId, abilityDefId])
  @@index([abilityDefId])
}

// Flat stat bonus, optionally gated by action context, biome, weather, or entity state.
// context: situational key e.g. "dodge", "attack"; null = always applies
// State gates (all as fraction of max, 0.0–1.0; null = no gate):
//   hpThresholdMin / hpThresholdMax     — e.g. max 0.3 = "only when HP ≤ 30%"
//   nutritionThresholdMax               — "only when nutrition ≤ X%"
//   hydrationThresholdMax               — "only when hydration ≤ X%"
model Ability_StatModifier {
  id           Int    @id @default(autoincrement())
  abilityDefId Int
  statId       Int
  value        Int    // positive = bonus, negative = penalty

  context        String? @db.VarChar(100)
  biomeId        Int?
  weatherStateId Int?

  valueThresholdMin Float?  // only active when the relevant tracked value fraction >= this (0.0–1.0)
  valueThresholdMax Float?  // only active when the relevant tracked value fraction <= this (0.0–1.0)

  abilityDef   AbilityDef    @relation(fields: [abilityDefId],   references: [id], onDelete: Cascade)
  stat         Stat          @relation(fields: [statId],         references: [id], onDelete: Restrict)
  biome        Biome?        @relation(fields: [biomeId],        references: [id], onDelete: Restrict)
  weatherState WeatherState? @relation(fields: [weatherStateId], references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([statId])
}

// Flat bonus to a specific proficiency roll, optionally gated by biome, weather, or entity state.
model Ability_ProficiencyModifier {
  id               Int     @id @default(autoincrement())
  abilityDefId     Int
  proficiencyDefId Int
  value            Int     // flat bonus to the roll
  hasAdvantage     Boolean @default(false)  // roll twice, take higher
  hasDisadvantage  Boolean @default(false)  // roll twice, take lower

  biomeId        Int?
  weatherStateId Int?

  valueThresholdMin Float?  // only active when the relevant tracked value fraction >= this (0.0–1.0)
  valueThresholdMax Float?  // only active when the relevant tracked value fraction <= this (0.0–1.0)

  abilityDef     AbilityDef     @relation(fields: [abilityDefId],     references: [id], onDelete: Cascade)
  proficiencyDef ProficiencyDef @relation(fields: [proficiencyDefId], references: [id], onDelete: Restrict)
  biome          Biome?         @relation(fields: [biomeId],          references: [id], onDelete: Restrict)
  weatherState   WeatherState?  @relation(fields: [weatherStateId],   references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([proficiencyDefId])
}

model AbilityTargetType {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)

  abilityMultiplierEffect Ability_MultiplierEffect[]
  abilityPresenceEffects  Ability_PresenceEffect[]
}

// Rate and yield multipliers, optionally gated by biome or weather.
model Ability_MultiplierEffect {
  id                Int    @id @default(autoincrement())
  abilityDefId      Int
  targetTypeId      Int
  targetId          Int?   // polymorphic narrow: targetTypeId determines which table this points to; null = all
  multiplier        Float?  // 1.2 = +20%, 0.8 = −20%; null if using flatRate
  flatRate          Int?    // flat additive bonus (e.g. +1 to harvest yield); null if using multiplier
  valueThresholdMin Float?
  valueThresholdMax Float?

  biomeId        Int?
  weatherStateId Int?

  abilityDef   AbilityDef    @relation(fields: [abilityDefId],   references: [id], onDelete: Cascade)
  biome        Biome?        @relation(fields: [biomeId],        references: [id], onDelete: Restrict)
  weatherState WeatherState? @relation(fields: [weatherStateId], references: [id], onDelete: Restrict)
  abilityTargetType AbilityTargetType @relation(fields: [targetTypeId], references: [id], onDelete: Restrict)


  @@index([abilityDefId])
}

// Grants access to an item's actions without requiring the item in inventory.
// Mirrors ConditionDef_GrantedItem — same routing through item action definitions.
// grantedToSource: false = granted to ability holder; true = granted to sourceEntityId
// usageContext: "any" = usable in and out of combat; "combat_only" = only during active combat;
//              "out_of_combat_only" = only when not in combat
// outOfCombatDailyLimit: max uses per day when used outside combat; null = no hard limit (energy still applies)
model Ability_GrantedAction {
  id              Int     @id @default(autoincrement())
  abilityDefId    Int
  itemId          Int
  grantedToSource Boolean @default(false)
  usesPerGrant    Int?    // null = unlimited total uses while ability is active
  usageContext    String  @db.VarChar(30) @default("any")  // "any" | "combat_only" | "out_of_combat_only"
  outOfCombatDailyLimit Int?  // null = limited only by energy out of combat

  abilityDef AbilityDef @relation(fields: [abilityDefId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId],       references: [id], onDelete: Cascade)

  @@index([abilityDefId])
  @@index([itemId])
}

// Combat behavior effects — mirrors ConditionBehaviorEffect but sourced from an ability.
model Ability_CombatBehavior {
  id           Int    @id @default(autoincrement())
  abilityDefId Int

  perspective    String @db.VarChar(20)  // "outgoing" | "incoming"
  behaviorTypeId Int
  actionTypeId   Int?                    // null = affects all action types
  triggerChance  Float  @default(1.0)

  redirectTargetId     Int?
  biasWeight           Float?
  restrictActionTypeId Int?
  restrictIsBlock      Boolean @default(false)  // false = may ONLY use; true = may NOT use

  valueThresholdMin Float?  // only active when the relevant tracked value fraction >= this (0.0–1.0)
  valueThresholdMax Float?  // only active when the relevant tracked value fraction <= this (0.0–1.0)

  abilityDef     AbilityDef              @relation(fields: [abilityDefId],          references: [id], onDelete: Cascade)
  behaviorType   ConditionBehaviorType   @relation(fields: [behaviorTypeId],         references: [id], onDelete: Restrict)
  actionType     ItemActionType?         @relation("AbilityCombatBehaviorAction",    fields: [actionTypeId],          references: [id], onDelete: Restrict)
  redirectTarget BehaviorRedirectTarget? @relation(fields: [redirectTargetId],       references: [id], onDelete: Restrict)
  restrictAction ItemActionType?         @relation("AbilityRestrictActionType",      fields: [restrictActionTypeId],  references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([behaviorTypeId])
}

// Resistance or immunity to a specific condition or entire condition type.
// Use conditionDefId for a specific condition, conditionTypeId for a whole category.
model Ability_ConditionResistance {
  id              Int     @id @default(autoincrement())
  abilityDefId    Int
  conditionDefId  Int?
  conditionTypeId Int?
  resistDcBonus   Int?    // CON roll bonus to resist; null when isImmune = true
  isImmune        Boolean @default(false)

  abilityDef    AbilityDef     @relation(fields: [abilityDefId],    references: [id], onDelete: Cascade)
  conditionDef  ConditionDef?  @relation(fields: [conditionDefId],  references: [id], onDelete: Cascade)
  conditionType ConditionType? @relation(fields: [conditionTypeId], references: [id], onDelete: Restrict)

  @@index([abilityDefId])
}

// Damage type modifier — resistance, vulnerability, or immunity.
// modifier: 1.0 = normal, 0.5 = half damage, 2.0 = vulnerability; ignored when isImmune = true
model Ability_DamageModifier {
  id           Int     @id @default(autoincrement())
  abilityDefId Int
  damageTypeId Int
  modifier     Float   @default(1.0)
  isImmune     Boolean @default(false)

  valueThresholdMin        Float?
  valueThresholdMax        Float?

  abilityDef AbilityDef @relation(fields: [abilityDefId], references: [id], onDelete: Cascade)
  damageType DamageType @relation(fields: [damageTypeId], references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([damageTypeId])
}

model AbilityEffectType {
  id    Int @id @default(autoincrement())
  name  String @unique

  abilityActionTrigger   Ability_ActionTrigger[]
  abilityPresenceEffects Ability_PresenceEffect[]
}

model AbilityThresholdType {
  id    Int @id @default(autoincrement())
  name  String @unique

  abilityThresholdTriggers Ability_ThresholdTrigger[]
}

model TargetScope {
  id    Int    @id @default(autoincrement())
  name  String @unique

  isAbilityTarget Boolean @default(false)  // valid for Ability_ActionTrigger.targetScopeId
  isPresenceScope Boolean @default(false)  // valid for Ability_PresenceEffect.presenceScopeId
  isPowerScope    Boolean @default(false)  // valid for StructureDef_FuelConfig.scopeId

  abilityActionTrigger   Ability_ActionTrigger[]
  abilityPresenceEffects Ability_PresenceEffect[]
  fuelConfigs            StructureDef_FuelConfig[]
}

model TriggerTiming {
  id    Int @id @default(autoincrement())
  name  String @unique

  abilityActionTrigger Ability_ActionTrigger[]
}

model StackBehavior {
  id    Int @id @default(autoincrement())
  name  String @unique

  abilityThresholdTriggers Ability_ThresholdTrigger[]
  abilityActionTrigger     Ability_ActionTrigger[]
  abilityPresenceEffects   Ability_PresenceEffect[]
}

// Fires an effect when the entity performs a specific action system type.
// Unlike passive ability effects, these are event-driven — activate on action resolution.
model Ability_ActionTrigger {
  id           Int    @id @default(autoincrement())
  abilityDefId Int

  triggerSystemType       String  @db.VarChar(50)  // FK → ActionSystemType
  targetScopeId           Int
  triggerOnId             Int
  triggerChance           Float   @default(1.0)    // 0.0–1.0 probability the trigger fires
  abilityEffectTypeId     Int
  stackBehaviorId         Int

  // effectType = "plot_buff"
  effectTypeId   Int?
  effectValue    Float?
  durationHours  Int?

  // effectType = "condition_grant"
  conditionDefId Int?

  // effectType = "energy_restore"
  energyAmount Float?

  // effectType = "xp_grant"
  disciplineDefId Int?
  xpAmount        Int?

  abilityDef           AbilityDef       @relation(fields: [abilityDefId], references: [id], onDelete: Cascade)
  triggerSystemTypeRel ActionSystemType @relation(fields: [triggerSystemType], references: [id], onDelete: Restrict)
  conditionDef         ConditionDef?    @relation(fields: [conditionDefId], references: [id], onDelete: Restrict)
  disciplineDef        DisciplineDef?   @relation(fields: [disciplineDefId], references: [id], onDelete: Restrict)
  abilityEffectType    AbilityEffectType @relation(fields: [abilityEffectTypeId], references: [id], onDelete: Restrict)
  targetScope          TargetScope       @relation(fields: [targetScopeId],       references: [id], onDelete: Restrict)
  triggerTiming        TriggerTiming     @relation(fields: [triggerOnId],          references: [id], onDelete: Restrict)
  stackBehavior        StackBehavior     @relation(fields: [stackBehaviorId],      references: [id], onDelete: Restrict)
  effectType           EffectType?       @relation(fields: [effectTypeId],         references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([triggerSystemType])
}

// Grants a condition when a tracked entity value crosses a defined threshold.
// Checked after any event that modifies the relevant value (damage, healing, eating, drinking).
// Fires only when the threshold is newly crossed and the condition is not already active.
model Ability_ThresholdTrigger {
  id           Int    @id @default(autoincrement())
  abilityDefId Int

  thresholdTypeId Int
  thresholdValue Float                    // 0.0–1.0 fraction of max
  thresholdBelow Boolean @default(true)
  thresholdAbove Boolean @default(false)
  conditionDefId Int
  stackBehaviorId Int

  abilityDef   AbilityDef   @relation(fields: [abilityDefId],   references: [id], onDelete: Cascade)
  thresholdType AbilityThresholdType @relation(fields: [thresholdTypeId], references: [id], onDelete: Restrict)
  conditionDef ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Restrict)
  stackBehavior StackBehavior @relation(fields: [stackBehaviorId], references: [id], onDelete: Restrict)

  @@index([abilityDefId])
}

// Always-on passive effect that activates based on the entity's housing assignment. Evaluated once per day per target.
// triggerChance: per-target daily roll (1.0 = guaranteed; 0.5 = 50% per target)
// abilityEffectType (AbilityEffectType):
//   "condition_grant" — applies a ConditionDef to target entity (scopes: colocated_entities, colocated_patients, camp_entities)
//   "multiplier"      — applies a rate/yield multiplier to target entity (same scopes as condition_grant)
//   "structure_buff"  — modifies a structure property (scopes: housing_structure, camp_structures)
//   "plot_buff"       — writes a Plot_Buff on target plot (scope: housing_plots)
// If the target does not exist (no plots, no patients, etc.) the effect does nothing.
model Ability_PresenceEffect {
  id           Int    @id @default(autoincrement())
  abilityDefId Int

  presenceScopeId     Int
  triggerChance       Float @default(1.0)  // 0.0–1.0 per-target daily roll
  abilityEffectTypeId Int
  stackBehaviorId     Int

  // abilityEffectType = "condition_grant"
  conditionDefId Int?

  // abilityEffectType = "multiplier"
  multiplierTargetTypeId Int?   // FK → AbilityTargetType; tells the app which table targetId points to
  multiplierValue        Float?
  targetId               Int?   // polymorphic narrow: e.g. disciplineDefId for discipline_xp, factionId for faction_rep_gain; null = all

  // abilityEffectType = "plot_buff"
  effectTypeId  Int?   // FK → EffectType (growth_rate, harvest_yeild, rot_rate, etc.)
  effectValue   Float?
  durationHours Int?

  abilityDef           AbilityDef         @relation(fields: [abilityDefId],           references: [id], onDelete: Cascade)
  targetScope          TargetScope        @relation(fields: [presenceScopeId],         references: [id], onDelete: Restrict)
  abilityEffectType    AbilityEffectType  @relation(fields: [abilityEffectTypeId],     references: [id], onDelete: Restrict)
  stackBehavior        StackBehavior      @relation(fields: [stackBehaviorId],         references: [id], onDelete: Restrict)
  conditionDef         ConditionDef?      @relation(fields: [conditionDefId],          references: [id], onDelete: Restrict)
  multiplierTargetType AbilityTargetType? @relation(fields: [multiplierTargetTypeId],  references: [id], onDelete: Restrict)
  effectType           EffectType?        @relation(fields: [effectTypeId],            references: [id], onDelete: Restrict)

  @@index([abilityDefId])
  @@index([presenceScopeId])
}

// ============================================================
// CONDITIONS
// ============================================================






// High-level classification of what a condition is *for* — drives display and query filtering.
model ConditionContext {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  conditions ConditionDef[]
}

// Defines the behavioral lifecycle pattern of a condition — drives how the app ticks progression each day.
// tracksDays:        engine counts days against maxDays on ConditionDef
// tracksProgression: engine tracks a progression value and runs the daily CON roll vs. dailyRollDC
// canSelfResolve:    condition can remove or advance itself at an endpoint; false = floors at 0/cap and persists
// canSpawn:          spawn link checks fire when spawnThreshold is crossed
model ConditionType {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(50)
  description String @db.VarChar(500)

  tracksDays        Boolean @default(false)
  tracksProgression Boolean @default(false)
  canSelfResolve    Boolean @default(false)
  canSpawn          Boolean @default(false)

  conditionDefs      ConditionDef[]
  abilityResistances Ability_ConditionResistance[]
}


// Guild-extensible condition definition — name is freely chosen by guild owners
// conditionTypeId: FK to ConditionType — determines the progression lifecycle and display label
// visibility is tracked per-instance via EntityCondition.discoveryLevel, not on the definition
model ConditionDef {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  conditionTypeId    Int
  conditionContextId Int

  conditionType    ConditionType   @relation(fields: [conditionTypeId],    references: [id], onDelete: Restrict)
  conditionContext ConditionContext @relation(fields: [conditionContextId], references: [id], onDelete: Restrict)

  isSecondWindConsequence Boolean @default(false)  // eligible to be rolled when combat ends with entity in second wind below the HP threshold
  isHidden                Boolean @default(false)  // condition name hidden until discoveryLevel >= linked symptomTag.defaultRoll
  isFatalAtCap            Boolean @default(false)  // Progressive only: entity dies if cap is hit with no worsen link

  // Progressive / Chronic fields — null for Timed / Permanent / Trait
  progressionCap Float? // maximum progression value; when hit, worsen link fires (or death if isFatalAtCap)
  dailyRollDC    Int?   // CON roll DC for daily delta: delta = roll - DC; positive = recover, negative = worsen

  // Timed field — null for all other types
  maxDays Int?  // number of days until the condition resolves forward via worsen/remove link

  // Duration field — for buffs/debuffs with a real-time expiry (e.g. pre-combat spells, potions).
  // Applies to any condition type. When set, EntityCondition.expiresAt is computed at application
  // as now() + durationMinutes. The app removes the condition when expiresAt is reached,
  // regardless of combat state. null = no time-based expiry.
  durationMinutes Int?

  // Spawn fields — applicable to Timed, Progressive, and Chronic
  spawnThreshold Float?  // 0.0–1.0 fraction of cap/maxDays at which spawn link checks fire; null = no spawning

  contagionResistDC Int?   // null = not contagious; roll d20 ≥ this value to resist; higher = more contagious
  energyDebuf       Float? // fractional reduction to energy cap (e.g. 0.4 = -40%)

  // Action component blocking — if true, this condition prevents the entity from performing
  // actions that require that component (checked at action resolution)
  blocksVerbal  Boolean @default(false)  // e.g. Muteness — prevents verbal-component actions
  blocksSomatic Boolean @default(false)  // e.g. future paralysis — prevents somatic-component actions

  links        ConditionDef_Link[] @relation("ConditionLinkParent")
  linkTargets  ConditionDef_Link[] @relation("ConditionLinkChild")
  symptomTags           ConditionDef_SymptomTag[]
  itemConditionEffects        ItemConditionEffect[] @relation("ItemConditionEffectTarget")
  itemConditionEffectOutputs  ItemConditionEffect[] @relation("ItemConditionEffectOutput")
  envRules              ConditionDef_EnvRule[]
  statEffects           ConditionDef_StatEffect[]
  proficiencyEffects          ConditionDef_ProficiencyEffect[]
  combatEffects         ConditionDef_CombatEffect[]
  eventConditionEffects EventEffect[]
  combatActions         ItemEquipmentProfile_Condition[]
  itemWarnings          ItemWarning[]
  entityConditions      EntityCondition[]
  damageModifiers       ConditionDef_DamageModifier[]
  behaviorEffects       ConditionBehaviorEffect[]
  abilityActionTriggers    Ability_ActionTrigger[]
  abilityThresholdTriggers Ability_ThresholdTrigger[]
  abilityPresenceEffects   Ability_PresenceEffect[]
  grantedItems           ConditionDef_GrantedItem[]
  abilityResistances     Ability_ConditionResistance[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
  @@index([conditionTypeId])
  @@index([conditionContextId])
}

// Damage type resistance or immunity granted while this condition is active.
// isResistant = true  → entity takes half damage from this damage type
// isResistant = false → entity takes no damage from this damage type (full immunity)
// Condition blocking is handled via ConditionDef_Link with linkType = "block".
model ConditionDef_DamageModifier {
  conditionDefId Int
  damageTypeId   Int
  isResistant    Boolean  // true = half damage; false = immune (no damage)

  condition  ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  damageType DamageType   @relation(fields: [damageTypeId],   references: [id], onDelete: Restrict)

  @@id([conditionDefId, damageTypeId])
  @@index([damageTypeId])
}

// How a condition's progression is affected when an environmental condition is active.
// relationshipType: "worsen" | "improve"
//   worsen — env condition makes this illness harder to recover from (e.g. asthma + Smoke)
//   improve — env condition aids recovery (e.g. a chest wound + Warm, Dry)
// value: Float >= 0.0, <= 2.0 (enforced app-side). Applied additively per active stack:
//   effectiveMod = 1.0 + value × stackCount
//   For "worsen":  effectiveDC = dailyRollDC × effectiveMod  (e.g. value=0.8, 1 stack → DC × 1.8)
//   For "improve": effectiveDC = dailyRollDC / effectiveMod  (worsening rate reduced proportionally)
//   A value of 0.0 has no effect; 2.0 is the maximum (3× DC per stack at cap).
model ConditionDef_EnvRule {
  conditionDefId   Int
  envConditionId   Int
  relationTypeId   Int
  value            Float                    // > 0.0 and <= 2.0; enforced app-side

  condition    ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Cascade)
  relationType RelationType  @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)

  @@id([conditionDefId, envConditionId])
  @@index([envConditionId])
}

// Flat stat modifier applied by a condition — one row per affected stat
// amount: signed integer; positive = buff (e.g. +2 Strength), negative = debuff (e.g. -3 Constitution)
model ConditionDef_StatEffect {
  conditionDefId Int
  statId         Int

  amount Int  // positive = buff, negative = debuff

  condition ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  stat      Stat         @relation(fields: [statId],         references: [id], onDelete: Restrict)

  @@id([conditionDefId, statId])
  @@index([statId])
}

// Skill effects for a condition — one row per affected skill
// amount:         signed flat modifier to the skill roll (e.g. +3 or -2); null = no flat modifier
// hasDisadvantage: roll twice, keep the lower result
model ConditionDef_ProficiencyEffect {
  conditionDefId Int
  proficiencyDefId     Int

  amount          Int?
  hasDisadvantage Boolean @default(false)

  condition ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  proficiency ProficiencyDef   @relation(fields: [proficiencyDefId],     references: [id], onDelete: Cascade)

  @@id([conditionDefId, proficiencyDefId])
  @@index([proficiencyDefId])
}

// In-combat effects for a condition — applied each round while the EntityCondition is active.
// Complements ConditionDef_StatEffect / ConditionDef_ProficiencyEffect, which are the out-of-combat effects.
// One ConditionDef can have multiple combat effects (e.g. Poisoned: damage per round + hit penalty).
//
// effectType:
//   "damage_per_round" — rolls diceCount d diceSides and deals the result as HP damage each round
//   "heal_per_round"   — rolls diceCount d diceSides and restores HP each round
//   "hit_mod"          — adds flatModifier (or EntityCondition.resolvedFlatModifier if null) to all hit rolls
//   "damage_mod"       — flat bonus/penalty to damage rolls
//   "stat_mod"         — temporary in-combat stat modifier (statId + flatModifier); distinct from the
//                        out-of-combat ConditionDef_StatEffect, which persists outside of combat
//   "action_denial"    — entity skips flatModifier turns each time this effect triggers (null = 1 turn)
//   "ac_mod"           — flat bonus/penalty to the entity's effective AC (e.g. defensive stance +2, broken guard -2)
//   "advantage"        — roll twice on affected rolls, take the higher result
//   "disadvantage"     — roll twice on affected rolls, take the lower result
//
// flatModifier: null when the magnitude is skill-derived (read from EntityCondition.resolvedFlatModifier).
//               positive = bonus, negative = penalty.
//               for "action_denial", null means skip 1 turn.
model ConditionDef_CombatEffect {
  id             Int @id @default(autoincrement())
  conditionDefId Int
  effectTypeId   Int

  // damage_per_round / heal_per_round
  diceCount Int?
  diceSides Int?

  // hit_mod / damage_mod / stat_mod / ac_mod
  statId       Int?  // stat_mod only
  flatModifier Int?  // null = use EntityCondition.resolvedFlatModifier; positive = bonus, negative = penalty

  condition  ConditionDef     @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  effectType CombatEffectType @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)
  stat       Stat?            @relation(fields: [statId],         references: [id], onDelete: Restrict)

  @@unique([conditionDefId, effectTypeId])
  @@index([effectTypeId])
  @@index([statId])
}

// Links between condition definitions — drives the full condition chain system.
// linkType: block | recover | worsen | spawn
//   block:   parent condition prevents child from being applied (e.g. nursing blocks pregnancy)
//   recover: when parent value hits 0, replace parent with child (e.g. moderate infection → minor infection)
//   worsen:  when parent value hits cap, replace parent with child (e.g. moderate infection → major infection)
//   spawn:   when parent hits spawnThreshold, add child alongside parent (e.g. asthma → pneumonia)
// weight: relative probability weight among multiple spawn candidates; ignored for block/recover/worsen
model ConditionDef_Link {
  id                Int   @id @default(autoincrement())
  parentConditionId Int
  childConditionId  Int
  relationTypeId    Int
  weight            Float @default(1.0)

  parentCondition ConditionDef @relation("ConditionLinkParent", fields: [parentConditionId], references: [id], onDelete: Cascade)
  childCondition  ConditionDef @relation("ConditionLinkChild",  fields: [childConditionId],  references: [id], onDelete: Restrict)
  relationType    RelationType @relation(                        fields: [relationTypeId],    references: [id], onDelete: Restrict)

  @@unique([parentConditionId, childConditionId, relationTypeId])
  @@index([parentConditionId, relationTypeId])
  @@index([childConditionId])
  @@index([relationTypeId])
}

// Symptom labels attached to a condition definition
// Both the condition (here) and the ItemEffect targeting that symptom reference the same Symptom row
// e.g. Asthma → [Difficulty Breathing, Wheezing]
// Herb ItemEffect → [Difficulty Breathing] — shared symptom drives treatment matching
model ConditionDef_SymptomTag {
  conditionDefId Int
  symptomId      Int

  condition ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  symptom   Symptom      @relation(fields: [symptomId],      references: [id], onDelete: Restrict)

  @@id([conditionDefId, symptomId])
  @@index([symptomId])
}

// Items granted to an entity while a condition is active.
// The item's combat actions appear in the entity's action menu without requiring the item
// to be in inventory (e.g. "Grappled" grants "Break Free"; "Grappling" grants "Release").
//
// grantedToSource: false (default) = item granted to the condition holder.
//                  true = item granted to EntityCondition.sourceEntityId (the entity that applied it).
//                  Enables exploitation actions — e.g. applying "Marked" grants the attacker "Hunter's Strike".
//
// usesPerApplication: max times the granted action can be used during this condition instance.
//                     null = unlimited. Tracked per EntityCondition at runtime.
//
// minProgression / maxProgression: gate the item behind the condition's current progressionValue.
//   minProgression: item only available when progressionValue >= this value (e.g. Last Stand at >= 3.0)
//   maxProgression: item only available when progressionValue <= this value (e.g. Apply Pressure at <= 4.0)
//   Both null = always available while condition is active.

model ConditionDef_GrantedItem {
  conditionDefId Int
  itemId         Int

  grantedToSource    Boolean @default(false)
  usesPerApplication Int?
  minProgression     Float?
  maxProgression     Float?

  conditionDef ConditionDef @relation(fields: [conditionDefId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId],         references: [id], onDelete: Cascade)

  @@id([conditionDefId, itemId])
  @@index([conditionDefId])
  @@index([itemId])
}

// ----------------------------------------------------------------
// CONDITION BEHAVIOR EFFECTS
// ----------------------------------------------------------------
// Data-driven combat action interception — defines how a condition modifies
// incoming or outgoing combat actions for the entity holding it.
//
// perspective: "outgoing" = triggers on actions made BY this entity (e.g. Confused redirects
//              their own attacks); "incoming" = triggers on actions directed AT this entity
//              (e.g. Being Guarded redirects attacks on the guarded entity to the guardian).
//
//   redirect — moves the action to a different target (redirectTarget required)
//   cancel   — action is prevented entirely (triggerChance = probability of cancel)
//   bias     — shifts targeting weight; biasWeight positive = toward redirectTarget,
//              negative = away from redirectTarget (e.g. Fear pushes actions away from source)
//   restrict — limits what action types the entity may/must use (restrictActionTypeId required)
//
//   source      — the entity stored in EntityCondition.sourceEntityId (covers Taunt, Guard, Mark)
//   self        — the entity holding the condition (confusion self-hit)
//   random_ally — a random member of the holder's own side
//   random_enemy — a random member of the opposing side
//
// triggerChance: 1.0 = always fires; 0.5 = 50% chance (used for confusion, parry, etc.)
// biasWeight:    signed float, bias behavior only; positive = toward target, negative = away
// restrictActionTypeId: the action type being allowed or blocked (restrict behavior only)
// restrictIsBlock: false = entity may ONLY use this action type; true = entity may NOT use it

model ConditionBehaviorType {
  id      Int    @id @default(autoincrement())
  name    String @unique
  // redirect | cancel | bias | restrict
  effects         ConditionBehaviorEffect[]
  abilityBehaviors Ability_CombatBehavior[]
}

model BehaviorRedirectTarget {
  id      Int    @id @default(autoincrement())
  name    String @unique
  // source | self | random_ally | random_enemy
  effects          ConditionBehaviorEffect[]
  abilityBehaviors Ability_CombatBehavior[]
}

model ConditionBehaviorEffect {
  id             Int @id @default(autoincrement())
  conditionDefId Int

  actionTypeId   Int?    // null = affects all action types
  perspective    String  // "outgoing" | "incoming"

  behaviorTypeId   Int
  triggerChance    Float @default(1.0)

  // redirect + bias
  redirectTargetId Int?
  biasWeight       Float?  // bias only; positive = toward, negative = away from redirectTarget

  // restrict
  restrictActionTypeId Int?
  restrictIsBlock      Boolean @default(false)  // false = may ONLY use; true = may NOT use

  conditionDef   ConditionDef           @relation(fields: [conditionDefId],        references: [id], onDelete: Cascade)
  actionType     ItemActionType?        @relation(fields: [actionTypeId],          references: [id], onDelete: Restrict)
  behaviorType   ConditionBehaviorType  @relation(fields: [behaviorTypeId],        references: [id], onDelete: Restrict)
  redirectTarget BehaviorRedirectTarget? @relation(fields: [redirectTargetId],     references: [id], onDelete: Restrict)
  restrictAction ItemActionType?        @relation("RestrictActionType", fields: [restrictActionTypeId], references: [id], onDelete: Restrict)

  @@index([conditionDefId])
  @@index([actionTypeId])
  @@index([behaviorTypeId])
  @@index([redirectTargetId])
  @@index([restrictActionTypeId])
}

// ============================================================
// ITEMS
// ============================================================







// Actions that can be performed with items
// Covers medicine use and item consumption only. Crafting and processing interactions
// live on CraftingInteraction, which is entirely separate.
model ItemInteraction {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  description String @db.VarChar(300)

  itemActions     ItemAction[]
  warningTriggers ItemWarning[]
}


// Item type classification tags for items — many-to-many via Item_Type.
// Classification tags for items — many-to-many via Item_Type.
// Tags drive which systems query for an item and how it appears in UI filters.
model ItemType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  items                Item_Type[]
  structureStorageTypes Structure_Storage_ItemType[]
  eventEffects         EventEffect[]
}

// Reusable warning labels for items — e.g. "Dangerous for kits", "Dangerous for elders"
model ItemWarning {
  id      Int    @id @default(autoincrement())
  guildId String @default("global") @db.VarChar(50)
  name    String @db.VarChar(200)

  // If both are set: when an entity performs triggeredByInteraction on this item, conditionDef is applied
  // If both are null: display-only warning (e.g. "Dangerous for Kits") — informational, no automation
  conditionDefId           Int?
  triggeredByInteractionId Int?

  conditionDef           ConditionDef?    @relation(fields: [conditionDefId],           references: [id], onDelete: SetNull)
  triggeredByInteraction ItemInteraction? @relation(fields: [triggeredByInteractionId], references: [id], onDelete: SetNull)

  items Item_Warning[]

  @@unique([guildId, name])
  @@index([guildId])
  @@index([conditionDefId])
  @@index([triggeredByInteractionId])
}

model Item_Warning {
  itemId      Int
  warningId   Int
  durationDays Int?  // overrides the condition's natural duration when this warning fires; null = use condition default

  item    Item        @relation(fields: [itemId],    references: [id], onDelete: Cascade)
  warning ItemWarning @relation(fields: [warningId], references: [id], onDelete: Restrict)

  @@id([itemId, warningId])
  @@index([warningId])
}

// Equipment slot categories
// defaultCapacity: how many slots of this type an entity has unless overridden by Species_EquipmentLoadout
// isUnlimited: true = capacity is never enforced (used for Innate slot — biological attacks, rank abilities, spells)
model EquipmentSlotType {
  id              Int     @id @default(autoincrement())
  name            String  @unique @db.VarChar(50)
  defaultCapacity Int     @default(1)
  isUnlimited     Boolean @default(false)

  equipmentProfiles ItemEquipmentProfile[]
  speciesLoadouts   Species_EquipmentLoadout[]
}

// Equipment properties for items that can be equipped (weapons, shields, armor, traits, spells, tools).
// An item can have multiple profiles representing different equip modes (e.g. one-handed vs two-handed grip).
//
// Slot enforcement (app-side):
//   When equipping, sum chosenProfile.slotCost for all currently equipped items with the same slotTypeId.
//   Compare against: Species_EquipmentLoadout.capacity (if row exists) else EquipmentSlotType.defaultCapacity.
//   Slots with isUnlimited = true skip capacity enforcement (Innate slot for biological attacks, spells, etc.)
//
// Combat action — all damage, heal, and action metadata lives here.
//   null actionCategoryId = this profile has no combat use (e.g. pure armor, shield with no attack).
model ItemEquipmentProfile {
  id     Int @id @default(autoincrement())
  itemId Int

  slotTypeId Int
  slotCost   Int     @default(1)     // how many slots this profile consumes; 2 for two-handed grip, 1 for everything else
  label      String? @db.VarChar(100) // display name for this equip mode, e.g. "One-Handed", "Two-Handed"; null = no label

  acModifier Int @default(0)  // flat AC modifier while equipped; positive = bonus, negative = penalty; 0 = no effect

  // Damage — null = this profile deals no inherent damage (shields, armor)
  damageDiceCount Int?
  damageDiceSides Int?
  damageTypeId    Int?  // FK to DamageType; any type — physical or elemental; null = untyped

  // Secondary elemental damage — rolled separately on hit; null = no elemental component
  elementalDiceCount    Int?
  elementalDiceSides    Int?
  elementalDamageTypeId Int?

  // Heal power — for tool/kit items used in combat (e.g. Field Medic Kit: 1d6 heal)
  healDiceCount Int?
  healDiceSides Int?

  isMagical Boolean @default(false)  // true = damage/heal is magical

  // Combat action metadata — null actionCategoryId = no combat use
  actionCategoryId     Int?
  actionTypeId         Int?
  targetScopeId        Int?
  cooldownRounds       Int     @default(0)
  durationRounds       Int     @default(0)   // 0 = instantaneous
  behaviorEffectTypeId Int?                  // set for stateful behaviors (guard, taunt, parry, etc.)
  requiresVerbal       Boolean @default(false)  // action has a verbal component — blocked by conditions with blocksVerbal
  requiresSomatic      Boolean @default(false)  // action has a somatic component — blocked by conditions with blocksSomatic
  allowedInSpar        Boolean @default(true)

  // Roll modifiers
  hitStatId    Int?  // stat modifier added to the 1d20 hit roll
  damageStatId Int?  // stat modifier added to damage roll
  healStatId   Int?  // stat modifier added to heal amount
  hitBonus     Int   @default(0)
  damageBonus  Int   @default(0)
  healBonus    Int   @default(0)

  // Optional event trigger on action use
  triggersEventDefId Int?
  triggerDC          Int @default(1)  // minimum d20 roll to fire the event; 1 = always, 20 = nat 20 only

  // Summon fields — populated only when actionType.name = 'summon'; null otherwise
  summonSpeciesId   Int?  // which species to spawn into the encounter
  summonDiceCount   Int?  // number of dice rolled to determine how many entities spawn (e.g. 1)
  summonDiceSides   Int?  // sides per die (e.g. 3 for 1d3 = 1–3 rats)

  damageType          DamageType?           @relation("EquipmentDamageType",         fields: [damageTypeId],          references: [id], onDelete: SetNull)
  elementalDamageType DamageType?           @relation("EquipmentElementalDamageType", fields: [elementalDamageTypeId], references: [id], onDelete: SetNull)
  slotType            EquipmentSlotType     @relation(fields: [slotTypeId],           references: [id], onDelete: Restrict)
  actionCategory      CombatActionCategory? @relation(fields: [actionCategoryId],     references: [id], onDelete: SetNull)
  actionType          ItemActionType?       @relation(fields: [actionTypeId],          references: [id], onDelete: Restrict)
  targetScope         CombatTargetScope?    @relation(fields: [targetScopeId],         references: [id], onDelete: Restrict)
  behaviorEffectType  CombatEffectType?     @relation("ProfileBehaviorEffect",         fields: [behaviorEffectTypeId], references: [id], onDelete: Restrict)
  hitStat             Stat?                 @relation("ProfileHitStat",                fields: [hitStatId],    references: [id], onDelete: Restrict)
  damageStat          Stat?                 @relation("ProfileDamageStat",             fields: [damageStatId], references: [id], onDelete: Restrict)
  healStat            Stat?                 @relation("ProfileHealStat",               fields: [healStatId],   references: [id], onDelete: Restrict)
  triggersEventDef    EventDef?             @relation(fields: [triggersEventDefId],     references: [id], onDelete: SetNull)
  summonSpecies       Species?              @relation("ProfileSummonSpecies",          fields: [summonSpeciesId], references: [id], onDelete: SetNull)

  // Conditions applied on action use or while equipped (see onEquip flag)
  conditions    ItemEquipmentProfile_Condition[]
  requiredItems ItemEquipmentProfile_RequiredItem[]
  equippedItems    StoredItem[]
  participantCooldowns ActiveCombat_Participant_ActionCooldown[]
  combatActionRecords  ActiveCombat_Action[]

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([slotTypeId])
  @@index([damageTypeId])
  @@index([elementalDamageTypeId])
  @@index([actionCategoryId])
  @@index([actionTypeId])
  @@index([targetScopeId])
  @@index([behaviorEffectTypeId])
  @@index([triggersEventDefId])
  @@index([summonSpeciesId])
  @@index([hitStatId])
  @@index([damageStatId])
  @@index([healStatId])
}

// Buff, debuff, or heal effects applied by an ItemAction.
// One action can apply multiple effects (e.g. -2 Strength AND disadvantage on damage rolls).
//
// effectType = "stat_mod":
//   flatModifier applied to statId rolls for durationRounds (negative = debuff, positive = buff)
//
// effectType = "damage_mod":
//   modType "advantage"     — reroll damage, take higher result
//   modType "disadvantage"  — reroll damage, take lower result
//   modType "percent_cut"   — multiply damage by (1 - modValue), then floor
//   modType "percent_bonus" — multiply damage by (1 + modValue), then floor
//
// effectType = "heal":
//   restores healAmount HP to the target immediately; durationRounds is ignored
//
// effectType = "hit_bonus":
//   adds flatModifier (or skill-derived value) to all hit rolls for durationRounds
//
// Conditions applied by an equipment profile action — one action can apply multiple conditions.
// For attacks: conditions are applied on a successful hit.
// For buffs/debuffs: conditions are applied when the action resolves (no hit roll needed).
//
// combatInstancedOnly: when true the created EntityCondition is removed at combat end.
//   Override for this specific action; the ConditionDef itself has no such flag.
// roundDuration: how many rounds the condition lasts; null = indefinite (or until combat end if combatInstancedOnly).
//
// Skill-derived modifier — when sourceProficiencyId is set, the app computes EntityCondition.resolvedFlatModifier
//   at application time from the actor's skill bonus, capped by maxBonusBase (non-proficient) or
//   maxBonusProficient (isProficient = true). ConditionDef_CombatEffect then uses that value when its
//   own flatModifier is null.
model ItemEquipmentProfile_Condition {
  id                 Int @id @default(autoincrement())
  equipmentProfileId Int
  conditionDefId     Int

  onEquip             Boolean @default(false)   // true = condition applied while equipped; false = applied when action fires
  appliesTo           String  @default("target") // "target" = entity the action targeted; "self" = entity using the action
  removes             Boolean @default(false)   // true = action removes this condition rather than applying it
                                                // applicationDC becomes the removal DC; linkedConditionId cascade fires on success
  applicationDC       Int     @default(1)      // minimum d20 roll to apply/remove on action fire; ignored when onEquip = true
  combatInstancedOnly Boolean @default(false)   // true = condition removed at combat end; ignored when onEquip = true
  roundDuration       Int?    // null = indefinite; ignored when onEquip = true (lasts while equipped)

  // Skill-derived modifier (e.g. Rallying Cry uses Leadership bonus)
  sourceProficiencyId      Int?
  maxBonusBase       Int?  // cap when Entity_Proficiency.isProficient = false
  maxBonusProficient Int?  // cap when Entity_Proficiency.isProficient = true

  // Linked profile condition — when both rows are created as EntityConditions, the app links them
  // via EntityCondition.linkedConditionId (e.g. "Grappling" on self linked to "Grappled" on target)
  linkedProfileConditionId Int?

  equipmentProfile        ItemEquipmentProfile           @relation(fields: [equipmentProfileId],       references: [id], onDelete: Cascade)
  conditionDef            ConditionDef                   @relation(fields: [conditionDefId],            references: [id], onDelete: Cascade)
  sourceProficiency             ProficiencyDef?                      @relation(fields: [sourceProficiencyId],             references: [id], onDelete: SetNull)
  linkedProfileCondition  ItemEquipmentProfile_Condition? @relation("LinkedProfileConditions",          fields: [linkedProfileConditionId], references: [id], onDelete: SetNull)
  linkedByProfileCondition ItemEquipmentProfile_Condition[] @relation("LinkedProfileConditions")

  @@unique([equipmentProfileId, conditionDefId, appliesTo])
  @@index([equipmentProfileId])
  @@index([conditionDefId])
  @@index([sourceProficiencyId])
  @@index([linkedProfileConditionId])
}

// An item that must be present (or is consumed) when this equipment profile action is used.
// isConsumed = false → item must exist in the entity's inventory but is not removed (focus item, totem, etc.)
// isConsumed = true  → one unit of the item is deducted from inventory on use
model ItemEquipmentProfile_RequiredItem {
  equipmentProfileId Int
  requiredItemId     Int
  isConsumed         Boolean @default(false)
  quantity           Float   @default(1.0)   // units required / consumed per use

  equipmentProfile ItemEquipmentProfile @relation(fields: [equipmentProfileId], references: [id], onDelete: Cascade)
  requiredItem     Item                 @relation("ProfileRequiredItem", fields: [requiredItemId], references: [id], onDelete: Cascade)

  @@id([equipmentProfileId, requiredItemId])
  @@index([requiredItemId])
}

model ItemActionType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  dealsDamage      Boolean @default(false)  // resolve damage roll against target AC
  restoresHealth   Boolean @default(false)  // resolve healing
  appliesCondition Boolean @default(false)  // check condition application on target
  isHarmful        Boolean @default(false)  // action is hostile — affects targeting and aggro

  equipmentProfiles       ItemEquipmentProfile[]
  behaviorEffects         ConditionBehaviorEffect[]
  restrictedByEffects     ConditionBehaviorEffect[] @relation("RestrictActionType")
  abilityBehaviorEffects  Ability_CombatBehavior[]  @relation("AbilityCombatBehaviorAction")
  abilityRestrictEffects  Ability_CombatBehavior[]  @relation("AbilityRestrictActionType")
}

// targetsAllies includes self; "all" = targetsAllies + targetsEnemies both true
model CombatTargetScope {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  targetsSelf     Boolean @default(false)  // action targets only the user
  targetsSingle   Boolean @default(false)  // action targets one selected entity
  targetsAllies   Boolean @default(false)  // action targets all allies including self
  targetsEnemies  Boolean @default(false)  // action targets all enemies

  equipmentProfiles ItemEquipmentProfile[]
}

// Herb/medicine/crafting action for an item (e.g. catmint + eat, catmint + chew).
// One row per item+interaction combo — items can have multiple interactions.
// Effects are attached here, not directly to the item.
// Combat actions (attacks, spells, rank abilities) live entirely on ItemEquipmentProfile — no ItemAction row needed.
model ItemAction {
  id                Int @id @default(autoincrement())
  itemId            Int
  itemInteractionId Int

  energyCost    Int     @default(0)    // energy consumed when used outside combat
  consumedOnUse Boolean @default(true) // false = item stays after use (tools, reusable applicators)

  item            Item            @relation(fields: [itemId],            references: [id], onDelete: Cascade)
  itemInteraction ItemInteraction @relation(fields: [itemInteractionId], references: [id], onDelete: Restrict)

  effects           ItemEffect[]
  conditionEffects  ItemConditionEffect[]
  outputs           ItemAction_Output[]

  @@unique([itemId, itemInteractionId])
  @@index([itemId])
  @@index([itemInteractionId])
}

// Defines one item produced when an ItemAction is performed.
// Supports single and multi-output actions — herb grinding, cooking, butchering, crafting, etc.
//
// Output quantity is proportional to input: outputQty = inputQty × avgQuantity × (1 ± quantityVariance)
//   e.g. grind catmint (stalks): avgQuantity=3.0  → 5 stalks produces ~15g of catmint powder
//   e.g. butcher rabbit (grams): avgQuantity=0.55 → 1200g rabbit produces ~660g of meat
//
// dropDC:           minimum d20 roll for this output to appear; 1 = always produced; higher = probabilistic byproduct
// craftBonusApplies: true = input StoredItem.craftBonus carries forward to this output's StoredItem.craftBonus
model ItemAction_Output {
  id           Int @id @default(autoincrement())
  itemActionId Int
  outputItemId Int

  avgQuantity      Float   @default(1.0)  // output units per 1 unit of input
  quantityVariance Float   @default(0.0)  // ± fraction; 0.2 = final output rolls between ×0.8 and ×1.2 of calculated amount; 0 = deterministic
  dropDC           Int     @default(1)    // minimum d20 roll to produce this output; 1 = always, 20 = only on nat 20
  craftBonusApplies Boolean @default(false)  // whether input craftBonus propagates to this output's StoredItem

  itemAction ItemAction @relation(fields: [itemActionId], references: [id], onDelete: Cascade)
  outputItem Item       @relation("ItemActionOutputItem", fields: [outputItemId], references: [id], onDelete: Restrict)

  @@unique([itemActionId, outputItemId])
  @@index([itemActionId])
  @@index([outputItemId])
}

// An effect of performing a specific action with a specific item on a symptom
// e.g. eat + catmint → treats Coughing; eat + yarrow → worsens Nausea
// Valid effectTypes for symptoms: treat, worsen
// use ItemWarning instead for hard condition spawns (e.g. "kills kits", "lethal above dose")
model ItemEffect {
  id              Int @id @default(autoincrement())
  itemActionId    Int
  symptomId       Int
  relationTypeId  Int

  effectiveness   Float @default(1.0)  // base effectiveness for this item+action+symptom combo
                                     // added to craftBonus when used as concoction ingredient

  itemAction   ItemAction   @relation(fields: [itemActionId], references: [id], onDelete: Cascade)
  symptom      Symptom      @relation(fields: [symptomId],    references: [id], onDelete: Restrict)
  relationType RelationType @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)

  @@unique([itemActionId, symptomId])
  @@index([itemActionId])
  @@index([symptomId])
}

// Direct condition-level effect for an item action — separate from symptom-level ItemEffect.
// treat    — reduces conditionDef progressionValue by effectiveness
// worsen   — increases conditionDef progressionValue by effectiveness
// cure     — removes the EntityCondition row entirely regardless of progressionValue
// transform — replaces the condition with outputConditionDef
// App rule: treat/worsen require effectiveness; transform requires outputConditionDefId; cure needs neither.
model ItemConditionEffect {
  id              Int @id @default(autoincrement())
  itemActionId    Int
  conditionDefId  Int
  relationTypeId  Int

  effectiveness        Float?  // treat / worsen only
  outputConditionDefId Int?    // transform only

  itemAction        ItemAction   @relation(fields: [itemActionId],          references: [id], onDelete: Cascade)
  conditionDef      ConditionDef @relation("ItemConditionEffectTarget",    fields: [conditionDefId],       references: [id], onDelete: Restrict)
  relationType      RelationType @relation(fields: [relationTypeId],        references: [id], onDelete: Restrict)
  outputCondition   ConditionDef? @relation("ItemConditionEffectOutput",   fields: [outputConditionDefId], references: [id], onDelete: SetNull)

  @@unique([itemActionId, conditionDefId])
  @@index([itemActionId])
  @@index([conditionDefId])
  @@index([outputConditionDefId])
}

// Nutritional values for food items. One optional row per item — only present on items
// with the Food ItemType. Items without a row cannot be eaten for nutrition.
//
// Nutrition and hydration are split by food category (Meat, Plant) so species digestion
// multipliers can be applied per category. A crafted meal with both meat and plant components
// sets non-zero values in both pairs.
//
// Runtime formula:
//   net_nutrition = quantity × (meatNutritionPerGram × species.meatNutritionMultiplier
//                             + plantNutritionPerGram × species.plantNutritionMultiplier)
//   net_hydration = quantity × (meatHydrationPerGram × species.meatHydrationMultiplier
//                             + plantHydrationPerGram × species.plantHydrationMultiplier)
model ItemFoodProfile {
  itemId Int @unique

  meatNutritionPerGram  Float @default(0.0)
  meatHydrationPerGram  Float @default(0.0)
  plantNutritionPerGram Float @default(0.0)
  plantHydrationPerGram Float @default(0.0)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
}


// Item definition (guild-extensible; guildId = "global" for seeded items)
model Item {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild (see @@unique below)
                                        // ephemeral: yarrow_leaf_a3f9b2 (source codeName + random suffix)
  name        String  @db.VarChar(200)  // display name; not unique — ephemeral items share names
  description String? @db.VarChar(1000)

  measurementTypeId Int?               // how this item's quantity is counted (Count/Weight/Volume); null = count-based
  averageWeight     Float @default(0.0) // grams per unit; used by storage weight calculations for Count and Weight items; 0 = weightless
  weightVariance    Float @default(0.0) // ± fraction applied to averageWeight at StoredItem creation; 0 = static weight
                                        // e.g. 0.1 → actual weight rolls between 0.9× and 1.1× of averageWeight
  averageVolume     Float @default(0.0) // ml per unit; used by storage fluid calculations for Volume items; 0 = ignored
  rotCap            Int?                // max rot points until fully decayed; null = does not decay.
                                        // 1 point = 1 day at base rate. 60 = lasts 60 days with no modifiers.
  maxDurability Int?                 // max durability for equipment; null = indestructible
  maxUses       Int?                 // max uses before depletion; null = unlimited
  fuelValue     Int?                 // fuel units added to a power source's bank on deposit; null = not a fuel item.
                                    // an item may carry multiple Fuel_* ItemType tags (for storage classification), but its
                                    // fuelValue is the same regardless of which power source accepts it.
  fuelTypeId    Int?                 // fuel category of this item — matched against StructureDef_FuelConfig_InputFuelType on deposit; null = not a fuel item

  // Ephemeral items are created at craft time by the recipe system (e.g. Dried Yarrow Leaf, Yarrow Paste).
  // App deletes the Item row when the last StoredItem referencing it is consumed or removed.
  isEphemeral Boolean @default(false)

  // Propagation items (seeds, spores, cuttings, bulbs) carry a plantDefId to define which plant they grow.
  // Null for all non-propagation items. Ephemeral variant seeds point to an ephemeral PlantDef.
  // App deletes ephemeral PlantDef rows when no PlotCrop.plantDefId and no Item.plantDefId references them.
  plantDefId  Int?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  measurementType MeasurementType? @relation(fields: [measurementTypeId], references: [id], onDelete: Restrict)
  fuelType        FuelType?        @relation(fields: [fuelTypeId],        references: [id], onDelete: Restrict)

  types           Item_Type[]
  warnings        Item_Warning[]
  dropTableEntries DropTable_Entry[]
  actions     ItemAction[]
  storedItems StoredItem[]
  equipmentProfiles ItemEquipmentProfile[]

  ingredientTypes        Item_IngredientType[]
  slotOptions            RecipeSlotOption[]
  recipeOutputs          RecipeOutput[]

  actionOutputs          ItemAction_Output[]  @relation("ItemActionOutputItem")  // back-relation: this item appears as an output of these actions
  eventItemEffects       EventEffect[]
  speciesDefaultLoadouts SpeciesDefaultLoadout[]
  rankDefaultItems              Rank_DefaultItem[]
  conditionGrants               ConditionDef_GrantedItem[]
  foodProfile                   ItemFoodProfile?
  actionTypeDefaultItems        ActionType_DefaultItem[]
  plantDef                      PlantDef?                      @relation("ItemPlantDef",         fields: [plantDefId], references: [id], onDelete: SetNull)
  propagationForPlantDefs       PlantDef[]                     @relation("PlantDefPropagationItem")

  structureBuildCosts               StructureDef_BuildCost[]
  structureUpgradeBuildCosts        StructureDef_Upgrade_BuildCost[]
  constructionItemRequirements      Construction_ItemRequirement[]
  compostInputs                     Item_CompostOutput[] @relation("ItemCompostInputs")
  compostOutputs                    Item_CompostOutput[] @relation("ItemCompostOutputs")
  compostDeposits                   Structure_CompostDeposit[]
  treatmentLogs          EntityTreatmentLog[]
  abilityGrantedActions  Ability_GrantedAction[]
  requiredByProfiles     ItemEquipmentProfile_RequiredItem[] @relation("ProfileRequiredItem")

  @@unique([guildId, codeName])  // ephemeral random suffix guarantees uniqueness without special handling
  @@index([guildId])
  @@index([guildId, name])       // non-unique display name lookup
}

// Item type tags attached to an item — many-to-many
model Item_Type {
  itemId     Int
  itemTypeId Int

  item     Item     @relation(fields: [itemId],     references: [id], onDelete: Cascade)
  itemType ItemType @relation(fields: [itemTypeId], references: [id], onDelete: Restrict)

  @@id([itemId, itemTypeId])
  @@index([itemTypeId])
}

// Defines what an item produces when composted. One row per output per item.
// An item with rotCap may have zero or more output rows — zero means it contributes
// mass to the compost queue but produces no output (still reduces pile, generates filth).
//
// inputMeasurement: "weight" | "volume" — must match the deposited item's measurementType.
// amountPerUnit:    grams or ml of input consumed per batch of this output.
// outputQuantity:   how much of the output item is produced per batch.
// dropChance:       0.0–1.0 probability this output triggers per conversion.
//                   1.0 = always; < 1.0 = rare/bonus output.
//                   Example: soil at 1.0 (guaranteed) + rare seed at 0.05 (5% bonus).
model Item_CompostOutput {
  id               Int    @id @default(autoincrement())
  structureDefId   Int                      // which compost StructureDef produces this output
  itemId           Int                      // the input item (must have rotCap)
  outputItemId     Int                      // the item produced
  measurementTypeId Int
  amountPerUnit    Float
  outputQuantity   Float  @default(1.0)
  dropChance       Float  @default(1.0)

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  item         Item         @relation("ItemCompostInputs",  fields: [itemId],       references: [id], onDelete: Cascade)
  outputItem   Item         @relation("ItemCompostOutputs", fields: [outputItemId], references: [id], onDelete: Restrict)
  measurementType MeasurementType @relation(fields: [measurementTypeId], references: [id], onDelete: Restrict)

  @@unique([structureDefId, itemId, outputItemId])
  @@index([itemId])
  @@index([outputItemId])
}

// ============================================================
// CRAFTING
// ============================================================






// Crafting verbs — entirely separate from ItemInteraction (global seed).
// Examples: Brew, Dry, Grind, Mash, Butcher, Craft, Bake, Render, Crush
model CraftingInteraction {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  description String @db.VarChar(300)

  recipes              Recipe[]
  structureConfigs     StructureDef_CraftingConfig_Interaction[]
  upgradeUnlocks       StructureDef_Upgrade_CraftingInteraction[]
  guildRules           Guild_CraftingInteractionRule[]
}

// Output quantity modes (global seed).
//   fixed:        outputQuantity = avgQuantity ± (avgQuantity × quantityVariance)
//   proportional: outputQuantity = inputWeight × inputProportion (butchering, rendering)
model RecipeOutputMode {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  recipeOutputs RecipeOutput[]
}

// A crafting recipe: one CraftingInteraction + input slots + output definitions.
// guildId = "global" for globally available recipes; guild snowflake for custom guild recipes.
model Recipe {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  craftingInteractionId Int

  requiresDiscovery Boolean @default(false)  // true = hidden until discovered via experimentation or admin grant
  craftingTimeMins  Int?    // null = instant; non-null = minutes required before output is produced
  maxBatchSize      Int?    // null = unlimited; maximum recipe executions per crafting action
  minCraftingLevel  Int?    // null = no minimum; minimum crafting skill level required to attempt

  craftingInteraction CraftingInteraction  @relation(fields: [craftingInteractionId], references: [id], onDelete: Restrict)

  slots              RecipeSlot[]
  outputs            RecipeOutput[]
  entityDiscoveries  Entity_DiscoveredRecipe[]
  disciplineRewards      Recipe_DisciplineReward[]
  craftingRequirements   Recipe_CraftingRequirement[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
  @@index([craftingInteractionId])
}

// Tracks which entities have discovered a recipe through experimentation or admin grant.
// Discovery is per-entity — each entity must discover a recipe themselves.
model Entity_DiscoveredRecipe {
  entityId     Int
  recipeId     Int
  discoveredAt DateTime @default(now()) @db.Timestamptz

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([entityId, recipeId])
  @@index([recipeId])
}

// Per-guild rules controlling when a crafting interaction is available and what improves it.
// If no rows exist for a guild+interaction, the interaction is available anywhere with no bonuses.
//
// relationType:
//   "requires" — the target must be present for the interaction to be usable.
//   "improves" — if the target is present, apply craftingRollBonus and outputQuantityBonus.
//
// orGroup:
//   null    — standalone rule; evaluated independently (AND logic).
//   non-null — grouped with other rows sharing the same guildId + craftingInteractionId + orGroup.
//             At least one row in the group must be satisfied (OR logic).
//             Different orGroup values on the same interaction are AND'd together.
//
// Example — smelt requires a workshop AND (a forge OR an anvil):
//   REQUIRES  structureDefId=workshop  orGroup: null
//   REQUIRES  structureDefId=forge     orGroup: 1
//   REQUIRES  structureDefId=anvil     orGroup: 1
//
// Exactly one target type must be set per row (enforced at app layer):
//   structureDefId                    — requires/improves a specific structure type
//   upgradeId                         — requires/improves a specific upgrade
//   disciplineDefId + minLevel        — requires a discipline at a minimum level
//   skillTreeNodeId                   — requires a specific skill tree node to be obtained
// craftingRollBonus and outputQuantityBonus are only applied when relationType = "improves".
model Guild_CraftingInteractionRule {
  id                    Int    @id @default(autoincrement())
  guildId               String @db.VarChar(50)
  craftingInteractionId Int
  relationTypeId        Int                      // FK → RelationType (isCraftingSystem = true); "requires" | "improves"
  orGroup               Int?                     // null = AND; non-null = OR group key
  structureDefId        Int?
  upgradeId             Int?
  disciplineDefId       Int?
  minLevel              Int?
  skillTreeNodeId       Int?
  // No bonus fields — for "improves" rows, bonus values are read from the referenced
  // StructureDef_CraftingConfig (structure) or StructureDef_Upgrade_Effect (upgrade).

  craftingInteraction CraftingInteraction   @relation(fields: [craftingInteractionId], references: [id], onDelete: Restrict)
  relationType        RelationType          @relation(fields: [relationTypeId],         references: [id], onDelete: Restrict)
  structureDef        StructureDef?         @relation(fields: [structureDefId],         references: [id], onDelete: Cascade)
  upgrade             StructureDef_Upgrade? @relation(fields: [upgradeId],              references: [id], onDelete: Cascade)
  disciplineDef       DisciplineDef?        @relation(fields: [disciplineDefId],        references: [id], onDelete: Restrict)
  skillTreeNode       SkillTreeNode?        @relation(fields: [skillTreeNodeId],         references: [id], onDelete: Cascade)

  @@index([guildId, craftingInteractionId])
  @@index([structureDefId])
  @@index([upgradeId])
  @@index([disciplineDefId])
  @@index([skillTreeNodeId])
}

// Discipline XP granted to the crafting entity on a successful recipe execution.
// Mirrors ActionType_DisciplineReward — any number of disciplines per recipe.
// Include the stat progression DisciplineDef row to grant stat point XP.
model Recipe_DisciplineReward {
  recipeId     Int
  disciplineId Int
  xpAmount     Int

  recipe     Recipe        @relation(fields: [recipeId],     references: [id], onDelete: Cascade)
  discipline DisciplineDef @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@id([recipeId, disciplineId])
  @@index([disciplineId])
}

// Per-recipe requirements and improvements. Follows the same logic as
// Guild_CraftingInteractionRule but applies to a single recipe rather than all
// recipes using a given interaction.
//
// relationType / orGroup semantics are identical to Guild_CraftingInteractionRule:
//   "requires" + orGroup null   → this target must be present (AND)
//   "requires" + orGroup N      → at least one row with orGroup N must be present (OR)
//   "improves"                  → if target is present, apply the bonus fields
//
// Exactly one target type must be set per row (enforced at app layer):
//   structureDefId                    — requires/improves a specific structure type
//   upgradeId                         — requires/improves a specific upgrade
//   disciplineDefId + minLevel        — requires a discipline at a minimum level
//   skillTreeNodeId                   — requires a specific skill tree node to be obtained
// Both recipe-level and interaction-level rules are evaluated at craft time; all must pass.
model Recipe_CraftingRequirement {
  id              Int  @id @default(autoincrement())
  recipeId        Int
  relationTypeId  Int                   // FK → RelationType (isCraftingSystem = true); "requires" | "improves"
  orGroup         Int?
  structureDefId  Int?
  upgradeId       Int?
  disciplineDefId Int?
  minLevel        Int?
  skillTreeNodeId Int?
  // No bonus fields — for "improves" rows, bonus values are read from the referenced
  // StructureDef_CraftingConfig (structure) or StructureDef_Upgrade_Effect (upgrade).

  recipe        Recipe                @relation(fields: [recipeId],        references: [id], onDelete: Cascade)
  relationType  RelationType          @relation(fields: [relationTypeId],  references: [id], onDelete: Restrict)
  structureDef  StructureDef?         @relation(fields: [structureDefId],  references: [id], onDelete: Cascade)
  upgrade       StructureDef_Upgrade? @relation(fields: [upgradeId],       references: [id], onDelete: Cascade)
  disciplineDef DisciplineDef?        @relation(fields: [disciplineDefId], references: [id], onDelete: Restrict)
  skillTreeNode SkillTreeNode?        @relation(fields: [skillTreeNodeId],  references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([structureDefId])
  @@index([upgradeId])
  @@index([disciplineDefId])
  @@index([skillTreeNodeId])
}

// One input requirement in a recipe. Multiple slots = multiple required ingredients.
// consumedOnUse = false: tool slot — item is required but returned after crafting (e.g. mortar and pestle).
// measurementTypeId: unit used to interpret the quantity field.
model RecipeSlot {
  id        Int     @id @default(autoincrement())
  recipeId  Int
  slotIndex Int     // display/processing order; ascending
  label     String? @db.VarChar(100)  // optional display label, e.g. "Binding", "Tool"

  quantity          Float   // per-batch minimum; total = quantity × batch_count when scalesWithBatch = true
  measurementTypeId Int
  consumedOnUse     Boolean @default(true)   // false = tool slot; item returned after crafting
  scalesWithBatch   Boolean @default(true)   // true  = total required scales with batch count (quantity × batches)
                                             // false = quantity is fixed regardless of batch count
                                             // consumedOnUse=false + scalesWithBatch=true  → 1 durability deducted per batch
                                             // consumedOnUse=false + scalesWithBatch=false → 1 durability deducted total

  recipe          Recipe          @relation(fields: [recipeId],          references: [id], onDelete: Cascade)
  measurementType MeasurementType @relation(fields: [measurementTypeId], references: [id], onDelete: Restrict)

  options RecipeSlotOption[]

  @@index([recipeId])
  @@index([measurementTypeId])
}

// One way to satisfy a RecipeSlot (OR relationship — any option satisfies the slot).
// Exactly one matching strategy (app-enforced):
//   itemId non-null: only this specific item satisfies the option
//   itemId null:     any item carrying ALL requiredTags and NONE of excludedTags satisfies the option
model RecipeSlotOption {
  id     Int  @id @default(autoincrement())
  slotId Int
  itemId Int?  // specific item; null if tag-based

  slot RecipeSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  item Item?      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  requiredTags RecipeSlotOption_RequiredTag[]
  excludedTags RecipeSlotOption_ExcludedTag[]

  @@index([slotId])
  @@index([itemId])
}

// Ingredient type an item MUST have to satisfy this slot option (AND relationship).
model RecipeSlotOption_RequiredTag {
  slotOptionId     Int
  ingredientTypeId Int

  slotOption     RecipeSlotOption @relation(fields: [slotOptionId],     references: [id], onDelete: Cascade)
  ingredientType IngredientType   @relation(fields: [ingredientTypeId], references: [id], onDelete: Restrict)

  @@id([slotOptionId, ingredientTypeId])
  @@index([ingredientTypeId])
}

// Ingredient type an item must NOT have to satisfy this slot option.
// e.g. Dry recipe excludes the Dried tag — cannot dry an already-dried item.
model RecipeSlotOption_ExcludedTag {
  slotOptionId     Int
  ingredientTypeId Int

  slotOption     RecipeSlotOption @relation(fields: [slotOptionId],     references: [id], onDelete: Cascade)
  ingredientType IngredientType   @relation(fields: [ingredientTypeId], references: [id], onDelete: Restrict)

  @@id([slotOptionId, ingredientTypeId])
  @@index([ingredientTypeId])
}

// One output produced by a recipe. A recipe can have multiple outputs (different outputModes allowed).
//
// Seeded output:   outputItemId non-null; ephemeral name/modifier fields unused.
// Ephemeral output: outputItemId null; app creates a new Item row at craft time:
//   - name computed from preName/postName + source item name (e.g. "Dried Yarrow Leaf")
//   - isEphemeral = true; child rows (ItemAction, ItemEffect, ItemFoodProfile, etc.) copied from source
//   - rotCapMultiplier applied to source item's rotCap
//   - addTags/removeTags applied to the new Item_IngredientType rows
//   - app deletes the Item row when the last StoredItem referencing it is consumed or removed
//
// onFailure:
//   false (default) = produced on successful skill roll
//   true            = produced on failed skill roll
//   A recipe can have both success and failure outputs simultaneously.
model RecipeOutput {
  id       Int @id @default(autoincrement())
  recipeId Int

  outputItemId Int?  // null for ephemeral outputs

  outputModeId     Int
  avgQuantity      Float  @default(1.0)  // fixed mode: base output quantity
  quantityVariance Float  @default(0.0)  // fixed mode: ± fraction; 0.2 = ×0.8–×1.2
  inputProportion  Float?               // proportional mode: fraction of consumed input weight → output quantity

  dropDC    Int     @default(1)      // min d20 roll to produce this output; 1 = always, 20 = nat 20 only
  onFailure Boolean @default(false)  // true = produced on failed skill roll only

  craftBonusApplies Boolean @default(false)  // carry source StoredItem.craftBonus to output StoredItem

  // Ephemeral output naming and modifiers (ignored for seeded outputs)
  preName                 String? @db.VarChar(100)  // prepended to source item display name: "Dried Yarrow Leaf"
  postName                String? @db.VarChar(100)  // appended to source item display name:  "Yarrow Paste"
  rotCapMultiplier        Float?                    // multiplied against source item's rotCap; null = unchanged. e.g. 10.0 = lasts 10× longer after drying.
  rotVariance             Float?                    // overrides source item's weightVariance for rot spread; null = inherit
  effectivenessMultiplier Float?                    // multiplied against all copied ItemEffect/ItemConditionEffect effectiveness values; null = unchanged
  outputMeasurementTypeId Int?                      // overrides measurementTypeId on the ephemeral item; null = inherit from source
                                                    // must be consistent with any addTags whose ingredient type implies a different unit (enforced app-side)

  recipe               Recipe           @relation(fields: [recipeId],               references: [id], onDelete: Cascade)
  outputItem           Item?            @relation(fields: [outputItemId],           references: [id], onDelete: Restrict)
  outputMode           RecipeOutputMode @relation(fields: [outputModeId],           references: [id], onDelete: Restrict)
  outputMeasurementType MeasurementType? @relation(fields: [outputMeasurementTypeId], references: [id], onDelete: Restrict)

  addTags    RecipeOutput_AddTag[]
  removeTags RecipeOutput_RemoveTag[]
  foodOverride RecipeOutput_FoodOverride?

  @@index([recipeId])
  @@index([outputItemId])
  @@index([outputModeId])
  @@index([outputMeasurementTypeId])
}

// Ingredient type added to the ephemeral output item's Item_IngredientType rows at craft time.
// e.g. Dry recipe adds the Dried ingredient type to the output.
model RecipeOutput_AddTag {
  recipeOutputId   Int
  ingredientTypeId Int

  recipeOutput   RecipeOutput   @relation(fields: [recipeOutputId],   references: [id], onDelete: Cascade)
  ingredientType IngredientType @relation(fields: [ingredientTypeId], references: [id], onDelete: Restrict)

  @@id([recipeOutputId, ingredientTypeId])
  @@index([ingredientTypeId])
}

// Ingredient type removed from the ephemeral output item's Item_IngredientType rows at craft time.
// e.g. remove Fresh tag when an item is dried or cooked.
model RecipeOutput_RemoveTag {
  recipeOutputId   Int
  ingredientTypeId Int

  recipeOutput   RecipeOutput   @relation(fields: [recipeOutputId],   references: [id], onDelete: Cascade)
  ingredientType IngredientType @relation(fields: [ingredientTypeId], references: [id], onDelete: Restrict)

  @@id([recipeOutputId, ingredientTypeId])
  @@index([ingredientTypeId])
}

// Sparse food profile overrides for ephemeral outputs (ignored for seeded outputs).
// Only non-null fields are applied; null = inherit value from source item's food profile.
// e.g. grinding a leaf into powder might increase plantNutritionPerGram while leaving hydration unchanged.
model RecipeOutput_FoodOverride {
  recipeOutputId Int @unique

  meatNutritionPerGram  Float?
  meatHydrationPerGram  Float?
  plantNutritionPerGram Float?
  plantHydrationPerGram Float?

  recipeOutput RecipeOutput @relation(fields: [recipeOutputId], references: [id], onDelete: Cascade)
}

// Attaches ingredient type tags to items for crafting slot matching.
// Guild-scoped: guildId = "global" for seeded assignments; guild snowflake for custom overrides.
// The same item can be categorized differently per guild.
model Item_IngredientType {
  guildId          String @db.VarChar(50)
  itemId           Int
  ingredientTypeId Int

  item           Item           @relation(fields: [itemId],           references: [id], onDelete: Cascade)
  ingredientType IngredientType @relation(fields: [ingredientTypeId], references: [id], onDelete: Restrict)

  @@id([guildId, itemId, ingredientTypeId])
  @@index([guildId])
  @@index([itemId])
  @@index([ingredientTypeId])
}

// ============================================================
// STORAGE
// ============================================================







// A named storage container belonging to a faction or an entity (never both)
// acceptedTypes restricts which item types this storage accepts; empty = accepts nothing
// Pure item container. Capacity, rot modifier, type restrictions, and ownership
// all live on the owner join table (Entity_Storage or Structure_Storage), not here.
model Storage {
  id      Int    @id @default(autoincrement())
  guildId String @db.VarChar(50)
  name    String @db.VarChar(200)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  entityStorage    Entity_Storage?
  structureStorage Structure_Storage?
  storedItems      StoredItem[]

  @@index([guildId])
}

// Personal entity inventory. Entity storage accepts all item types; no type restrictions apply.
// No expirationModifier — items decay at their natural rate in entity storage.
model Entity_Storage {
  entityId       Int   @id
  storageId      Int   @unique
  weightCapacity Float?  // null = no weight limit
  fluidCapacity  Float?  // null = no fluid limit (ml)

  entity  Entity  @relation(fields: [entityId],  references: [id], onDelete: Cascade)
  storage Storage @relation(fields: [storageId], references: [id], onDelete: Cascade)
}

// Assigns an entity to a housing structure. One row per entity — an entity can only have one home.
// The structure must be of type "housing" (enforced at app layer).
// App layer enforces StructureDef_HousingConfig capacity limits on assignment.
model Entity_Housing {
  entityId    Int      @id
  structureId Int
  assignedAt  DateTime @default(now()) @db.Timestamptz

  entity    Entity    @relation(fields: [entityId],    references: [id], onDelete: Cascade)
  structure Structure @relation(fields: [structureId], references: [id], onDelete: Restrict)

  @@index([structureId])
}

// Camp structure inventory. Owned by a storage-type Structure.
// expirationModifier: driven by StructureDef_StorageConfig base value + rot_modifier upgrade deltas; recomputed when upgrades apply.
// isPrimaryStorage: faction's designated primary for its accepted item types.
// acceptedTypes: item must match at least one accepted type to be stored here.
model Structure_Storage {
  structureId        Int   @id
  storageId          Int   @unique
  weightCapacity     Float?
  fluidCapacity      Float?
  expirationModifier Float   @default(1.0)
  isPrimaryStorage   Boolean @default(false)
  securityRating     Int     @default(0)  // effective sum of security_rating upgrade deltas; read by event system for theft/raid event weights

  structure Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  storage   Storage   @relation(fields: [storageId],   references: [id], onDelete: Cascade)

  acceptedTypes Structure_Storage_ItemType[]
}

// Item types accepted by a structure storage. A storage with no entries accepts nothing.
model Structure_Storage_ItemType {
  storageId  Int
  itemTypeId Int

  structureStorage Structure_Storage @relation(fields: [storageId],  references: [storageId], onDelete: Cascade)
  itemType         ItemType          @relation(fields: [itemTypeId], references: [id],        onDelete: Restrict)

  @@id([storageId, itemTypeId])
  @@index([itemTypeId])
}

// One physical instance of an item in a storage
// One row per instance — items are not stacked, so each has its own quantity and rotProgression for decay tracking
// isEquipped: only meaningful for entity-owned storage; true = item is currently equipped by the owning entity
// chosenProfileId + equippedAt are set together with isEquipped = true and cleared when unequipped
model StoredItem {
  id        Int   @id @default(autoincrement())
  storageId Int
  itemId    Int

  quantity       Float  // amount in item's unit (e.g. weight in grams, or 1.0 for count-based items)
  rotProgression Float  @default(0.0)  // accumulated rot points; increments by 1 per daily tick at base rate (modified by
                                        // storage.expirationModifier and active spoilage env conditions). Null-safe:
                                        // only relevant when item.rotCap is non-null. Rot% = rotProgression / item.rotCap.
  craftBonus     Float  @default(0.0)  // flat bonus accumulated through crafting skill rolls; added to ItemEffect.effectiveness on use
                                        // carries forward to ephemeral outputs when RecipeOutput.craftBonusApplies = true

  currentDurability Int?  // null when item.maxDurability is null; initialized from maxDurability on creation
  usesRemaining     Int?  // null when item.maxUses is null; initialized from maxUses on creation, decremented on use

  isEquipped      Boolean   @default(false)
  chosenProfileId Int?      // set at equip time; null when not equipped
  equippedAt      DateTime? @db.Timestamptz  // null when not equipped

  storage       Storage               @relation(fields: [storageId],       references: [id], onDelete: Cascade)
  item          Item                  @relation(fields: [itemId],           references: [id], onDelete: Restrict)
  chosenProfile ItemEquipmentProfile? @relation(fields: [chosenProfileId],  references: [id], onDelete: Restrict)

  @@index([storageId])
  @@index([itemId])
  @@index([chosenProfileId])
}

// ============================================================
// STRUCTURES
// ============================================================






// Seeded engine-level structure categories. Each type maps to a specific engine system.
// Guilds reference these when defining their own StructureDefs — they cannot create new types.
model StructureType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  structureDefTypes StructureDef_StructureType[]
  campLimits        Camp_StructureLimit[]
  campRequirements  StructureDef_CampRequirement[]
}

// Global seeded lookup for valid upgrade effect types.
// Boolean flags indicate which StructureType categories accept this effect.
// The worker switches on the name to apply the correct logic.
// requiresEnvTarget: when true, targetEnvConditionId on StructureDef_Upgrade_Effect must be set.
model UpgradeEffectType {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(50)
  description String? @db.VarChar(500)

  isStorage  Boolean @default(false)
  isFarming  Boolean @default(false)
  isHousing  Boolean @default(false)
  isMedical  Boolean @default(false)
  isCrafting Boolean @default(false)
  isCompost  Boolean @default(false)
  isPower    Boolean @default(false)  // valid for power-type structures (renamed from isFuel for consistency with StructureType name)

  requiresEnvTarget Boolean @default(false)

  effects StructureDef_Upgrade_Effect[]
}

// Used on both sides of the power system:
//   Sources:   declare input types (what items they accept) and output types (what power they produce).
//   Items:     carry a fuelTypeId matched against a source's input types on deposit.
//   Consumers: optionally declare accepted output types via StructureDef_AcceptedFuelType /
//              StructureDef_Upgrade_AcceptedFuelType; empty = satisfied by any output type.
model FuelType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  fuelConfigInputs      StructureDef_FuelConfig_InputFuelType[]       @relation("FuelConfigInput")
  fuelConfigOutputs     StructureDef_FuelConfig_OutputFuelType[]      @relation("FuelConfigOutput")
  items                 Item[]
  acceptedByStructures  StructureDef_AcceptedFuelType[]
  acceptedByUpgrades    StructureDef_Upgrade_AcceptedFuelType[]
}

// Guild-defined named structure. Types assigned via StructureDef_StructureType (most defs have one type).
// name: internal snake_case key (e.g. "mossy_storage_den")
// constructionPoints: progress points required for the initial build (see ActionSystemType.progressPoints for structure_contribute)
// Filth fields: dailyFilthAverage = average filth generated per day (null = exempt); filthCap = max filth (null = exempt).
// filthPerActivePlot: farming structures only — extra filth per active plot added on top of base roll.
model StructureDef {
  id                 Int     @id @default(autoincrement())
  guildId            String  @db.VarChar(50)
  name               String  @db.VarChar(200)
  displayName        String  @db.VarChar(200)
  description        String? @db.VarChar(1000)
  constructionPoints Int
  baseDurability     Int
  dailyFilthAverage  Int?
  filthPerActivePlot Int?
  filthCap           Int?
  isPowered          Boolean @default(false) // true = structure requires an active power source to function
  fuelCostPerHour    Float?                  // fuel units deducted from the satisfying power source each worker tick; null if not powered

  structureTypes   StructureDef_StructureType[]
  buildCosts       StructureDef_BuildCost[]
  campRequirements StructureDef_CampRequirement[]
  acceptedFuelTypes StructureDef_AcceptedFuelType[]
  relations        StructureDef_Relation[] @relation("StructureDefRelations")
  relatedTo        StructureDef_Relation[] @relation("StructureDefRelationTarget")
  storageConfig    StructureDef_StorageConfig?
  farmingConfig    StructureDef_FarmingConfig?
  housingConfig    StructureDef_HousingConfig?
  medicalConfig    StructureDef_MedicalConfig?
  compostConfig    StructureDef_CompostConfig?
  craftingConfig   StructureDef_CraftingConfig?
  fuelConfig       StructureDef_FuelConfig?
  compostOutputs           Item_CompostOutput[]
  craftingInteractionRules   Guild_CraftingInteractionRule[]
  recipeCraftingRequirements Recipe_CraftingRequirement[]
  upgrades         StructureDef_Upgrade[]
  structures       Structure[]

  @@index([guildId])
}

// Assigns one or more StructureTypes to a StructureDef.
// Most defs have exactly one type. Multi-type defs (e.g. a hospital = housing + medical) are supported.
// For multi-type defs, all relevant type-specific config tables must have a corresponding row.
model StructureDef_StructureType {
  structureDefId  Int
  structureTypeId Int

  structureDef  StructureDef  @relation(fields: [structureDefId],  references: [id], onDelete: Cascade)
  structureType StructureType @relation(fields: [structureTypeId], references: [id], onDelete: Restrict)

  @@id([structureDefId, structureTypeId])
  @@index([structureTypeId])
}

// Structure types that must have at least one active (non-broken, non-destroyed)
// instance in a camp before this StructureDef can be built there.
// Checked at Construction initiation. A def may have zero or more requirement rows.
model StructureDef_CampRequirement {
  structureDefId          Int
  requiredStructureTypeId Int

  structureDef          StructureDef  @relation(fields: [structureDefId],          references: [id], onDelete: Cascade)
  requiredStructureType StructureType @relation(fields: [requiredStructureTypeId], references: [id], onDelete: Restrict)

  @@id([structureDefId, requiredStructureTypeId])
  @@index([requiredStructureTypeId])
}

// Directed relation edges between StructureDefs within the same guild.
// relationType: REQUIRES | BLOCKS | UPGRADES
// REQUIRES: structureDefId cannot be built unless an active instance of targetStructureDefId
//           exists in the camp.
// BLOCKS:   structureDefId cannot be built if an active instance of targetStructureDefId
//           exists in the camp (one-directional).
// UPGRADES: structureDefId is a tier upgrade of targetStructureDefId. Requires an active
//           instance of targetStructureDefId (implicit REQUIRES). On Construction completion,
//           the target structure is set to destroyed and its applied upgrades are deleted.
//           No resources refunded.
model StructureDef_Relation {
  structureDefId       Int
  relationTypeId       Int
  targetStructureDefId Int

  structureDef StructureDef @relation("StructureDefRelations",     fields: [structureDefId],       references: [id], onDelete: Cascade)
  targetDef    StructureDef @relation("StructureDefRelationTarget", fields: [targetStructureDefId], references: [id], onDelete: Cascade)
  relationType RelationType @relation(                              fields: [relationTypeId],        references: [id], onDelete: Restrict)

  @@id([structureDefId, relationTypeId, targetStructureDefId])
  @@index([targetStructureDefId])
  @@index([relationTypeId])
}

// Items required to initiate the initial build of a StructureDef.
model StructureDef_BuildCost {
  structureDefId Int
  itemId         Int
  quantity       Int

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId],         references: [id], onDelete: Restrict)

  @@id([structureDefId, itemId])
  @@index([itemId])
}

// Base config for storage-type StructureDefs.
// baseRotModifier: < 1.0 = slower rot; used as the starting expirationModifier before upgrades.
model StructureDef_StorageConfig {
  structureDefId      Int   @id
  baseCapacitySolids  Int
  baseCapacityLiquids Int
  baseRotModifier     Float @default(1.0)

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
}

// Base config for housing-type StructureDefs.
// comfortableCapacity:    number of residents that can live here without penalty.
// maxCapacity:            null = strict (hard cap at comfortableCapacity; no overflow allowed).
//                         non-null = soft cap (residents may exceed comfortable up to this limit,
//                         with an overcrowding filth penalty applied to each entity's daily contribution).
// overcrowdingFilthBonus: multiplier bonus added to each overcrowded entity's daily filth contribution
//                         when occupants exceed comfortableCapacity. 0.5 = +50% (total 1.5×).
//                         Ignored when maxCapacity is null (strict structures never overcrowd).
model StructureDef_HousingConfig {
  structureDefId         Int   @id
  comfortableCapacity    Int
  maxCapacity            Int?  // null = strict; non-null = soft overcrowding limit
  overcrowdingFilthBonus Float @default(0.5)

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
}

// Base config for medical-type StructureDefs.
// treatmentRollBonus:   flat bonus added to treatment proficiency rolls made inside this structure.
// examRollBonus:        flat bonus added to examination (inspection) proficiency rolls made here.
// recoveryModifier:     multiplier applied to each housed patient's daily condition progression delta
//                       after the CON roll resolves. < 1.0 = conditions worsen more slowly / recover
//                       more quickly. Applied to Progressive and Chronic conditions only (Timed and
//                       LifeCycle conditions use fixed day counts, not progression deltas).
//                       Example: 0.8 = each day's progression change is 80% of what it would be elsewhere.
// contagionResistBonus: flat bonus added to the CON roll when a housed entity resists catching a
//                       contagious condition. Higher values represent better isolation practices.
//                       Default 0 (no bonus). Stack with the entity's own CON modifier.
model StructureDef_MedicalConfig {
  structureDefId      Int   @id
  treatmentRollBonus  Int   @default(0)
  examRollBonus       Int   @default(0)
  recoveryModifier    Float @default(1.0)
  contagionResistBonus Int  @default(0)

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
}

// Base config for farming-type StructureDefs.
// plotTypeId: all plots in this structure share this type. References PlotType (defined when farming schema is implemented).
// defaultSoilQuality: assigned to each plot when created, including plots added by plot_count upgrades.
model StructureDef_FarmingConfig {
  structureDefId     Int   @id
  plotTypeId         Int
  basePlotCount      Int
  defaultSoilQuality Float @default(0.0)  // starting soilQuality delta for new plots; 0.0 = neutral

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  plotType     PlotType     @relation(fields: [plotTypeId],     references: [id], onDelete: Restrict)
}

// Base config for crafting-type StructureDefs.
// craftingRollBonus:      flat bonus added to crafting skill rolls performed at this structure.
// outputQuantityBonus:    additive multiplier on output quantity (0.1 = +10% output).
// Supported interactions are defined in StructureDef_CraftingConfig_Interaction.
// Per-guild requirements and improvements are defined in Guild_CraftingInteractionRule.
model StructureDef_CraftingConfig {
  structureDefId      Int   @id
  craftingRollBonus   Int   @default(0)
  outputQuantityBonus Float @default(0.0)

  structureDef   StructureDef                           @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  interactions   StructureDef_CraftingConfig_Interaction[]
}

// Which crafting interactions a structure supports by default.
// Additional interactions can be unlocked via StructureDef_Upgrade_CraftingInteraction.
model StructureDef_CraftingConfig_Interaction {
  structureDefId        Int
  craftingInteractionId Int

  craftingConfig      StructureDef_CraftingConfig @relation(fields: [structureDefId],        references: [structureDefId], onDelete: Cascade)
  craftingInteraction CraftingInteraction          @relation(fields: [craftingInteractionId], references: [id],            onDelete: Restrict)

  @@id([structureDefId, craftingInteractionId])
  @@index([craftingInteractionId])
}

// Interactions unlocked when this upgrade is applied to a structure.
// Kept separate from StructureDef_Upgrade_Effect because the target is a CraftingInteraction
// ID rather than a numeric value.
model StructureDef_Upgrade_CraftingInteraction {
  upgradeId             Int
  craftingInteractionId Int

  upgrade             StructureDef_Upgrade @relation(fields: [upgradeId],             references: [id], onDelete: Cascade)
  craftingInteraction CraftingInteraction  @relation(fields: [craftingInteractionId],  references: [id], onDelete: Restrict)

  @@id([upgradeId, craftingInteractionId])
  @@index([craftingInteractionId])
}

// Base config for compost-type StructureDefs.
// Compost structures must also have the storage type — the output storage is where converted
// items land. Items eligible for composting are those with a non-null rotCap on Item.
// On deposit, the item is consumed and a Structure_CompostDeposit row is created.
//
// conversionDays:  days before a deposit converts to output. Upgrades reduce this.
// weightCapacity:  max total grams currently in the deposit queue; null = unlimited.
// volumeCapacity:  max total ml currently in the deposit queue; null = unlimited.
//
// Outputs are defined per input item on Item_CompostOutput — the structure def controls
// the timer and capacity only; what comes out is determined by what went in.
//
// Note: rotItemCount for filth generation is derived from deposit rows,
// not StoredItem rows, since items are consumed on deposit.
model StructureDef_CompostConfig {
  structureDefId Int    @id
  conversionDays Int
  weightCapacity Float?
  volumeCapacity Float?

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
}

// Base config for fuel-type StructureDefs (power sources).
//
// generatorType: "active"  — fueled by item deposits. Items with a matching fuelTypeId are
//                            destroyed on deposit and their fuelValue added to Structure.currentFuel.
//               "passive"  — fueled automatically by the worker each tick based on active env
//                            conditions. Generation rate is defined per condition in
//                            StructureDef_FuelConfig_EnvCondition. No item deposits; fuelTypeId unused.
//
// scope:        "structure" — satisfies only the structure this power source is built into.
//                             Requires the StructureDef to be a multi-type def that includes
//                             the power type alongside the powered type(s). The power source
//                             powers that structure and nothing else.
//               "camp"      — satisfies all isPowered structures/upgrades in the same camp.
//               "location"  — satisfies all isPowered structures/upgrades across all camps in
//                             the same location. Useful for large installations (e.g. a reactor)
//                             that sit outside a camp but serve the surrounding area.
//               "faction"   — satisfies all isPowered structures/upgrades across the entire faction
//                             regardless of location. Reserved for high-tier infrastructure.
//
// Input fuel types:  defined via StructureDef_FuelConfig_InputFuelType (join table).
//                   Items deposited must match one of the input types.
//                   No rows = accepts no item deposits (passive-only or input-free sources).
// Output fuel types: defined via StructureDef_FuelConfig_OutputFuelType (join table).
//                   What power type(s) this source produces — what consumers match against.
//
// fuelCapacity: max fuel units (1 unit = 1 hour) the structure can hold.
//               Drain is driven entirely by consumers (StructureDef.fuelCostPerHour /
//               StructureDef_Upgrade.fuelCostPerHour); the source itself has no idle drain.
//               The worker deducts each active consumer's cost from the satisfying source's
//               currentFuel once per tick (hourly).
//
// Camp-scope drain order: worker drains the lowest Structure.powerSortOrder source first;
// ties broken by Structure.id. Structure-scope sources drain independently.
model StructureDef_FuelConfig {
  structureDefId        Int    @id
  isActive              Boolean @default(false)
  scopeId                 Int
  fuelCapacity          Float  @default(100)   // max fuel units the bank can hold; upgradeable via fuel_capacity effect
  baseGenerationPerHour Float?                 // passive sources only — base fuel units generated per hour before env condition bonuses;
                                               // null on active sources (gain only from item deposits)

  structureDef   StructureDef                               @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  targetScope TargetScope @relation(fields: [scopeId], references: [id], onDelete: Restrict)
  inputFuelTypes StructureDef_FuelConfig_InputFuelType[]
  outputFuelTypes StructureDef_FuelConfig_OutputFuelType[]
  envConditions  StructureDef_FuelConfig_EnvCondition[]
}

// Fuel types a power source accepts as item inputs.
// Each deposited item's fuelTypeId must match one of these rows.
// No rows = source accepts no deposits (passive generators, or intentional input-free designs).
model StructureDef_FuelConfig_InputFuelType {
  structureDefId Int
  fuelTypeId     Int

  fuelConfig StructureDef_FuelConfig @relation(fields: [structureDefId], references: [structureDefId], onDelete: Cascade)
  fuelType   FuelType                @relation("FuelConfigInput",        fields: [fuelTypeId],          references: [id], onDelete: Restrict)

  @@id([structureDefId, fuelTypeId])
  @@index([fuelTypeId])
}

// Fuel types a power source produces — what consumers match against when resolving power.
// A source may output multiple types (e.g. a multi-output generator producing both Burnable heat and Electric).
model StructureDef_FuelConfig_OutputFuelType {
  structureDefId Int
  fuelTypeId     Int

  fuelConfig StructureDef_FuelConfig @relation(fields: [structureDefId], references: [structureDefId], onDelete: Cascade)
  fuelType   FuelType                @relation("FuelConfigOutput",       fields: [fuelTypeId],          references: [id], onDelete: Restrict)

  @@id([structureDefId, fuelTypeId])
  @@index([fuelTypeId])
}

// Env conditions that drive generation for a passive power source.
// Each tick the worker sums (stack count × generationRatePerStack) across all active conditions
// linked here and adds the result to Structure.currentFuel, capped at fuelCapacity.
// A passive source with no rows generates nothing (misconfigured — flagged at app layer).
model StructureDef_FuelConfig_EnvCondition {
  structureDefId         Int
  envConditionId         Int
  generationRatePerStack Float @default(1.0) // fuel units added per hour per stack of this condition

  fuelConfig   StructureDef_FuelConfig @relation(fields: [structureDefId], references: [structureDefId], onDelete: Cascade)
  envCondition EnvCondition            @relation(fields: [envConditionId], references: [id],             onDelete: Restrict)

  @@id([structureDefId, envConditionId])
  @@index([envConditionId])
}

// Fuel types a powered StructureDef will accept from power sources.
// Empty = accepts any fuel type. Populated = only matched fuel types satisfy this structure's power requirement.
model StructureDef_AcceptedFuelType {
  structureDefId Int
  fuelTypeId     Int

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)
  fuelType     FuelType     @relation(fields: [fuelTypeId],     references: [id], onDelete: Restrict)

  @@id([structureDefId, fuelTypeId])
  @@index([fuelTypeId])
}

// Fuel types a powered upgrade will accept from power sources.
// Empty = accepts any fuel type. Populated = only matched fuel types satisfy this upgrade's power requirement.
model StructureDef_Upgrade_AcceptedFuelType {
  upgradeId  Int
  fuelTypeId Int

  upgrade  StructureDef_Upgrade @relation(fields: [upgradeId],  references: [id], onDelete: Cascade)
  fuelType FuelType             @relation(fields: [fuelTypeId], references: [id], onDelete: Restrict)

  @@id([upgradeId, fuelTypeId])
  @@index([fuelTypeId])
}

// A discrete, independently applicable upgrade for a StructureDef.
// maxApplications: 1 = one-time only; > 1 = stackable up to this limit.
// constructionPoints: progress points required to apply this upgrade.
// Effects are defined in StructureDef_Upgrade_Effect — one row per effect.
model StructureDef_Upgrade {
  id                 Int     @id @default(autoincrement())
  structureDefId     Int
  name               String  @db.VarChar(200)
  displayName        String  @db.VarChar(200)
  description        String? @db.VarChar(1000)
  maxApplications    Int
  constructionPoints Int
  isPowered          Boolean @default(false) // true = upgrade's effects are suspended when no active power source satisfies it
  fuelCostPerHour    Float?                  // fuel units deducted from the satisfying power source each worker tick; null if not powered

  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Cascade)

  effects              StructureDef_Upgrade_Effect[]
  buildCosts           StructureDef_Upgrade_BuildCost[]
  relations            StructureDef_Upgrade_Relation[]             @relation("UpgradeRelations")
  relatedTo            StructureDef_Upgrade_Relation[]             @relation("UpgradeRelationTarget")
  craftingInteractions     StructureDef_Upgrade_CraftingInteraction[]
  craftingInteractionRules   Guild_CraftingInteractionRule[]
  recipeCraftingRequirements Recipe_CraftingRequirement[]
  appliedUpgrades            Structure_AppliedUpgrade[]
  constructions        Construction[]
  acceptedFuelTypes    StructureDef_Upgrade_AcceptedFuelType[]

  @@index([structureDefId])
}

// Individual effects of an upgrade. An upgrade may have one or more effects,
// all applied together when the upgrade's Construction completes.
// effectTypeId must be valid for the parent StructureDef's StructureType (enforced at app layer).
// effectValue: additive delta applied per application.
// targetEnvConditionId: required when UpgradeEffectType.requiresEnvTarget = true; null otherwise.
model StructureDef_Upgrade_Effect {
  id                   Int    @id @default(autoincrement())
  upgradeId            Int
  effectTypeId         Int
  effectValue          Float
  targetEnvConditionId Int?

  upgrade            StructureDef_Upgrade @relation(fields: [upgradeId],            references: [id], onDelete: Cascade)
  effectType         UpgradeEffectType    @relation(fields: [effectTypeId],          references: [id], onDelete: Restrict)
  targetEnvCondition EnvCondition?        @relation(fields: [targetEnvConditionId], references: [id], onDelete: Restrict)

  @@index([upgradeId])
  @@index([effectTypeId])
}

// Directed relation edges between upgrades on the same StructureDef.
// relationType: REQUIRES | BLOCKS | UPGRADES
// REQUIRES: upgradeId cannot be applied unless targetUpgradeId has been applied at least once.
// BLOCKS:   upgradeId cannot be applied if targetUpgradeId is already applied (one-directional).
// UPGRADES: upgradeId supersedes targetUpgradeId; on completion, all Structure_AppliedUpgrade
//           rows for targetUpgradeId are deleted (no item refund). UPGRADES implies REQUIRES.
model StructureDef_Upgrade_Relation {
  upgradeId       Int
  relationTypeId  Int
  targetUpgradeId Int

  upgrade      StructureDef_Upgrade @relation("UpgradeRelations",      fields: [upgradeId],       references: [id], onDelete: Cascade)
  target       StructureDef_Upgrade @relation("UpgradeRelationTarget", fields: [targetUpgradeId], references: [id], onDelete: Cascade)
  relationType RelationType         @relation(                          fields: [relationTypeId],  references: [id], onDelete: Restrict)

  @@id([upgradeId, relationTypeId, targetUpgradeId])
  @@index([targetUpgradeId])
  @@index([relationTypeId])
}

// Items required to apply a specific upgrade.
model StructureDef_Upgrade_BuildCost {
  upgradeId Int
  itemId    Int
  quantity  Int

  upgrade StructureDef_Upgrade @relation(fields: [upgradeId], references: [id], onDelete: Cascade)
  item    Item                 @relation(fields: [itemId],    references: [id], onDelete: Restrict)

  @@id([upgradeId, itemId])
  @@index([itemId])
}

// A single built (or in-progress) installation within a camp.
// status: active | under_construction | broken | destroyed
// broken — durability reached 0; storage protections suspended, farm plots locked.
//          Counts against Camp_StructureLimit until cleared or rebuilt.
// destroyed — cleared by faction leader; no longer counts against limit.
model Structure {
  id                 Int     @id @default(autoincrement())
  campId             Int
  structureDefId     Int
  statusId           Int
  currentDurability  Int
  filthLevel         Int     @default(0)
  name               String? @db.VarChar(200)
  currentFuel        Float?               // null = not a fuel structure; 0–fuelCapacity when fuel type
  isFuelActive       Boolean @default(false) // power SOURCE toggle — worker only drains/generates when true
  isPoweredOn        Boolean @default(false) // power CONSUMER toggle — when false, powered functionality disabled and no fuel drawn
  powerSortOrder     Int?                 // camp-scope sources only; lower = drained first by worker. null = not a camp-scope source

  camp         Camp         @relation(fields: [campId],         references: [id], onDelete: Cascade)
  structureDef StructureDef @relation(fields: [structureDefId], references: [id], onDelete: Restrict)
  status       Status       @relation(fields: [statusId], references: [id], onDelete: Restrict)

  appliedUpgrades  Structure_AppliedUpgrade[]
  structureStorage Structure_Storage?
  constructions    Construction[]
  plots            Plot[]
  residents        Entity_Housing[]
  compostDeposits  Structure_CompostDeposit[]

  @@index([campId])
  @@index([structureDefId])
}

// One row per upgrade application on a structure. Created when a Construction for that upgrade completes.
model Structure_AppliedUpgrade {
  id          Int      @id @default(autoincrement())
  structureId Int
  upgradeId   Int
  appliedAt   DateTime @default(now()) @db.Timestamptz
  isPoweredOn Boolean  @default(false) // power CONSUMER toggle for powered upgrades — when false, upgrade effects suspended and no fuel drawn

  structure Structure            @relation(fields: [structureId], references: [id], onDelete: Cascade)
  upgrade   StructureDef_Upgrade @relation(fields: [upgradeId],   references: [id], onDelete: Restrict)

  @@index([structureId])
  @@index([upgradeId])
}

// A build or upgrade project. Exists for the duration of the work; completedAt is set on completion.
// upgradeId null = initial build; non-null = applying a specific upgrade.
// Item costs are consumed from faction storage when the Construction is initiated.
// On completion: initial build → Structure.status = active; upgrade → Structure_AppliedUpgrade row created.
// For plot_count upgrades: new Plot rows are also created on completion.
// constructionType: build | upgrade | repair | rebuild
// upgradeId: only set when constructionType = "upgrade".
// repairCostProportion: only set when constructionType = "repair". Captures the damage
//   fraction at initiation: (maxDurability - currentDurability) / maxDurability.
//   Stored so mid-repair damage events don't change what was already charged.
model Construction {
  id                    Int       @id @default(autoincrement())
  structureId           Int
  constructionType      String    @db.VarChar(20) @default("build")
  upgradeId             Int?
  repairCostProportion  Float?
  pointsRequired        Int
  pointsRemaining       Int
  initiatedByEntityId   Int
  startedAt             DateTime  @default(now()) @db.Timestamptz
  completedAt           DateTime? @db.Timestamptz

  structure         Structure             @relation(fields: [structureId],         references: [id], onDelete: Cascade)
  upgrade           StructureDef_Upgrade? @relation(fields: [upgradeId],           references: [id], onDelete: Restrict)
  initiatedByEntity Entity                @relation(fields: [initiatedByEntityId], references: [id], onDelete: Restrict)

  itemRequirements  Construction_ItemRequirement[]

  @@index([structureId])
  @@index([initiatedByEntityId])
}

// Tracks required materials and contribution progress for an active construction.
// Rows are created at initiation with quantityContributed = 0 and deleted on completion.
// Construction cannot complete until all rows have quantityContributed >= quantityRequired
// AND pointsRemaining = 0.
model Construction_ItemRequirement {
  constructionId      Int
  itemId              Int
  quantityRequired    Int
  quantityContributed Int @default(0)

  construction Construction @relation(fields: [constructionId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId],         references: [id], onDelete: Restrict)

  @@id([constructionId, itemId])
  @@index([itemId])
}

// A single in-progress compost batch. Created when an eligible item is deposited;
// the item is consumed immediately (removed from inventory). On convertsAt, the worker:
//   1. Looks up Item_CompostOutput rows for deposit.itemId.
//   2. Rolls each output row against dropChance.
//   3. For each triggered output: floor(amount / amountPerUnit) * outputQuantity added to storage.
//   4. Deletes this row.
// Remainders below the amountPerUnit threshold are lost (composting is not perfectly efficient).
model Structure_CompostDeposit {
  id          Int      @id @default(autoincrement())
  structureId       Int
  itemId            Int                      // which item was deposited — needed to resolve Item_CompostOutput
  measurementTypeId Int
  amount            Float
  depositedAt DateTime @default(now()) @db.Timestamptz
  convertsAt  DateTime @db.Timestamptz

  structure       Structure       @relation(fields: [structureId],       references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId],            references: [id], onDelete: Restrict)
  measurementType MeasurementType @relation(fields: [measurementTypeId], references: [id], onDelete: Restrict)

  @@index([structureId])
  @@index([convertsAt])
}

// ============================================================
// LOCATIONS & CAMPS
// ============================================================






// A named territory / point of interest in a guild's world (e.g. Sunningrocks, Fourtrees, Mothermouth).
// Ownership and status are managed via Location_Faction join rows.
model Location {
  id          Int     @id @default(autoincrement())
  guildId     String
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  preyChance     Float @default(1.0)
  preyWeight     Float @default(1.0)
  herbChance     Float @default(1.0)
  herbWeight     Float @default(1.0)
  predatorChance Float @default(1.0)
  hazardChance   Float @default(1.0)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  factions          Location_Faction[]
  borders           LocationBorder[]
  biomes            Location_Biome[]
  envConditions     Location_EnvCondition[]
  actionInstances   ActionInstance[]
  eventTriggers     EventDef_Location[]
  camps             Camp[]

  @@unique([guildId, name])
  @@index([guildId])
}

// Which factions are associated with a territory, and what their relationship to it is (Owned, Shared, Disputed).
// A territory can have multiple factions with different statuses.
model Location_Faction {
  locationId Int
  factionId    Int
  relationTypeId   Int

  location Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  faction    Faction           @relation(fields: [factionId],    references: [id], onDelete: Cascade)
  relationType RelationType  @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)

  @@id([locationId, factionId])
  @@index([factionId])
  @@index([relationTypeId])
}

// A neighboring faction that borders this location from outside the owning faction's territory
// Used to determine whether an entity could trespass without crossing all of another faction's land
model LocationBorder {
  locationId       Int
  borderingFactionId Int

  location       Location @relation(fields: [locationId],       references: [id], onDelete: Cascade)
  borderingFaction Faction    @relation(fields: [borderingFactionId], references: [id], onDelete: Cascade)

  @@id([locationId, borderingFactionId])
  @@index([borderingFactionId])
}

// Biomes present at a location — a location can have multiple biomes (e.g. Forest + River)
model Location_Biome {
  locationId Int
  biomeId    Int
  weight     Float @default(1.0)  // relative contribution of this biome at this location; higher = more likely items/spawns from this biome; compared against sum of all biome weights at the location

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  biome    Biome    @relation(fields: [biomeId],    references: [id], onDelete: Restrict)

  @@id([locationId, biomeId])
  @@index([biomeId])
}

// Per-location environmental condition additions — use for locations that deviate from their biome baseline.
// e.g. a Forest location in a low valley might add an extra Damp stack beyond what Forest normally carries.
// Stacks on top of biome contributions; a location with no entries relies entirely on its biomes + active season/weather.
model Location_EnvCondition {
  locationId     Int
  envConditionId Int
  stacks         Int @default(1)  // additional stacks beyond what the location's biomes contribute; minimum 1 (enforced app-side)

  location     Location     @relation(fields: [locationId],     references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)

  @@id([locationId, envConditionId])
  @@index([envConditionId])
}


// A physical camp installation at a location. Admin-created; not built via Construction.
// Filth is tracked per-structure (Structure.filthLevel); camp-level filth is a runtime aggregate only.
// See filth-system.md for generation formula, caps, and event trigger rules.
//
// Faction membership is managed via Camp_Faction (bridge table):
//   owner  — the faction that owns and administrates this camp (exactly one; enforced at app layer)
//   shared — factions granted access to act on this camp (e.g. a border garden shared between two factions)
//
// isActive: when false the worker skips this camp entirely — no events fire, no daily ticks run.
//           Used for camps a faction is not currently occupying (e.g. seasonal camps, abandoned outposts).
model Camp {
  id          Int     @id @default(autoincrement())
  guildId     String  @db.VarChar(50)
  locationId  Int
  codeName    String  @db.VarChar(200) // snake_case slug; unique per guild
  name        String  @db.VarChar(200) // display name; not unique
  description String? @db.VarChar(500)
  isActive    Boolean @default(false)  // true = included in world sim ticks; false = dormant

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  factions        Camp_Faction[]
  structureLimits Camp_StructureLimit[]
  structures      Structure[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([locationId])
}

// Faction membership for a camp.
// role: "owner"  — administrating faction; exactly one per camp (enforced at app layer).
//       "shared" — faction has access to act on this camp (build, harvest, house entities, etc.)
// Deleting the owner row does not cascade-delete the camp — app layer must handle ownership transfer
// or camp archival before removing the owning faction's row.
model Camp_Faction {
  campId              Int
  factionId           Int
  relationTypeId  Int

  camp    Camp    @relation(fields: [campId],    references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)
  relationType RelationType @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)

  @@id([campId, factionId])
  @@index([factionId])
}

// Per-camp cap on how many structures of each type may be built.
// No row for a given type means that type cannot be built in this camp.
model Camp_StructureLimit {
  campId          Int
  structureTypeId Int
  maxCount        Int

  camp          Camp          @relation(fields: [campId],          references: [id], onDelete: Cascade)
  structureType StructureType @relation(fields: [structureTypeId], references: [id], onDelete: Restrict)

  @@id([campId, structureTypeId])
  @@index([structureTypeId])
}

// ============================================================
// ACTIONS
// ============================================================







// Seeded reference table — identifies which bot subsystem an ActionType invokes on resolution.
// Only ActionTypes with guildId = "global" may reference this table (app-layer enforced).
model ActionSystemType {
  id          String  @id @db.VarChar(50)   // e.g. "patrol", "hunting", "spar", "farming_water"
  description String  @db.VarChar(500)

  cooldownHours     Int?  // null = no cooldown enforced by this system type; global per-plot time lock for farming actions
  progressPoints    Int?  // null = no progress tracking; for farming = care points per action; for construction = points per contribution
  entityDailyLimit  Int?  // null = unlimited; max times per day any one entity may perform this action type globally

  actionTypes         ActionType[]
  abilityTriggers     Ability_ActionTrigger[]
  tendRecords         Plot_TendRecord[]
  entityDailyRecords  Action_EntityDailyRecord[]
}

// Per-entity daily action count. Tracks how many times an entity has performed each ActionSystemType today.
// Row is upserted on every resolution; checked against ActionSystemType.entityDailyLimit before resolving.
// Date is stored as UTC date (day boundary). Rows may be pruned on daily tick.
model Action_EntityDailyRecord {
  entityId   Int
  systemType String   @db.VarChar(50)   // FK → ActionSystemType
  date       DateTime @db.Date           // UTC date; truncated to day
  count      Int      @default(1)

  entity           Entity           @relation(fields: [entityId],   references: [id], onDelete: Cascade)
  actionSystemType ActionSystemType @relation(fields: [systemType], references: [id], onDelete: Cascade)

  @@id([entityId, systemType, date])
  @@index([entityId, date])
}

// Defines the set of actions cats can spend daily energy on (patrol, hunt, gather herbs, train, etc.)
// Guild-extensible; guildId = "global" for seeded defaults.
// Identity and eligibility only — costs and rewards are configured per-guild in Guild_ActionConfig
// and ActionType_DisciplineReward.
// Eligibility mirrors EventDef: requiresCanMentor gates adult-only actions; allowApprenticesWithAdult permits
// apprentices when at least one canMentor entity is present.
model ActionType {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  name        String  @db.VarChar(100)    // internal key e.g. "border_patrol"
  displayName String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  // Eligibility
  requiresCanMentor         Boolean @default(false)
  allowApprenticesWithAdult Boolean @default(false)
  requiresCanLeadEvents     Boolean @default(false)  // true = the entity initiating this action must have Rank.canLeadEvents
  minAge               Int?

  // Resolution mode — null = pure reward action (auto-resolves, no subsystem invoked).
  // App rule: only guildId = "global" actions may have a non-null systemTypeId.
  systemTypeId  String?           @db.VarChar(50)
  systemType    ActionSystemType? @relation(fields: [systemTypeId], references: [id], onDelete: Restrict)
  // false = quick (auto-resolves in background, posts summary)
  // true  = interactive (step-by-step): each participant's roll is surfaced
  isInteractive Boolean @default(false)

  eventTriggers          EventDef_ActionType[]
  instances              ActionInstance[]
  defaultItems           ActionType_DefaultItem[]
  guildConfigs           Guild_ActionConfig[]
  disciplineRewards      ActionType_DisciplineReward[]
  disciplineRequirements ActionType_DisciplineRequirement[]
  entityUsage            Entity_ActionUsage[]

  @@unique([guildId, name])
  @@index([guildId])
}

// Per-guild configuration for a global action type.
// If no row exists for a guild+action, the action is unavailable in that guild until configured.
// baseFactionReward may be negative (e.g. a risky or taboo activity).
model Guild_ActionConfig {
  guildId      String @db.VarChar(50)
  actionTypeId Int

  energyCost        Int  @default(10)
  dailyLimit        Int?               // null = energy-only limit; non-null = max starts per entity per day
  minEntities       Int  @default(1)
  maxEntities       Int?               // null = unlimited
  durationMinutes   Int?               // null = resolves immediately on next tick
  baseFactionReward Int  @default(0)

  actionType ActionType @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)

  @@id([guildId, actionTypeId])
  @@index([actionTypeId])
}

// Per-guild XP rewards for action completion. Each guild configures its own reward amounts.
// Include the stat progression DisciplineDef row here to grant stat point XP.
model ActionType_DisciplineReward {
  guildId      String @db.VarChar(50)
  actionTypeId Int
  disciplineId Int
  xpAmount     Int
  // Who receives this reward on completion:
  // "all"               — every participant
  // "leader_only"       — only ActionInstance.leaderEntityId
  // "participants_only" — all non-leader participants
  // "winners_only"      — winning side of a combat-spawning action (e.g. spar)
  // "losers_only"       — losing side of a combat-spawning action
  recipientScope String @default("all") @db.VarChar(30)

  actionType ActionType    @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)
  discipline DisciplineDef @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@id([guildId, actionTypeId, disciplineId, recipientScope])
  @@index([actionTypeId])
  @@index([disciplineId])
}

// Items shadow-added and equipped to the patrol leader when they start an ActionInstance, removed when it ends.
// leaderOnly = true  → only granted to the entity in ActionInstance.leaderEntityId (default)
// leaderOnly = false → granted to all participants (e.g. a shared patrol item every entity carries)
model ActionType_DefaultItem {
  actionTypeId Int
  itemId       Int
  autoEquip    Boolean @default(true)
  leaderOnly   Boolean @default(true)

  actionType ActionType @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId],       references: [id], onDelete: Cascade)

  @@id([actionTypeId, itemId])
  @@index([itemId])
}

// Per-guild discipline level gate on an action type.
// scope = "leader" → only the ActionInstance.leaderEntityId must meet the requirement.
// scope = "all"    → every participant must meet the requirement.
model ActionType_DisciplineRequirement {
  guildId      String @db.VarChar(50)
  actionTypeId Int
  disciplineId Int
  minLevel     Int
  scope        String @default("all") @db.VarChar(10)  // "leader" | "all"

  actionType  ActionType    @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)
  discipline  DisciplineDef @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@id([guildId, actionTypeId, disciplineId])
  @@index([actionTypeId])
  @@index([disciplineId])
}

// Tracks how many times an entity has started each action type on a given calendar day.
// Created on first use; incremented on each subsequent use that day.
// Used to enforce Guild_ActionConfig.dailyLimit. Rows older than today can be pruned by the daily tick.
model Entity_ActionUsage {
  entityId     Int
  actionTypeId Int
  date         DateTime @db.Date  // calendar date only; compared against guild's current day
  usageCount   Int      @default(1)

  entity     Entity     @relation(fields: [entityId],     references: [id], onDelete: Cascade)
  actionType ActionType @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)

  @@id([entityId, actionTypeId, date])
  @@index([actionTypeId])
}

// An in-progress or completed instance of an activity taken by a faction of cats
model ActionInstance {
  id           Int    @id @default(autoincrement())
  actionTypeId Int
  factionId      Int
  locationId   Int?   // where the action takes place; null = at camp
  leaderEntityId  Int?   // the entity leading this instance; null until set at start

  isActive    Boolean   @default(true)  // false = ended (completed or interrupted)
  startedAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz

  actionType ActionType @relation(fields: [actionTypeId], references: [id], onDelete: Restrict)
  faction      Faction      @relation(fields: [factionId],      references: [id], onDelete: Cascade)
  location   Location?  @relation(fields: [locationId],   references: [id], onDelete: SetNull)
  leader     Entity?    @relation("ActionInstanceLeader", fields: [leaderEntityId], references: [id], onDelete: SetNull)

  participants ActionInstance_Entity[]
  activeEvent  ActiveEvent?

  @@index([factionId])
  @@index([actionTypeId])
  @@index([locationId])
  @@index([leaderEntityId])
}

// The entities participating in an action instance and how much energy each spent
model ActionInstance_Entity {
  actionInstanceId Int
  entityId         Int

  energySpent      Int @default(0)
  factionRepEarned Int @default(0)  // snapshot of faction rep granted to this entity on completion; may be negative

  actionInstance ActionInstance                    @relation(fields: [actionInstanceId], references: [id], onDelete: Cascade)
  entity         Entity                            @relation(fields: [entityId],         references: [id], onDelete: Cascade)
  disciplineXp   ActionInstance_Entity_DisciplineXp[]

  @@id([actionInstanceId, entityId])
  @@index([entityId])
}

// Snapshot of XP granted per discipline to a participant on action completion.
// Mirrors ActionType_DisciplineReward at the time of resolution.
model ActionInstance_Entity_DisciplineXp {
  actionInstanceId Int
  entityId         Int
  disciplineId     Int
  xpEarned         Int

  participant ActionInstance_Entity @relation(fields: [actionInstanceId, entityId], references: [actionInstanceId, entityId], onDelete: Cascade)
  discipline  DisciplineDef         @relation(fields: [disciplineId],               references: [id],                        onDelete: Restrict)

  @@id([actionInstanceId, entityId, disciplineId])
  @@index([disciplineId])
}

// ============================================================
// EVENTS
// ============================================================







model EventTriggerType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  eventDefs EventDef[]
}

model EventScope {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  eventDefs EventDef[]
}

model EventStepType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  stepDefs EventStepDef[]
}

// appliesToAll:    effect applies to every participant individually
// appliesToRandom: effect applies to one randomly selected participant
// appliesToLeader: effect applies to the action leader only
// appliesToGroup:  effect applies to the group of participants collectively
model EventParticipantScope {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  appliesToAll    Boolean @default(false)
  appliesToRandom Boolean @default(false)
  appliesToLeader Boolean @default(false)
  appliesToGroup  Boolean @default(false)

  stepDefs     EventStepDef[]
  outcomeDefs  EventOutcomeDef[]
  eventEffects EventEffect[]
}

model EventEffectType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  eventEffects EventEffect[]
}

model EventCheckMode {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  choiceDefs EventChoiceDef[]
}


// Top-level event definition.
//
// triggerType:
//   "admin"         — admin-initiated; participants provided via signup before the chain starts
//   "activity"      — fires during an ActionInstance; participants pulled from the activity roster
//   "weather_onset" — fires automatically when a matching WeatherState becomes active
//   "filth"         — fires when faction filth/cap ratio crosses a threshold (see EventDef_FilthTrigger)
//   "daily"         — Worker rolls once per day per guild; chancePerDay controls probability
//
// scope:
//   "global" — posted guild-wide; not tied to any faction or activity
//   "faction"  — scoped to one faction
//   "action" — scoped to a specific ActionInstance
//
// Eligibility (checked before the chain begins against the provided participant list):
//   requiresLeader            — at least one participant must have Rank.canLeadEvents = true
//   requiresCanMentor         — all participants must have Rank.canMentor = true
//   allowApprenticesWithAdult — non-mentor ranks OK if ≥1 canMentor entity is present
//   minAge               — minimum entity age gate; null = no requirement
model EventDef {
  id          Int     @id @default(autoincrement())
  guildId     String  @default("global") @db.VarChar(50)
  codeName    String  @db.VarChar(200)  // snake_case slug; unique per guild
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  triggerTypeId Int
  scopeId       Int

  baseWeight   Float  @default(1.0)  // base spawn weight for activity/daily selection
  chancePerDay Float?                // triggerType = "daily" only

  // Eligibility
  requiresLeader            Boolean @default(false)
  requiresCanMentor         Boolean @default(false)
  allowApprenticesWithAdult Boolean @default(false)
  minAge               Int?

  // Cooldown — days before this event can fire again for the same faction/guild
  cooldownDays Int @default(3)

  // Trigger conditions
  weatherTriggers     EventDef_WeatherTrigger[]
  actionTriggers      EventDef_ActionType[]
  filthTrigger        EventDef_FilthTrigger?
  envConditionWeights EnvCondition_EventDef[]
  locationTriggers    EventDef_Location[]
  prerequisites       EventDef_Prerequisite[] @relation("EventPrerequisites")
  isPrerequisiteFor   EventDef_Prerequisite[] @relation("EventIsPrerequisiteFor")

  // Content
  steps EventStepDef[]

  triggerType EventTriggerType @relation(fields: [triggerTypeId], references: [id], onDelete: Restrict)
  scope       EventScope       @relation(fields: [scopeId],       references: [id], onDelete: Restrict)

  // Back-relations
  profileTriggers ItemEquipmentProfile[]
  cooldowns       EventCooldown[]
  activeEvents       ActiveEvent[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
  @@index([triggerTypeId])
  @@index([scopeId])
}

// Weather state that gates or boosts an event.
// required = true:  event can ONLY fire when this weather state is active
// required = false: weather boosts the event's effective selection weight by weightMod
// triggersOnOnset:  for triggerType = "weather_onset", fires when the weather state activates
model EventDef_WeatherTrigger {
  eventDefId     Int
  weatherStateId Int

  required        Boolean @default(false)
  weightMod       Float   @default(0.0)
  triggersOnOnset Boolean @default(false)

  eventDef     EventDef     @relation(fields: [eventDefId],     references: [id], onDelete: Cascade)
  weatherState WeatherState @relation(fields: [weatherStateId], references: [id], onDelete: Cascade)

  @@id([eventDefId, weatherStateId])
  @@index([weatherStateId])
}

// Which action types can trigger this event, and how much they boost its selection weight
model EventDef_ActionType {
  eventDefId   Int
  actionTypeId Int

  weightMod Float @default(0.0)

  eventDef   EventDef   @relation(fields: [eventDefId],   references: [id], onDelete: Cascade)
  actionType ActionType @relation(fields: [actionTypeId], references: [id], onDelete: Cascade)

  @@id([eventDefId, actionTypeId])
  @@index([actionTypeId])
}

// Filth threshold trigger.
// chancePerDay scales linearly above filthThreshold.
// isOngoing: true = event persists and re-applies effects each tick until filth drops below threshold.
model EventDef_FilthTrigger {
  eventDefId Int @id

  filthThreshold Float   // filth/cap ratio (0.0–1.0) at which daily roll begins
  chancePerDay   Float   // base daily chance at filth/cap = 1.0; scales linearly above threshold
  isOngoing      Boolean @default(false)

  eventDef EventDef @relation(fields: [eventDefId], references: [id], onDelete: Cascade)
}

// Another EventDef that must have at least one completed ActiveEvent in the guild before this event is eligible.
model EventDef_Prerequisite {
  eventDefId         Int
  requiredEventDefId Int
  withinDays         Int?  // null = any past occurrence qualifies; non-null = must have fired within this many days

  eventDef         EventDef @relation("EventPrerequisites",     fields: [eventDefId],         references: [id], onDelete: Cascade)
  requiredEventDef EventDef @relation("EventIsPrerequisiteFor", fields: [requiredEventDefId],  references: [id], onDelete: Cascade)

  @@id([eventDefId, requiredEventDefId])
  @@index([requiredEventDefId])
}

// Event weight boost when an environmental condition is active (from season or weather)
model EnvCondition_EventDef {
  envConditionId Int
  eventDefId     Int

  weightMod Float  // added to effective weight when this condition is active

  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Cascade)
  eventDef     EventDef     @relation(fields: [eventDefId],     references: [id], onDelete: Cascade)

  @@id([envConditionId, eventDefId])
  @@index([eventDefId])
}


// A single step in an event chain.
//
// stepType:
//   "narrative" — auto-resolves; posts prompt text, applies effects to effectScope, then advances
//                 to nextStepId. No player input required.
//   "choice"    — patrol leader selects from EventChoiceDef options. Each choice leads to a
//                 weighted outcome roll which determines effects and the next step.
//   "combat"    — triggers an ActiveCombat for the faction vs. the defined NPC. The event chain
//                 pauses until combat resolves, then advances to winStepId or loseStepId.
//
// isStarter: true on exactly one step per EventDef — the entry point of the chain.
//
// sortOrder: display/seeding hint only — NOT used for execution order.
//            Execution flows via isStarter → outcomes / winStep / loseStep / nextStep links.
//
// expiresAfterMinutes: "choice" steps only — how long the leader has to respond before the step
//   auto-resolves via defaultChoiceDefId. null = no time limit.
model EventStepDef {
  id         Int     @id @default(autoincrement())
  eventDefId Int
  sortOrder  Int
  isStarter    Boolean @default(false)  // true on the entry-point step of the chain
  stepTypeId   Int
  prompt       String  @db.VarChar(2000)

  // ── narrative step fields ────────────────────────────────────────────────
  // effectScope: who the narrative effects apply to
  effectScopeId Int?  // null for non-narrative steps
  nextStepId  Int?   // null = event ends after this step

  // ── choice step fields ───────────────────────────────────────────────────
  expiresAfterMinutes Int?  // time window for the leader to choose; null = no limit
  defaultChoiceDefId  Int?  // choice applied automatically when the window expires

  // ── combat step fields ───────────────────────────────────────────────────
  combatEncounterDefId Int?  // which CombatEncounterDef to spawn
  winStepId            Int?  // next step when players win; null = event ends
  loseStepId           Int?  // next step when players lose; null = event ends
  winExpReward         Int   @default(0)  // exp awarded to each non-fleeing player participant on win
  winFactionRepReward  Int   @default(0)  // faction rep awarded to each non-fleeing player participant on win

  // ── relations ────────────────────────────────────────────────────────────
  eventDef           EventDef            @relation(fields: [eventDefId],           references: [id], onDelete: Cascade)
  stepType           EventStepType       @relation(fields: [stepTypeId],           references: [id], onDelete: Restrict)
  effectScope        EventParticipantScope? @relation(fields: [effectScopeId],      references: [id], onDelete: Restrict)
  nextStep           EventStepDef?       @relation("NarrativeNext", fields: [nextStepId],  references: [id], onDelete: Restrict)
  winStep            EventStepDef?       @relation("CombatWin",     fields: [winStepId],   references: [id], onDelete: Restrict)
  loseStep           EventStepDef?       @relation("CombatLose",    fields: [loseStepId],  references: [id], onDelete: Restrict)
  defaultChoice      EventChoiceDef?     @relation("StepDefaultChoice", fields: [defaultChoiceDefId], references: [id], onDelete: Restrict)
  combatEncounterDef CombatEncounterDef? @relation(fields: [combatEncounterDefId], references: [id], onDelete: SetNull)

  choices  EventChoiceDef[]
  effects  EventEffect[]

  // Back-references for self-joins
  incomingNarrativeSteps EventStepDef[] @relation("NarrativeNext")
  incomingWinSteps       EventStepDef[] @relation("CombatWin")
  incomingLoseSteps      EventStepDef[] @relation("CombatLose")

  incomingOutcomes EventOutcomeDef[] @relation("OutcomeNextStep")
  activeEvents     ActiveEvent[]

  @@unique([eventDefId, sortOrder])
  @@index([eventDefId])
  @@index([stepTypeId])
  @@index([effectScopeId])
  @@index([defaultChoiceDefId])
  @@index([combatEncounterDefId])
  @@index([nextStepId])
  @@index([winStepId])
  @@index([loseStepId])
}

// Narrative step: condition applied or removed on auto-resolve.
// Unified event effect — applies to either a narrative step or a choice outcome.
// Exactly one of stepDefId or outcomeDefId must be set (app-enforced).
//
// effectType: "condition" | "item"
//
// condition fields (effectType = "condition"):
//   conditionDefId — which condition to apply or remove
//   remove         — true = remove the condition; false = apply it
//
// item fields (effectType = "item"):
//   itemId / itemTypeId — specific item or any item of this type (mutually exclusive, app-enforced)
//                         itemTypeId: app picks a random item of that type from entity storage (isGain=false)
//                                     or a random globally seeded item of that type (isGain=true)
//   minQuantity / maxQuantity — rolled quantity range
//   isGain        — true = items added; false = items removed/consumed
//   targetScopeId — who receives/loses the item
model EventEffect {
  id           Int @id @default(autoincrement())
  effectTypeId Int

  stepDefId    Int?  // FK to EventStepDef; null for outcome effects
  outcomeDefId Int?  // FK to EventOutcomeDef; null for step effects

  // condition effect fields
  conditionDefId Int?
  remove         Boolean @default(false)

  // item effect fields
  itemId      Int?
  itemTypeId  Int?
  minQuantity Float @default(1.0)
  maxQuantity Float @default(1.0)
  isGain      Boolean @default(true)
  targetScopeId Int?

  effectType    EventEffectType   @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)
  stepDef       EventStepDef?     @relation(fields: [stepDefId],      references: [id], onDelete: Cascade)
  outcomeDef    EventOutcomeDef?  @relation(fields: [outcomeDefId],   references: [id], onDelete: Cascade)
  conditionDef  ConditionDef?     @relation(fields: [conditionDefId], references: [id], onDelete: Restrict)
  item          Item?             @relation(fields: [itemId],     references: [id], onDelete: SetNull)
  itemType      ItemType?         @relation(fields: [itemTypeId], references: [id], onDelete: SetNull)
  targetScope   EventParticipantScope? @relation(fields: [targetScopeId], references: [id], onDelete: Restrict)

  @@index([effectTypeId])
  @@index([stepDefId])
  @@index([outcomeDefId])
  @@index([conditionDefId])
  @@index([itemId])
  @@index([itemTypeId])
  @@index([targetScopeId])
}


// A choice option presented during a "choice" step. The patrol leader selects one.
// If statId or proficiencyDefId is set, a check is rolled after the choice is made.
// checkMode determines how the roll is computed across participants:
//   "individual"        — each entity rolls independently; each may get a different outcome
//   "faction_average"     — single roll using the average stat/skill across all participants
//   "leader_designates" — leader names one entity to roll on behalf of the faction
model EventChoiceDef {
  id          Int     @id @default(autoincrement())
  stepDefId   Int
  label       String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  // Optional skill/stat check made after this choice is selected
  statId      Int?
  proficiencyDefId  Int?
  difficulty  Int?
  checkModeId Int?  // null = no check; FK to EventCheckMode

  stepDef   EventStepDef    @relation(fields: [stepDefId],   references: [id], onDelete: Cascade)
  stat      Stat?           @relation(fields: [statId],      references: [id], onDelete: Restrict)
  proficiency ProficiencyDef?     @relation(fields: [proficiencyDefId],  references: [id], onDelete: Restrict)
  checkMode EventCheckMode? @relation(fields: [checkModeId], references: [id], onDelete: Restrict)

  outcomes        EventOutcomeDef[]
  defaultForSteps EventStepDef[]    @relation("StepDefaultChoice")

  @@index([stepDefId])
  @@index([checkModeId])
}

// A possible outcome for a choice — selected by weighted random roll (modified by skill check result).
// effectScope: "all_participants" | "random_participant" | "leader"
// nextStepId: null = event ends after this outcome
// endsAction: true = the linked ActionInstance is immediately marked interrupted
model EventOutcomeDef {
  id          Int    @id @default(autoincrement())
  choiceDefId Int
  name        String @db.VarChar(200)
  description String @db.VarChar(2000)

  weight        Float   @default(1.0)
  effectScopeId Int
  endsAction    Boolean @default(false)
  nextStepId    Int?

  choiceDef   EventChoiceDef   @relation(fields: [choiceDefId],   references: [id], onDelete: Cascade)
  nextStep    EventStepDef?    @relation("OutcomeNextStep", fields: [nextStepId], references: [id], onDelete: Restrict)
  effectScope EventParticipantScope @relation(fields: [effectScopeId], references: [id], onDelete: Restrict)

  effects EventEffect[]

  @@index([choiceDefId])
  @@index([effectScopeId])
  @@index([nextStepId])
}


// A running or resolved event chain instance.
//
// status:
//   "active"    — chain is progressing; currentStepId is set
//   "completed" — all steps resolved naturally
//   "expired"   — a choice step's time window elapsed with no default choice to fall back on
//
// currentStepId is the sole runtime state for the chain. History of which choices/outcomes
// led here is derivable by traversing the step graph from the starter step.
model ActiveEvent {
  id         Int    @id @default(autoincrement())
  eventDefId Int
  guildId    String

  factionId          Int?
  actionInstanceId Int?  @unique

  isActive      Boolean   @default(true)  // false = event has ended (completed or expired)
  currentStepId Int?      // which EventStepDef the chain is currently on; null when event ends

  startedAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
  expiresAt   DateTime? @db.Timestamptz  // set when the current step has a response window

  eventDef       EventDef        @relation(fields: [eventDefId],       references: [id], onDelete: Restrict)
  currentStep    EventStepDef?   @relation(fields: [currentStepId],    references: [id], onDelete: SetNull)
  faction          Faction?          @relation(fields: [factionId],          references: [id], onDelete: Cascade)
  actionInstance ActionInstance? @relation(fields: [actionInstanceId], references: [id], onDelete: Cascade)

  participants  ActiveEvent_Participant[]
  activeCombats ActiveCombat[]

  @@index([guildId])
  @@index([eventDefId])
  @@index([factionId])
  @@index([currentStepId])
}

// An entity participating in an active event chain.
model ActiveEvent_Participant {
  id            Int    @id @default(autoincrement())
  activeEventId Int
  entityId      Int
  userId        String

  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now()) @db.Timestamptz

  activeEvent ActiveEvent @relation(fields: [activeEventId], references: [id], onDelete: Cascade)
  entity      Entity      @relation(fields: [entityId],      references: [id], onDelete: Cascade)

  @@unique([activeEventId, userId])
  @@unique([activeEventId, entityId])
  @@index([activeEventId])
  @@index([entityId])
}

// Binds an EventDef to one or more named Locations.
// weightMod = 0.0: hard gate (event can only fire at this location)
// weightMod > 0.0: weight boost when the action occurs at this location
model EventDef_Location {
  eventDefId Int
  locationId Int
  weightMod  Float @default(0.0)

  eventDef EventDef  @relation(fields: [eventDefId], references: [id], onDelete: Cascade)
  location Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([eventDefId, locationId])
  @@index([locationId])
}

// Per-faction (or per-guild for global events) cooldown tracking.
// factionId = null means guild-wide cooldown (guild derived from eventDef.guildId).
model EventCooldown {
  id         Int  @id @default(autoincrement())
  eventDefId Int
  factionId    Int?

  lastEventAt DateTime @db.Timestamptz

  eventDef EventDef @relation(fields: [eventDefId], references: [id], onDelete: Cascade)

  @@unique([eventDefId, factionId])
  @@index([eventDefId])
  @@index([factionId])
}

// ============================================================
// COMBAT
// ============================================================







model CombatInitiationType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  canResultInDeath Boolean @default(false)  // spar = false; event and boss can be fatal
  isScripted       Boolean @default(false)  // boss = true; pre-defined encounter with specific enemies
  allowsFleeing    Boolean @default(false)  // event and boss allow fleeing; spar does not
  canSecondWind    Boolean @default(true)   // entity can enter second wind state at low HP

  activeCombats ActiveCombat[]
}

// isVictory: triggers loot drops, positive morale, XP bonuses
// isDefeat:  triggers retreat mechanics, morale penalty, injury consequences
// isDraw:    neither side won; partial consequences applied
// isExpired: combat ended without resolution (time/round limit, mutual retreat)
model CombatOutcome {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  isVictory  Boolean @default(false)
  isDefeat   Boolean @default(false)
  isDraw     Boolean @default(false)
  isExpired  Boolean @default(false)  // combat ended without resolution (time/round limit, mutual retreat)

  activeCombats ActiveCombat[]
}

//             "advantage" | "disadvantage" | "guard" | "taunt" | "parry" | "absorb" | "dodge_stance"
//             "counterattack" | "suppress" | "dispel" | "untargetable"
// isPerRound:           fires actively each round rather than applying as a passive modifier
// dealsDamage:          applies damage each round (bleed, burn, poison tick)
// restoresHealth:       restores HP each round (regeneration)
// modifiesRoll:         adds/subtracts from a roll result (hit_mod, damage_mod)
// modifiesStat:         changes a base stat value while active
// deniesActions:        prevents the entity from acting (stun, paralysis)
// modifiesAC:           changes the AC value that attack rolls are checked against
// grantsAdvantage:      roll twice, take higher
// grantsDisadvantage:   roll twice, take lower
// redirectsDamage:      incoming damage to a protected ally is rerouted to the effect-holder (guard)
// forcesTargeting:      enemies must select the effect-holder as their target (taunt)
// isReactive:           effect triggers on an incoming attack rather than on action use (parry, counterattack)
// absorbsDamage:        creates a damage buffer that absorbs hits before HP is reduced (absorb)
// grantsEvasion:        chance-based complete avoidance of an incoming attack (dodge_stance)
// enablesCounterattack: triggers an automatic attack when the effect-holder is hit (counterattack)
// suppressesReactive:   prevents the target's reactive effects (parry, counterattack) from firing (suppress)
// removesEffects:       strips existing active effects from the target (dispel)
// preventedAsTarget:    effect-holder cannot be selected as a target (untargetable)
model CombatEffectType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  isPerRound           Boolean @default(false)
  dealsDamage          Boolean @default(false)
  restoresHealth       Boolean @default(false)
  modifiesRoll         Boolean @default(false)
  modifiesStat         Boolean @default(false)
  deniesActions        Boolean @default(false)
  modifiesAC           Boolean @default(false)
  grantsAdvantage      Boolean @default(false)
  grantsDisadvantage   Boolean @default(false)
  redirectsDamage      Boolean @default(false)
  forcesTargeting      Boolean @default(false)
  isReactive           Boolean @default(false)
  absorbsDamage        Boolean @default(false)
  grantsEvasion        Boolean @default(false)
  enablesCounterattack Boolean @default(false)
  suppressesReactive   Boolean @default(false)
  removesEffects       Boolean @default(false)
  preventedAsTarget    Boolean @default(false)

  combatEffects        ConditionDef_CombatEffect[]
  profileBehaviors      ItemEquipmentProfile[]        @relation("ProfileBehaviorEffect")
  activeBehaviorEffects ActiveCombat_BehaviorEffect[] @relation("ActiveBehaviorEffectType")
}

// Used by damage_mod combat effects to express roll-based modifiers instead of flat values.


// Pre-populated categories that control turn economy.
// Each entity may use one action per category per turn.
model CombatActionCategory {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  description String? @db.VarChar(500)

  actionsAllowedPerRound Int @default(1)

  equipmentProfiles   ItemEquipmentProfile[]
  combatActionRecords ActiveCombat_Action[]
}

// Used by SpeciesCombatBehavior to define how an NPC picks targets offensively and for support.
model CombatTargetStrategy {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  offensiveUsers SpeciesCombatBehavior[] @relation("OffensiveTargetStrategy")
  supportUsers   SpeciesCombatBehavior[] @relation("SupportTargetStrategy")
}


// Damage type seed table — covers both physical and elemental categories.
// Physical: blunt, slashing, piercing
// Global seed: Physical | Magical | True
// Physical: reduced by physical armor/defense
// Magical:  bypasses physical armor; checked against magical resistance
// True:     bypasses all defenses; cannot be resisted or immuned
model DamageCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  damageTypes DamageType[]
}

// Guild-extensible — guildId = "global" for base types; guilds may add their own.
// categoryId drives engine defense resolution; name is the display label.
// Resistance/immunity to a damage type is modelled via ConditionDef_DamageModifier on inherentTrait conditions.
model DamageType {
  id       Int    @id @default(autoincrement())
  guildId  String @default("global") @db.VarChar(50)
  name     String @db.VarChar(50)
  categoryId Int

  category DamageCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  equipmentPrimary   ItemEquipmentProfile[]      @relation("EquipmentDamageType")
  equipmentElemental ItemEquipmentProfile[]      @relation("EquipmentElementalDamageType")
  conditionModifiers   ConditionDef_DamageModifier[]
  abilityDamageModifiers Ability_DamageModifier[]

  @@unique([guildId, name])
  @@index([guildId])
  @@index([categoryId])
}

// AI combat behaviour profile for a species. One-to-one with Species.
// Used by isAiControlled participants; ignored for player-controlled entities.
// All species should have this seeded so NPC cats, foxes, badgers, etc. all have defined behaviour out of the box.
//
// Action category weights — normalised into a probability distribution each turn to pick which type of action to use.
//   e.g. attackWeight 2.0, healWeight 1.0 → 67% chance to attack, 33% chance to heal (ignoring zero-weight categories).
//   A category is only eligible if the species has at least one equipped item with a combat action of that actionType.
//
// Target strategies — FK to CombatTargetStrategy seed table ("lowest_health" | "highest_health" | "lowest_strength" | "random")
//   offensiveTargetStrategyId: used when choosing a target for attacks and debuffs.
//   supportTargetStrategyId:   used when choosing a target for buffs and heals.
//   strategyWeight: probability of following the named strategy; (1 - strategyWeight) = random pick.
//   One strategyWeight covers both strategies — species are assumed to be consistently decisive or erratic.
model SpeciesCombatBehavior {
  speciesId Int @id

  // Outer action-category weights
  attackWeight Float @default(1.0)
  buffWeight   Float @default(0.5)
  debuffWeight Float @default(0.5)
  healWeight   Float @default(0.3)

  // Target selection
  offensiveTargetStrategyId Int  // attacks + debuffs
  supportTargetStrategyId   Int  // buffs + heals
  strategyWeight            Float @default(0.8)  // probability of following the strategy; remainder = random

  species                   Species              @relation(fields: [speciesId],                   references: [id], onDelete: Cascade)
  offensiveTargetStrategy   CombatTargetStrategy @relation("OffensiveTargetStrategy", fields: [offensiveTargetStrategyId], references: [id], onDelete: Restrict)
  supportTargetStrategy     CombatTargetStrategy @relation("SupportTargetStrategy",   fields: [supportTargetStrategyId],   references: [id], onDelete: Restrict)

  @@index([offensiveTargetStrategyId])
  @@index([supportTargetStrategyId])
}

// Default item loadout applied to all entities of this species at generation time (players and NPCs alike).
// autoEquip: true = item is equipped immediately (StoredItem.isEquipped = true); false = placed in storage only.
// quantity: how many of the item to give (e.g. 3 charges of a healing herb).
// aiWeight: relative probability weight for NPC AI action selection when this item's combat actions are
//           considered. Ignored for player-controlled entities. Tune per species to shape how often an
//           NPC uses one biological trait over another (e.g. claws preferred 2:1 over bite).
model SpeciesDefaultLoadout {
  id        Int @id @default(autoincrement())
  speciesId Int
  itemId    Int

  quantity  Int     @default(1)
  autoEquip Boolean @default(true)
  aiWeight  Float   @default(1.0)

  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId],    references: [id], onDelete: Cascade)

  @@unique([speciesId, itemId])
  @@index([speciesId])
  @@index([itemId])
}


// A live combat encounter. Spawned by event chains (combat steps), /spar, or admin boss fights.
// When spawned by an event chain, activeEventId links back to the originating ActiveEvent.
// On completion, the event system reads winningAllyFactionId to determine which participants "won"
// and advances the chain to winStepId or loseStepId accordingly.
//
// initiationType: "spar" | "event" | "patrol" | "boss"
//   "spar"    — training fight; ItemAction.allowedInSpar = false actions are suppressed
//   "event"   — spawned from an event chain combat step; no patrol leader required
//   "patrol"  — spawned during a patrol or hunt; requiresPatrolLeader = true
//   "boss"    — admin-initiated boss fight
//
// requiresPatrolLeader: when true, exactly one participant must have isPatrolLeader = true;
//   ItemAction.requiresPatrolLeader actions are restricted to that participant.
//
// currentTurnOrder: the turnOrder value of the participant currently taking their turn.
//   Participants and NPC entities each have a unique turnOrder set at combat start.
//
// outcome: null = ongoing; "win" = one ally faction remains; "lose" = all player-side participants defeated or fled;
//   "draw" = all factions eliminated simultaneously; "completed" = inactivity timeout (isExpired = true).
// winningAllyFactionId: the allyFactionId of the surviving faction; null if draw, completed, or ongoing.
model ActiveCombat {
  id                   Int     @id @default(autoincrement())
  guildId              String
  combatEncounterDefId Int?    // null for standalone (spar/admin/patrol) combats not tied to a def

  // Link back to the event chain that spawned this combat; null for standalone combats
  activeEventId Int?

  initiationTypeId     Int
  requiresPatrolLeader Boolean  @default(false)
  isActive             Boolean  @default(true)  // false = combat has ended
  currentRound         Int      @default(1)
  currentTurnOrder     Int      @default(1)  // matches turnOrder on the participant whose turn it currently is
  outcomeId            Int?     // null = ongoing
  winningAllyFactionId   Int?     // allyFactionId of the surviving faction; null if draw or ongoing

  startedAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz

  combatEncounterDef CombatEncounterDef?  @relation(fields: [combatEncounterDefId], references: [id], onDelete: SetNull)
  activeEvent        ActiveEvent?         @relation(fields: [activeEventId],        references: [id], onDelete: Cascade)
  initiationType     CombatInitiationType @relation(fields: [initiationTypeId],     references: [id], onDelete: Restrict)
  outcome            CombatOutcome?       @relation(fields: [outcomeId],            references: [id], onDelete: Restrict)

  participants      ActiveCombat_Participant[]
  actions           ActiveCombat_Action[]
  behaviorEffects   ActiveCombat_BehaviorEffect[]
  entityConditions  EntityCondition[]

  @@index([guildId])
  @@index([activeEventId])
  @@index([combatEncounterDefId])
  @@index([initiationTypeId])
  @@index([outcomeId])
}

// Per-entity combat state for an active combat encounter.
// Covers all participant types: player cats, side characters, and NPC entities (entityType = "npc").
//
// allyFactionId: participants sharing this value are allies; different values = enemies.
//   Combat ends when only one distinct allyFactionId remains among non-fled, non-defeated participants.
// turnOrder: unique position in initiative order within this combat (1 = acts first).
//   Resolved at combat start (initiative ties broken app-side), then persisted.
//
// isAiControlled: true for NPC entity types; false for player-controlled entities.
//   When true, action selection and targeting are driven by entity.species.combatBehavior — read live, no snapshot.
//
// dropTableId: snapshotted from species.dropTableId at spawn time; null for player-controlled entities.
//   Rolled when this participant is defeated to determine loot drops.
//
// isPatrolLeader: true for the designated leader when ActiveCombat.requiresPatrolLeader = true.
//   At most one participant per combat may have this set.
//
// HP and AC are tracked on the entity directly — the combat engine reads EntityStats and Species live.
// inSecondWind: true when the entity has triggered second wind (hit 0 HP and chosen to recover).
//   At combat end: if inSecondWind = true and EntityStats.currentHp < 50% of EntityStats.maxHp,
//   a second wind consequence condition (ConditionDef.isSecondWindConsequence = true) is rolled and applied.
//   NPC entities never trigger second wind (isAiControlled = true entities are simply defeated at 0 HP).
// hasFled: entity chose to flee; removed from turn order, earns no exp or rep.
// isDefeated: entity eliminated (declined second wind, hit 0 HP while inSecondWind, or NPC at 0 HP).
// Guard and taunt state are not cached here — query ActiveCombat_BehaviorEffect directly:
//   guard: WHERE behaviorKey = "guard" AND linkedParticipantId = <this participant>
//   taunt: WHERE behaviorKey = "taunt" AND affectedParticipantId = <this participant>
model ActiveCombat_Participant {
  id             Int  @id @default(autoincrement())
  activeCombatId Int
  entityId       Int

  allyFactionId    Int     // same value = ally; different value = enemy
  turnOrder      Int     // unique within this combat; 1 = acts first
  isPatrolLeader Boolean @default(false)

  isAiControlled Boolean @default(false)
  // AI targeting behaviour is read at decision time from entity.species.combatBehavior — no snapshot needed.

  dropTableId Int?  // null for player entities; snapshotted from species.dropTableId at spawn time

  inSecondWind   Boolean @default(false)
  hasFled        Boolean @default(false)
  isDefeated     Boolean @default(false)

  activeCombat    ActiveCombat              @relation(fields: [activeCombatId], references: [id], onDelete: Cascade)
  entity          Entity                    @relation(fields: [entityId],       references: [id], onDelete: Cascade)
  dropTable       DropTable?                @relation(fields: [dropTableId],    references: [id], onDelete: SetNull)
  actionCooldowns ActiveCombat_Participant_ActionCooldown[]
  behaviorEffects ActiveCombat_BehaviorEffect[] @relation("BehaviorEffectTarget")
  linkedBehaviors ActiveCombat_BehaviorEffect[] @relation("BehaviorEffectLinked")

  @@unique([activeCombatId, entityId])
  @@unique([activeCombatId, turnOrder])
  @@index([activeCombatId])
  @@index([dropTableId])
}

// Per-action cooldown state for a combat participant.
// A row exists only while the action is on cooldown; deleted when roundsRemaining reaches 0.
model ActiveCombat_Participant_ActionCooldown {
  id                 Int @id @default(autoincrement())
  participantId      Int
  equipmentProfileId Int

  roundsRemaining Int

  participant      ActiveCombat_Participant @relation(fields: [participantId],      references: [id], onDelete: Cascade)
  equipmentProfile ItemEquipmentProfile     @relation(fields: [equipmentProfileId], references: [id], onDelete: Cascade)

  @@unique([participantId, equipmentProfileId])
  @@index([participantId])
}

// Persistent behavioral effects lasting one or more rounds (guard, taunt, etc.).
// At round start: decrement roundsRemaining and delete rows that reach 0.
//
// behaviorKey: "guard" | "taunt" | extensible
// Directional semantics:
//   guard:   affectedParticipantId = the guarding entity;  linkedParticipantId = the guarded participant
//   taunt:   affectedParticipantId = the taunted entity;   linkedParticipantId = the taunting participant
//   parry:   affectedParticipantId = the parrying entity;  linkedParticipantId = null
//   absorb:  affectedParticipantId = the absorbing entity; linkedParticipantId = null
model ActiveCombat_BehaviorEffect {
  id             Int @id @default(autoincrement())
  activeCombatId    Int
  effectTypeId      Int

  affectedParticipantId Int
  linkedParticipantId   Int?

  roundsRemaining Int

  activeCombat        ActiveCombat              @relation(fields: [activeCombatId],    references: [id], onDelete: Cascade)
  effectType          CombatEffectType          @relation("ActiveBehaviorEffectType",  fields: [effectTypeId],           references: [id], onDelete: Restrict)
  affectedParticipant ActiveCombat_Participant  @relation("BehaviorEffectTarget",      fields: [affectedParticipantId],  references: [id], onDelete: Cascade)
  linkedParticipant   ActiveCombat_Participant? @relation("BehaviorEffectLinked",       fields: [linkedParticipantId],    references: [id], onDelete: Cascade)

  @@unique([affectedParticipantId, effectTypeId])
  @@index([activeCombatId])
  @@index([effectTypeId])
  @@index([affectedParticipantId])
  @@index([linkedParticipantId])
}

// One action taken during a combat turn — stored for Discord message reconstruction.
// All actors and targets are entities (player cats, side characters, or NPC entities).
model ActiveCombat_Action {
  id             Int @id @default(autoincrement())
  activeCombatId Int
  roundNumber    Int
  turnIndex      Int  // position within the round (for ordering)

  actorEntityId      Int
  actionCategoryId   Int
  equipmentProfileId Int

  targetEntityId Int?  // null for self-targeted or area actions resolved entirely app-side

  hitRoll        Int?
  hitModifier    Int?
  hit            Boolean?
  damageRoll     Int?
  damageModifier Int?
  damageDealt    Int?
  healDealt      Int?

  secondWindTriggered Boolean  @default(false)

  occurredAt DateTime @default(now()) @db.Timestamptz

  activeCombat     ActiveCombat         @relation(fields: [activeCombatId],     references: [id], onDelete: Cascade)
  actionCategory   CombatActionCategory @relation(fields: [actionCategoryId],   references: [id], onDelete: Restrict)
  equipmentProfile ItemEquipmentProfile @relation(fields: [equipmentProfileId], references: [id], onDelete: Restrict)
  actorEntity      Entity               @relation("CombatActionActor",  fields: [actorEntityId],  references: [id], onDelete: Cascade)
  targetEntity     Entity?              @relation("CombatActionTarget", fields: [targetEntityId], references: [id], onDelete: SetNull)
  appliedConditions EntityCondition[]

  @@unique([activeCombatId, roundNumber, turnIndex])
  @@index([activeCombatId, roundNumber])
  @@index([actionCategoryId])
  @@index([equipmentProfileId])
  @@index([actorEntityId])
  @@index([targetEntityId])
}


// Defines a reusable NPC combat encounter that event combat steps can reference.
// When an event chain reaches a "combat" step, an ActiveCombat is created from this definition.
//
// Two spawn modes — at least one must be used; both can be combined (e.g. a named boss + generic adds):
//
//   Species mode (speciesId + npcCount set):
//     The spawner creates npcCount ephemeral Entity records of the given species, initialises
//     their EntityStats from species defaults, equips them from SpeciesDefaultLoadout, and snapshots
//     species.dropTableId onto each ActiveCombat_Participant.
//
//   Named entity mode (one or more CombatEncounterDef_NamedEntity rows):
//     Specific pre-created NPC entities (e.g. hand-crafted bosses with custom stats, gear,
//     and loot tables) participate directly. No ephemeral entity is created — named entities
//     persist after combat.
model CombatEncounterDef {
  id       Int    @id @default(autoincrement())
  guildId  String @default("global") @db.VarChar(50)
  codeName String @db.VarChar(200)  // snake_case slug; unique per guild
  name     String @db.VarChar(200)

  // Species mode (optional)
  speciesId Int?
  npcCount  Int?

  species       Species?                        @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  namedEntities CombatEncounterDef_NamedEntity[]
  eventSteps    EventStepDef[]
  activeCombats ActiveCombat[]

  @@unique([guildId, codeName])
  @@index([guildId])
  @@index([guildId, name])
  @@index([speciesId])
}

// Named NPC entities attached to a CombatEncounterDef.
// Each row pins one pre-created entity to the encounter.
model CombatEncounterDef_NamedEntity {
  combatEncounterDefId Int
  entityId             Int

  encounterDef CombatEncounterDef @relation(fields: [combatEncounterDefId], references: [id], onDelete: Cascade)
  entity       Entity             @relation(fields: [entityId],             references: [id], onDelete: Restrict)

  @@id([combatEncounterDefId, entityId])
  @@index([entityId])
}

// ============================================================
// FARMING & PLANTS
// ============================================================




model PlantType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  plantDefs                   PlantDef_PlantType[]
  plantTypeEnvConditionEffect PlantType_EnvConditionEffect[]
}



// ─────────────────────────────────────────────
// FARMING SYSTEM
// ─────────────────────────────────────────────

// Lookup table of heritable plant trait definitions. Seeded globally; never altered via app.
// Traits: growth_rate, yield, potency, nutrition, decay_resistance, propagation_yield
model PlantTrait {
  id          Int     @id @default(autoincrement())
  codeName    String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)

  plantDefTraits PlantDef_Trait[]
}

// Definition of a growable plant. All PlantDefs are guild-scoped — no PlantDef rows have guildId = "global".
// Base plants are seeded at guild initialization time under the guild's own guildId, not as global records.
// Mutated variants are ephemeral PlantDef rows created by the cross-breeding system.
// Ephemeral rows are deleted when no PlotCrop.plantDefId and no Item.plantDefId references them.
model PlantDef {
  id          Int     @id @default(autoincrement())
  guildId     String  @db.VarChar(50)
  codeName    String  @db.VarChar(200)   // snake_case slug unique per guild; ephemeral: base_codeName + random suffix
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  isEphemeral    Boolean @default(false)    // false = seeded base plant; true = cross-breeding-created variant
  rootPlantDefId Int?                       // FK → PlantDef; null for base plants; always the original non-ephemeral ancestor

  growthCap          Int      // base growth points to advance one stage; 1 point = 1 day at base rate
  growthStages       Int      // stages from seedling to harvestable
  maxHarvests        Int      // harvests before only uproot_crop is available (~3 for most plants)
  harvestDropTableId Int      // FK → DropTable; used for harvest_crop and wild foraging
  propagationItemId  Int?     // FK → Item; the seed/spore/cutting consumed on planting; null if not yet assigned
  mutationChance     Float    @default(0.7)    // controls mutations at cross-breeding; floor = guaranteed, decimal = chance of +1

  rootPlantDef   PlantDef?  @relation("PlantDefLineage", fields: [rootPlantDefId], references: [id], onDelete: Restrict)
  variants       PlantDef[] @relation("PlantDefLineage")

  harvestDropTable  DropTable @relation("PlantDefHarvestDrop", fields: [harvestDropTableId], references: [id], onDelete: Restrict)
  propagationItem   Item?     @relation("PlantDefPropagationItem", fields: [propagationItemId], references: [id], onDelete: SetNull)

  seedItems             Item[]               @relation("ItemPlantDef")  // items whose Item.plantDefId points here
  plantTypes            PlantDef_PlantType[]
  plotTypes             PlantDef_PlotType[]
  biomes                PlantDef_Biome[]
  envConditionEffects   PlantDef_EnvConditionEffect[]
  traits                PlantDef_Trait[]
  growthStages          PlantDef_GrowthStage[]
  plotCrops             PlotCrop[]

  @@unique([guildId, codeName])
  @@index([guildId])
}

// Classification tags for a plant def — many-to-many.
// Drives PlantType_EnvConditionEffect lookups: type-level responses apply to all member plants
// unless overridden by a PlantDef_EnvConditionEffect row on the specific plant.
model PlantDef_PlantType {
  plantDefId  Int
  plantTypeId Int

  plantDef  PlantDef  @relation(fields: [plantDefId],  references: [id], onDelete: Cascade)
  plantType PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Restrict)

  @@id([plantDefId, plantTypeId])
  @@index([plantTypeId])
}

// Type-level env condition response — applies to all PlantDefs carrying this PlantType.
// Overridden per-plant by PlantDef_EnvConditionEffect.
// Mirrors SpeciesType_EnvConditionEffect.
model PlantType_EnvConditionEffect {
  id             Int   @id @default(autoincrement())
  plantTypeId    Int
  envConditionId Int
  relationTypeId Int
  effectTypeId   Int?
  value          Float?

  plantType    PlantType    @relation(fields: [plantTypeId],    references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)
  relationType RelationType @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)
  effectType   EffectType?  @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)

  @@unique([plantTypeId, envConditionId, relationTypeId, effectTypeId])
  @@index([plantTypeId])
  @@index([envConditionId])
}

// Trait values for a PlantDef. Ephemeral PlantDefs carry their own rows with mutated values.
// minValue / maxValue are copied verbatim from the root PlantDef and never drift — only value drifts.
model PlantDef_Trait {
  plantDefId   Int
  plantTraitId Int
  value        Float  // actual value for this trait on this plant
  minValue     Float  // floor — cross-breeding cannot go below this (from root PlantDef)
  maxValue     Float  // ceiling — cross-breeding cannot go above this (from root PlantDef)

  plantDef   PlantDef   @relation(fields: [plantDefId],   references: [id], onDelete: Cascade)
  plantTrait PlantTrait @relation(fields: [plantTraitId], references: [id], onDelete: Restrict)

  @@id([plantDefId, plantTraitId])
}

// Display labels for each growth stage of a plant. Optional — stages without a row show the integer stage number.
// Ephemeral PlantDefs inherit their root's rows (same rootPlantDefId → same stage labels).
model PlantDef_GrowthStage {
  plantDefId Int
  stage      Int           // matches PlotCrop.currentStage (0 = seedling, growthStages = harvestable)
  label      String        @db.VarChar(100)   // e.g. "Seedling", "Sprouting", "Budding", "Flowering", "Mature"
  description String?      @db.VarChar(500)   // optional flavour text shown in plot inspection

  plantDef PlantDef @relation(fields: [plantDefId], references: [id], onDelete: Cascade)

  @@id([plantDefId, stage])
}

// Biome affinities for a plant. Controls wild foraging find rates and cultivated growth rate modifiers.
// No rows = grows in any biome at 0.0 (neutral) but never found during wild foraging.
// spawnRate is only read from the base (rootPlantDefId = null) PlantDef.
model PlantDef_Biome {
  plantDefId          Int
  biomeId             Int
  spawnRate           Float @default(0.0)  // base weight per foraging attempt; scaled by PlantDef_EnvConditionEffect spawn_rate rows; only read from base PlantDef
  growthRateModifier  Float @default(0.0)  // added to growth rate for crops in this biome; 0.0 = no effect; ephemerals inherit and may mutate this value

  plantDef PlantDef @relation(fields: [plantDefId], references: [id], onDelete: Cascade)
  biome    Biome    @relation(fields: [biomeId],    references: [id], onDelete: Restrict)

  @@id([plantDefId, biomeId])
}


// Per-plant response to an active env condition. Consolidates all env-condition
// relationships for a plant into one table, including hard planting requirements.
//
// effectType:       "cultivation" | "spawn_rate" | "spawn_weight" | "growth_rate" | "survival"
// relationType:     "requires" | "increase" | "decrease" | "block" | "kills"
// value:            magnitude, > 0.0; null when relationType is "requires" or "block"
//
//   cultivation / requires — planting prerequisite. The condition must be present in the
//                     combined active set (location + PlotType_EnvCondition + env_inject stacks)
//                     for planting to be allowed AND for growth ticks to advance.
//                     If lost after planting, growth pauses until restored.
//                     No value. effectType must be "cultivation" for all "requires" rows.
//
//   spawn_rate   — wild foraging find chance (multiplies PlantDef_Biome.spawnRate)
//   spawn_weight — quantity found per forage attempt
//   growth_rate  — cultivated growth tick rate (farming only)
//   survival     — per-tick death probability check. Used with "kills" relationshipType only.
//                  value = probability (0.0–1.0) that the crop dies on each growth tick
//                  while the condition is active. Structure env_override upgrades targeting
//                  this condition reduce the effective probability:
//                    effectiveKillChance = value × (1.0 − conditionOverride)
//
// Stacking formula (per effectType, across all active conditions):
//   netModifier = 1.0 + Σ(increase.value × stackCount) − Σ(decrease.value × stackCount)
//   "block" on any effectType excludes the entity entirely — takes precedence over all modifiers.
//
// A single env condition can have multiple rows for the same plant with different effectTypes.
// e.g. Damp on Rice: requires(cultivation) + increase(growth_rate) — must be present AND boosts growth.
model PlantDef_EnvConditionEffect {
  id             Int  @id @default(autoincrement())
  plantDefId     Int
  envConditionId Int
  relationTypeId Int
  effectTypeId   Int?
  value          Float?                   // null when block; > 0.0 otherwise (enforced app-side)

  plantDef     PlantDef     @relation(fields: [plantDefId],     references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)
  relationType RelationType @relation(fields: [relationTypeId], references: [id], onDelete: Restrict)
  effectType   EffectType?  @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)

  @@unique([plantDefId, envConditionId, relationTypeId, effectTypeId])
  @@index([plantDefId])
  @@index([envConditionId])
}

// Which plot types a plant can grow in and at what growth rate delta.
// No rows = can grow in any plot type at 0.0 (neutral).
// If rows exist, plant may only be placed in matching plot types.
model PlantDef_PlotType {
  plantDefId          Int
  plotTypeId          Int
  growthRateModifier  Float @default(0.0)  // added to growth rate; 0.0 = no effect; negative values reduce it

  plantDef PlantDef @relation(fields: [plantDefId], references: [id], onDelete: Cascade)
  plotType PlotType @relation(fields: [plotTypeId], references: [id], onDelete: Restrict)

  @@id([plantDefId, plotTypeId])
}

// Guild-defined plot environment type. Admins create these per server — no globally seeded values.
// e.g. "Open Farmland", "Hydroponics Bay", "Mushroom Cave", "Tidal Bed", "Shaded Grove"
// Each plot type can declare env conditions that are always active for plants in it,
// stacking with the location's real env conditions in the growth formula.
model PlotType {
  id          Int     @id @default(autoincrement())
  guildId     String  @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)

  // Maximum soilQuality achievable via composting. Prevents indefinite improvement.
  // e.g. 1.0 = soil can contribute at most +100% to growth/yield. Rocky terrain might cap at 0.3.
  soilQualityCap Float @default(1.0)

  plantDefPlotTypes PlantDef_PlotType[]
  farmingConfigs    StructureDef_FarmingConfig[]
  envConditions     PlotType_EnvCondition[]

  @@unique([guildId, name])
  @@index([guildId])
}

// Env conditions that are always active for plants growing in this plot type.
// These stack additively with the location's actual env conditions.
// Use this to model controlled environments: a hydroponics bay always has Cultivated + Watered;
// a mushroom cave always has Damp; an open field has nothing (growth depends on real location env).
model PlotType_EnvCondition {
  plotTypeId     Int
  envConditionId Int

  plotType     PlotType     @relation(fields: [plotTypeId],     references: [id], onDelete: Cascade)
  envCondition EnvCondition @relation(fields: [envConditionId], references: [id], onDelete: Restrict)

  @@id([plotTypeId, envConditionId])
}

// A single growing slot within a farming structure. One Plot = one PlotCrop at a time.
// Created when a farming structure is built (basePlotCount rows) and when plot_count upgrades complete.
// PlotType is derived via Plot → Structure → StructureDef → StructureDef_FarmingConfig.
// TendRecord rows and Buff rows live on Plot (not on the crop). carePoints lives on PlotCrop.
// On PlotCrop removal (uproot or replant): delete Plot_TendRecord rows, delete Plot_Buff rows.
model Plot {
  id          Int     @id @default(autoincrement())
  structureId Int                  // FK → Structure (farming-type)
  name        String? @db.VarChar(100)
  soilQuality Float   @default(0.0)  // added to growth rate; 0.0 = no effect; positive = enriched; negative = degraded

  createdAt DateTime @default(now()) @db.Timestamptz

  structure   Structure         @relation(fields: [structureId], references: [id], onDelete: Cascade)
  buffs       Plot_Buff[]
  crops       PlotCrop[]
  tendRecords Plot_TendRecord[]
}

// Active timed buffs on a plot, written when a skilled farmer tends and has a matching Ability_ActionTrigger.
// PK is (plotId, sourceEntityId, effectTypeId) — one active buff per effect type per entity per plot.
model Plot_Buff {
  plotId         Int
  sourceEntityId Int?  // null for event-system-written debuffs (blights, droughts, etc.) that have no entity source
  effectTypeId   Int
  effectValue    Float
  appliedAt      DateTime @default(now()) @db.Timestamptz
  expiresAt      DateTime @db.Timestamptz

  plot       Plot        @relation(fields: [plotId],         references: [id], onDelete: Cascade)
  entity     Entity?     @relation(fields: [sourceEntityId], references: [id], onDelete: Cascade)
  effectType EffectType  @relation(fields: [effectTypeId],   references: [id], onDelete: Restrict)

  @@id([plotId, sourceEntityId, effectTypeId])
}

// A live instance of a plant growing at a plot. One PlotCrop per plot at a time (enforced via Plot).
// Owns the plant's lifecycle metrics: care points, growth state, harvest count, planted timestamp.
// Tending cooldown records and buffs live on Plot (per-slot), but carePoints lives here because
// it tracks this specific plant's care history and pairs directly with plantedAt for cross-breeding.
model PlotCrop {
  id                Int      @id @default(autoincrement())
  plotId            Int      @unique   // one crop per plot at a time
  plantDefId        Int
  plantedAt         DateTime @default(now()) @db.Timestamptz  // when this plant was put in the ground; denominator for cross-breeding care percentage
  currentStage      Int      @default(0)    // 0 = seedling; PlantDef.growthStages = harvestable
  growthProgression Float    @default(0.0)  // accumulated growth points this stage; resets when a stage advances
  harvestCount      Int      @default(0)    // increments each harvest; blocks harvest_crop when >= PlantDef.maxHarvests
  carePoints        Int       @default(0)    // accumulated tending care points for this plant's lifetime; used at cross-breeding for mutation bias
  lastCrossbredAt   DateTime? @db.Timestamptz // null = never cross-bred; updated on both parent crops when a cross-breed resolves

  plot     Plot     @relation(fields: [plotId],     references: [id], onDelete: Cascade)
  plantDef PlantDef @relation(fields: [plantDefId], references: [id], onDelete: Restrict)
}

// Tracks when each tending action type was last performed on a plot slot.
// Enforces the per-systemType cooldown (crop-level lock — one entity tending resets the clock for all).
// Deleted when the PlotCrop is removed (PlotCrop deletion also removes its carePoints).
// PK is (plotId, systemType).
model Plot_TendRecord {
  plotId          Int
  systemType      String   @db.VarChar(50)   // FK → ActionSystemType
  lastPerformedAt DateTime @db.Timestamptz

  plot             Plot             @relation(fields: [plotId],    references: [id], onDelete: Cascade)
  actionSystemType ActionSystemType @relation(fields: [systemType], references: [id], onDelete: Restrict)

  @@id([plotId, systemType])
}

// ============================================================
// MEDICINE
// ============================================================







// One row per examination. A healer entity (medicEntityId) may examine a
// patient (patientEntityId) at most once per calendar day — enforced at
// the application layer. The highest rollResult across all examiners for
// a given patient on a given day feeds into EntityCondition.discoveryLevel.
model EntityInspectionLog {
  id              Int      @id @default(autoincrement())
  patientEntityId Int
  medicEntityId   Int
  inspectedAt     DateTime @default(now()) @db.Timestamptz
  rollResult      Int      // Medicine/Perception skill roll; determines which symptoms are revealed

  patient Entity @relation("InspectionPatient", fields: [patientEntityId], references: [id], onDelete: Cascade)
  medic   Entity @relation("InspectionMedic",   fields: [medicEntityId],   references: [id], onDelete: Cascade)

  @@index([patientEntityId])
  @@index([medicEntityId])
}

// One row per treatment. A given condition (entityConditionId) may be
// treated at most once per calendar day — enforced at the application layer.
// progressionChange is the amount subtracted from EntityCondition.progressionValue
// that session; stored for history and auditing.
model EntityTreatmentLog {
  id                Int      @id @default(autoincrement())
  entityConditionId Int
  medicEntityId     Int
  itemId            Int?     // null only if non-item treatment (e.g. enforced rest); normally required
  treatedAt         DateTime @default(now()) @db.Timestamptz
  progressionChange Float    // amount subtracted from progressionValue (positive = reduction)

  entityCondition EntityCondition @relation(fields: [entityConditionId], references: [id], onDelete: Cascade)
  medic           Entity          @relation("TreatmentMedic", fields: [medicEntityId], references: [id], onDelete: Cascade)
  item            Item?           @relation(fields: [itemId],            references: [id], onDelete: SetNull)

  @@index([entityConditionId])
  @@index([medicEntityId])
  @@index([itemId])
}
