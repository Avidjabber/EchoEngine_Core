{
  "name": "echoengine-core",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate:primary": "prisma generate --schema=prisma/primary/schema.prisma",
    "db:migrate:dev:primary": "prisma migrate dev --schema=prisma/primary/schema.prisma",
    "db:migrate:deploy:primary": "prisma migrate deploy --schema=prisma/primary/schema.prisma",
    "db:push:primary": "prisma db push --schema=prisma/primary/schema.prisma",
    "db:studio:primary": "prisma studio --schema=prisma/primary/schema.prisma",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "cron": "^4.4.0",
    "node-cron": "^4.2.1"
    "@prisma/client": "^7.8.0"
  }
}
