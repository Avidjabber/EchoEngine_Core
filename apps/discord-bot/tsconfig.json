{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@prisma/primary": ["../../prisma/primary/generated/client"],
      "@prisma/primary/*": ["../../prisma/primary/generated/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
